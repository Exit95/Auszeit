version: '3.8'

services:
  web:
    image: "[2a01:4f8:202:1129:2447:2447:1:900]:5000/keramik-auszeit-de:latest"
    environment:
      - ADMIN_PASSWORD=${ADMIN_PASSWORD}
      - SUPERUSER_PASSWORD=${SUPERUSER_PASSWORD}
      - TOTP_SECRET=${TOTP_SECRET}
      - SMTP_HOST=smtp.web.de
      - SMTP_PORT=587
      - SMTP_USER=${SMTP_USER}
      - SMTP_PASS=${SMTP_PASS}
      - BOOKING_EMAIL=${BOOKING_EMAIL}
      - FROM_EMAIL=${FROM_EMAIL}
      - S3_ENDPOINT=https://nbg1.your-objectstorage.com
      - S3_BUCKET=${S3_BUCKET}
      - S3_ACCESS_KEY_ID=${S3_ACCESS_KEY_ID}
      - S3_SECRET_ACCESS_KEY=${S3_SECRET_ACCESS_KEY}
      - S3_REGION=eu-central
      - S3_PREFIX=Auszeit/
      - STRIPE_SECRET_KEY=${STRIPE_SECRET_KEY}
      - STRIPE_PUBLISHABLE_KEY=${STRIPE_PUBLISHABLE_KEY}
    networks:
      - public-ingress
    deploy:
      replicas: 1
      placement:
        constraints:
          - node.role == manager
      labels:
        - "traefik.enable=true"
        - "traefik.http.routers.keramik-auszeit-de.rule=Host(`keramik-auszeit.de`) || Host(`www.keramik-auszeit.de`)"
        - "traefik.http.routers.keramik-auszeit-de.entrypoints=websecure"
        - "traefik.http.routers.keramik-auszeit-de.tls.certresolver=myresolver"
        - "traefik.http.services.keramik-auszeit-de.loadbalancer.server.port=3000"

networks:
  public-ingress:
    external: true
