{
  "name": "auszeit-brennsystem",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'App.tsx' 'index.ts'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' 'App.tsx' 'index.ts' --fix",
    "build:preview": "eas build --profile preview --platform android",
    "build:production": "eas build --profile production --platform android",
    "update:preview": "eas update --branch preview --message",
    "update:production": "eas update --branch production --message"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@expo/vector-icons": "~14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "@shopify/flash-list": "1.7.3",
    "@tanstack/query-async-storage-persister": "^5.99.2",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-query-persist-client": "^5.99.2",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-build-properties": "~0.13.3",
    "expo-camera": "~16.0.18",
    "expo-constants": "~17.0.8",
    "expo-device": "~7.0.3",
    "expo-font": "~13.0.4",
    "expo-image-picker": "~16.0.6",
    "expo-notifications": "~0.29.14",
    "expo-secure-store": "~14.0.1",
    "expo-status-bar": "~2.0.0",
    "expo-updates": "~0.27.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "eslint": "^8.57.1",
    "eslint-config-expo": "~8.0.1",
    "typescript": "^5.3.3"
  }
