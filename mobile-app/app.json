{
  "expo": {
    "name": "Auszeit Brennverwaltung",
    "slug": "auszeit-brennsystem",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c0064f8c-976b-43c4-9fee-69132fda6000",
      "checkAutomatically": "NEVER",
      "fallbackToCacheTimeout": 30000,
      "enabled": true
    },
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#A0522D"
    },
    "platforms": [
      "android",
      "web"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#A0522D"
      },
      "package": "de.keramikauszeit.brennsystem",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "VIBRATE",
        "WAKE_LOCK"
      ],
      "blockedPermissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-image-picker",
      "expo-camera",
      "expo-asset",
      "expo-font",
      "expo-updates",
      "expo-notifications",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": false
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c0064f8c-976b-43c4-9fee-69132fda6000"
      }
    },
    "owner": "danapfeldigital"
  }
}
