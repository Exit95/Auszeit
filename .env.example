# Admin-Passwort für /admin Seite
ADMIN_PASSWORD=ichliebedich0112

# E-Mail Konfiguration (optional - ohne SMTP werden keine E-Mails versendet)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=dein-smtp-benutzer
SMTP_PASS=dein-smtp-passwort

# E-Mail-Adressen
BOOKING_EMAIL=info@keramik-auszeit.de
FROM_EMAIL=info@keramik-auszeit.de

# Hetzner Object Storage (S3-kompatibel)
S3_ENDPOINT=https://nbg1.your-objectstorage.com
S3_BUCKET=danapfel-digital
S3_ACCESS_KEY=dein-access-key
S3_SECRET_KEY=dein-secret-key
S3_REGION=eu-central
S3_PREFIX=Auszeit/

# ─── MariaDB/MySQL Datenbank (optional) ───────────────────────────
# DB_ENABLED=true aktiviert die Datenbankanbindung
# DUAL_WRITE=true schreibt parallel in DB UND JSON/S3
# JSON_FALLBACK=true liest weiterhin aus JSON (Standard)
#
# Empfohlene Reihenfolge:
# 1. Erst Migration laufen lassen (scripts/db/migrate-json-to-db.ts)
# 2. DB_ENABLED=true, DUAL_WRITE=true, JSON_FALLBACK=true  (Parallelbetrieb)
# 3. Nach Verifikation: JSON_FALLBACK=false (DB liest)
# 4. Wenn stabil: DUAL_WRITE=false (nur noch DB)
DB_ENABLED=false
DUAL_WRITE=false
JSON_FALLBACK=true
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=auszeit_prod
DB_USER=auszeit_user
DB_PASSWORD=dein-db-passwort

# ─── Brenn-Verwaltung ───────────────────────────────────────
# Benötigt DB_ENABLED=true!
# Tabellen anlegen: mysql -u auszeit_user -p auszeit_prod < migrations/run-all.sql
# Dann: https://keramik-auszeit.de/admin/brenn/

