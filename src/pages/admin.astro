	    // Formular in Bearbeitungsmodus versetzen
	    function startEditSlot(slot: any) {
	      editingSlotId = slot.id;

	      const dateInput = document.getElementById('slot-date') as HTMLInputElement | null;
	      const startInput = document.getElementById('slot-start-time') as HTMLInputElement | null;
	      const endInput = document.getElementById('slot-end-time') as HTMLInputElement | null;
	      const capacityInput = document.getElementById('slot-capacity') as HTMLInputElement | null;
	      const initialBookedInput = document.getElementById('slot-initial-booked') as HTMLInputElement | null;
	      const eventTypeSelect = document.getElementById('slot-event-type') as HTMLSelectElement | null;
	      const eventTypeHint = document.getElementById('event-type-hint');
	      const initialBookedGroup = document.getElementById('initial-booked-group');
	      const titleEl = document.getElementById('slot-form-title');
	      const submitBtn = document.getElementById('slot-submit-btn') as HTMLButtonElement | null;
	      const cancelBtn = document.getElementById('cancel-edit-btn');

	      if (dateInput) dateInput.value = slot.date;
	      if (startInput) startInput.value = slot.time;
	      if (endInput) endInput.value = slot.endTime || '';
	      if (capacityInput) capacityInput.value = String(slot.maxCapacity);

	      // Event-Typ setzen
	      if (eventTypeSelect) {
	        eventTypeSelect.value = slot.eventType || 'normal';
	      }

	      // Hinweis und Felder entsprechend Event-Typ anzeigen/verstecken
	      const isSpecialEvent = slot.eventType === 'kindergeburtstag' || slot.eventType === 'stammtisch';
	      if (eventTypeHint) eventTypeHint.classList.toggle('hidden', !isSpecialEvent);
	      if (initialBookedGroup) initialBookedGroup.classList.toggle('hidden', isSpecialEvent);

	      // Bereits gebuchte Plätze anzeigen und bearbeitbar lassen
	      const bookedCount = slot.maxCapacity - slot.available;
	      if (initialBookedInput) {
	        initialBookedInput.value = String(bookedCount);
	        initialBookedInput.disabled = false; // Bearbeitbar lassen
	      }

	      if (titleEl) titleEl.textContent = 'Termin bearbeiten';
	      if (submitBtn) submitBtn.textContent = 'Termin aktualisieren';
	      if (cancelBtn) cancelBtn.classList.remove('hidden');

	      const formEl = document.getElementById('add-slot-form') as HTMLElement | null;
	      if (formEl && 'scrollIntoView' in formEl) {
	        formEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
	      }
	    }

	    // Formular-Zustand zurücksetzen (Neuen-Termin-Modus)
	    function resetSlotFormState() {
	      editingSlotId = null;

	      const initialBookedInput = document.getElementById('slot-initial-booked') as HTMLInputElement | null;
	      const titleEl = document.getElementById('slot-form-title');
	      const submitBtn = document.getElementById('slot-submit-btn') as HTMLButtonElement | null;
	      const cancelBtn = document.getElementById('cancel-edit-btn');

	      if (initialBookedInput) {
	        initialBookedInput.disabled = false;
	        if (!initialBookedInput.value) {
	          initialBookedInput.value = '0';
	        }
	      }

	      if (titleEl) titleEl.textContent = 'Neuen Termin hinzufügen';
	      if (submitBtn) submitBtn.textContent = 'Termin hinzufügen';
	      if (cancelBtn && !cancelBtn.classList.contains('hidden')) {
	        cancelBtn.classList.add('hidden');
	      }
	    }

	    // Datum formatieren
	    function formatDate(dateStr: string) {
	      const date = new Date(dateStr + 'T00:00:00');
	      return date.toLocaleDateString('de-DE', {
	        weekday: 'long',
	        year: 'numeric',
	        month: 'long',
	        day: 'numeric'
	      });
	    }

	    // Setze Mindestdatum auf heute
	    const dateInput = document.getElementById('slot-date') as HTMLInputElement;
	    if (dateInput) {
	      const today = new Date().toISOString().split('T')[0];
	      dateInput.min = today;
	    }

    // ========== TAB NAVIGATION ==========
    const tabButtons = document.querySelectorAll('.admin-nav__btn');
    const tabContents = document.querySelectorAll('.admin-tab');

    tabButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const tabName = btn.getAttribute('data-tab');

        // Deaktiviere alle Tabs
        tabButtons.forEach(b => b.classList.remove('active'));
        tabContents.forEach(t => t.classList.add('hidden'));

        // Aktiviere gewählten Tab
        btn.classList.add('active');
        const targetTab = document.getElementById(`tab-${tabName}`);
        if (targetTab) {
          targetTab.classList.remove('hidden');

          // Lade Daten wenn Tab gewechselt wird (parallel für Geschwindigkeit)
          if (tabName === 'uebersicht') {
            Promise.all([loadSlots(), loadBookings()]).then(() => {
              renderOverview();
              renderWeekCalendar();
            });
          } else if (tabName === 'termine') {
            Promise.all([loadSlots(), loadBookings()]);
          } else if (tabName === 'workshops') {
            Promise.all([loadWorkshopImageOptions(), loadWorkshops(), loadWorkshopBookings()]);
          } else if (tabName === 'galerie') {
            loadGalleryData();
          } else if (tabName === 'bewertungen') {
            loadReviews();
          }
        }
      });
    });

    // ========== BUCHUNGSFILTER & SUCHE ==========
    document.querySelectorAll('[data-booking-filter]').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('[data-booking-filter]').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        loadBookings();
      });
    });

    let bookingSearchTimeout: ReturnType<typeof setTimeout>;
    document.getElementById('booking-search')?.addEventListener('input', () => {
      clearTimeout(bookingSearchTimeout);
      bookingSearchTimeout = setTimeout(() => loadBookings(), 300);
    });

    // ========== WORKSHOPS VERWALTUNG ==========
    let editingWorkshopId: string | null = null;
    let workshopImagePreviewInitialized = false;

    // Workshop-Formular absenden
    document.getElementById('add-workshop-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const formData = new FormData(form);

      const imageFilename = formData.get('imageFilename') as string;

      const data = {
        title: formData.get('title'),
        description: formData.get('description'),
        detailedDescription: formData.get('detailedDescription') || undefined,
        date: formData.get('date'),
        time: formData.get('time'),
        price: formData.get('price'),
        maxParticipants: formData.get('maxParticipants'),
        active: (document.getElementById('workshop-active') as HTMLInputElement)?.checked || false,
        imageFilename: imageFilename || undefined
      };

      try {
        const url = editingWorkshopId ? '/api/admin/workshops' : '/api/admin/workshops';
        const method = editingWorkshopId ? 'PUT' : 'POST';
        const body = editingWorkshopId ? { ...data, id: editingWorkshopId } : data;

        const response = await fetch(url, {
          method,
          headers: {
            'Authorization': `Basic ${authCredentials}`,
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(body)
        });

        if (response.ok) {
          form.reset();
          (document.getElementById('workshop-active') as HTMLInputElement).checked = true;
          resetWorkshopFormState();
          await loadWorkshops();
        } else {
          alert('Fehler beim Speichern des Workshops');
        }
      } catch (error) {
        console.error('Error saving workshop:', error);
        alert('Fehler beim Speichern des Workshops');
      }
    });

    // Workshop bearbeiten abbrechen
    document.getElementById('cancel-workshop-edit-btn')?.addEventListener('click', () => {
      (document.getElementById('add-workshop-form') as HTMLFormElement)?.reset();
      resetWorkshopFormState();
    });

    // Bilder-Dropdown für Workshop-Formular laden (aus Galerie - nicht zugeordnete Bilder)
    async function loadWorkshopImageOptions() {
      const selectEl = document.getElementById('workshop-image') as HTMLSelectElement;
      if (!selectEl) return;

      try {
        // Lade Galerie-Bilder und Metadaten
        const [galleryRes, metadataRes] = await Promise.all([
          fetch('/api/gallery'),
          fetch('/api/gallery-metadata')
        ]);

        if (galleryRes.ok && metadataRes.ok) {
          const allImages = await galleryRes.json();
          const { metadata } = await metadataRes.json();
          const currentValue = selectEl.value;

          // Reset URL-Map
          workshopImageUrlMap = {};

          // Filtere nur nicht zugeordnete Bilder (aus gallery/ ohne Kategorie)
          const unassignedImages = allImages.filter((img: any) => {
            // Bilder aus gallery/ die keine Kategorie haben
            if (img.source === 'gallery') {
              const imgMeta = metadata[img.filename];
              return !imgMeta || !imgMeta.category;
            }
            return false;
          });

          selectEl.innerHTML = '<option value="">Kein Bild</option>';

          unassignedImages.forEach((img: any) => {
            const option = document.createElement('option');
            option.value = img.url; // Speichere die volle URL als Wert
            option.textContent = img.filename;
            selectEl.appendChild(option);
            // URL in Map speichern für Vorschau
            workshopImageUrlMap[img.url] = img.url;
          });

          if (currentValue) {
            selectEl.value = currentValue;
          }

          ensureWorkshopImagePreviewListener();
          updateWorkshopImagePreview(selectEl.value || null);
        }
      } catch (error) {
        console.error('Error loading images for workshop:', error);
      }
    }

    function ensureWorkshopImagePreviewListener() {
      if (workshopImagePreviewInitialized) return;
      const selectEl = document.getElementById('workshop-image') as HTMLSelectElement | null;
      if (!selectEl) return;
      workshopImagePreviewInitialized = true;
      selectEl.addEventListener('change', () => {
        updateWorkshopImagePreview(selectEl.value || null);
      });
    }

    // Workshops laden
    async function loadWorkshops() {
      const loadingEl = document.getElementById('workshops-loading');
      const listEl = document.getElementById('workshops-list');
      const noWorkshopsEl = document.getElementById('no-workshops-admin');

      if (loadingEl) loadingEl.classList.remove('hidden');
      if (listEl) listEl.classList.add('hidden');
      if (noWorkshopsEl) noWorkshopsEl.classList.add('hidden');

      try {
        const response = await fetch('/api/admin/workshops', {
          headers: {
            'Authorization': `Basic ${authCredentials}`
          }
        });

        if (!response.ok) throw new Error('Failed to load workshops');

        const workshops = await response.json();

        if (loadingEl) loadingEl.classList.add('hidden');

        if (workshops.length === 0) {
          if (noWorkshopsEl) noWorkshopsEl.classList.remove('hidden');
          return;
        }

        if (listEl) {
          listEl.classList.remove('hidden');
          listEl.innerHTML = '';

          workshops.forEach((workshop: any) => {
            const card = document.createElement('div');
            card.className = 'slot-card';

            const formattedDate = formatDate(workshop.date);
            const statusBadge = workshop.active
              ? '<span class="status-badge status-active">Aktiv</span>'
              : '<span class="status-badge status-inactive">Inaktiv</span>';

            const detailedDesc = workshop.detailedDescription
              ? `<br><small><strong>Ausführlich:</strong> ${workshop.detailedDescription}</small>`
              : '';

            card.innerHTML = `
              <div class="slot-info">
                <div class="slot-date">${formattedDate}</div>
                <div class="slot-time">${workshop.time} Uhr</div>
                <div class="slot-capacity">
                  <strong>${workshop.title}</strong><br>
                  <strong>Kurz:</strong> ${workshop.description}${detailedDesc}<br>
                  Preis: ${workshop.price} | Max. ${workshop.maxParticipants} Teilnehmer
                </div>
                ${statusBadge}
              </div>
              <div class="slot-actions">
                <button class="btn btn-secondary btn-edit-workshop" data-id="${workshop.id}">Bearbeiten</button>
                <button class="btn btn-danger btn-delete-workshop" data-id="${workshop.id}">Löschen</button>
              </div>
            `;

            listEl.appendChild(card);
          });

          // Event Listener für Bearbeiten-Buttons
          document.querySelectorAll('.btn-edit-workshop').forEach(btn => {
            btn.addEventListener('click', () => {
              const id = btn.getAttribute('data-id');
              const workshop = workshops.find((w: any) => w.id === id);
              if (workshop) startEditWorkshop(workshop);
            });
          });

          // Event Listener für Löschen-Buttons
          document.querySelectorAll('.btn-delete-workshop').forEach(btn => {
            btn.addEventListener('click', async () => {
              const id = btn.getAttribute('data-id');
              if (confirm('Workshop wirklich löschen?')) {
                await deleteWorkshop(id!);
              }
            });
          });
        }
      } catch (error) {
        console.error('Error loading workshops:', error);
        if (loadingEl) loadingEl.classList.add('hidden');
      }
    }

    // Workshop löschen
    async function deleteWorkshop(id: string) {
      try {
        console.log('Deleting workshop:', id);
        const response = await fetch(`/api/admin/workshops?id=${encodeURIComponent(id)}`, {
          method: 'DELETE',
          headers: {
            'Authorization': `Basic ${authCredentials}`,
            'X-Requested-With': 'XMLHttpRequest'
          }
        });

        console.log('Delete response status:', response.status);

        if (response.ok) {
          alert('Workshop erfolgreich gelöscht!');
          await loadWorkshops();
        } else {
          const error = await response.json();
          console.error('Delete error:', error);
          alert(`Fehler beim Löschen: ${error.error || 'Unbekannter Fehler'}`);
        }
      } catch (error) {
        console.error('Error deleting workshop:', error);
        alert('Fehler beim Löschen des Workshops: ' + error);
      }
    }

    // Workshop bearbeiten
    function startEditWorkshop(workshop: any) {
      editingWorkshopId = workshop.id;

      (document.getElementById('workshop-title') as HTMLInputElement).value = workshop.title;
      (document.getElementById('workshop-description') as HTMLTextAreaElement).value = workshop.description;
      (document.getElementById('workshop-detailed-description') as HTMLTextAreaElement).value = workshop.detailedDescription || '';
      (document.getElementById('workshop-date') as HTMLInputElement).value = workshop.date;
      (document.getElementById('workshop-time') as HTMLInputElement).value = workshop.time;
      (document.getElementById('workshop-price') as HTMLInputElement).value = workshop.price;
      (document.getElementById('workshop-max-participants') as HTMLInputElement).value = String(workshop.maxParticipants);
      (document.getElementById('workshop-active') as HTMLInputElement).checked = workshop.active;
      (document.getElementById('workshop-image') as HTMLSelectElement).value = workshop.imageFilename || '';
      updateWorkshopImagePreview(workshop.imageFilename || null);

      const titleEl = document.getElementById('workshop-form-title');
      const submitBtn = document.getElementById('workshop-submit-btn');
      const cancelBtn = document.getElementById('cancel-workshop-edit-btn');

      if (titleEl) titleEl.textContent = 'Workshop bearbeiten';
      if (submitBtn) submitBtn.textContent = 'Workshop aktualisieren';
      if (cancelBtn) cancelBtn.classList.remove('hidden');

      document.getElementById('add-workshop-form')?.scrollIntoView({ behavior: 'smooth' });
    }

    // Workshop-Formular zurücksetzen
    function resetWorkshopFormState() {
      editingWorkshopId = null;

      const titleEl = document.getElementById('workshop-form-title');
      const submitBtn = document.getElementById('workshop-submit-btn');
      const cancelBtn = document.getElementById('cancel-workshop-edit-btn');

      if (titleEl) titleEl.textContent = 'Neuen Workshop hinzufügen';
      if (submitBtn) submitBtn.textContent = 'Workshop hinzufügen';
      if (cancelBtn) cancelBtn.classList.add('hidden');
      updateWorkshopImagePreview(null);
    }

    // ========== WORKSHOP-BUCHUNGEN VERWALTUNG ==========
    async function loadWorkshopBookings() {
      const loadingEl = document.getElementById('workshop-bookings-loading');
      const listEl = document.getElementById('workshop-bookings-list');
      const noBookingsEl = document.getElementById('no-workshop-bookings');

      if (loadingEl) loadingEl.classList.remove('hidden');
      if (listEl) listEl.classList.add('hidden');
      if (noBookingsEl) noBookingsEl.classList.add('hidden');

      try {
        const response = await fetch('/api/admin/workshop-bookings', {
          headers: { 'Authorization': `Basic ${authCredentials}` }
        });

        if (!response.ok) throw new Error('Failed to load workshop bookings');

        const bookings = await response.json();

        if (loadingEl) loadingEl.classList.add('hidden');

        // Nur nicht-stornierte Buchungen anzeigen
        const activeBookings = bookings.filter((b: any) => b.status !== 'cancelled');

        if (activeBookings.length === 0) {
          if (noBookingsEl) noBookingsEl.classList.remove('hidden');
          return;
        }

        if (listEl) {
          listEl.innerHTML = activeBookings.map((booking: any) => {
            const status = booking.status || 'pending';
            let statusLabel = 'Bestätigt';
            let statusClass = 'booking-status--confirmed';
            if (status === 'pending') {
              statusLabel = 'Neu / unbestätigt';
              statusClass = 'booking-status--pending';
            }

            const showConfirm = status === 'pending';

            return `
              <div class="slot-card booking-card" data-id="${booking.id}">
                <div class="slot-info booking-info">
                  <div class="booking-main">
                    <div>
                      <div class="slot-date">${booking.workshopTitle || 'Workshop'}</div>
                      <div class="slot-time">${booking.workshopDate || ''} um ${booking.workshopTime || ''} Uhr</div>
                    </div>
                    <div class="booking-status ${statusClass}">${statusLabel}</div>
                  </div>
                  <div class="booking-customer">
                    <div><strong>${booking.name}</strong> (${booking.email})</div>
                    <div>${booking.participants} Person(en)${booking.phone ? ' | Tel: ' + booking.phone : ''}</div>
                    ${booking.notes ? `<div style="font-size: 0.85em; color: #666;">Notiz: ${booking.notes}</div>` : ''}
                  </div>
                </div>
                <div class="slot-actions booking-actions">
                  ${showConfirm ? `<button class="btn btn-success btn-confirm-wb" data-id="${booking.id}">✓ Bestätigen</button>` : ''}
                  <button class="btn btn-danger btn-cancel-wb" data-id="${booking.id}">✕ Stornieren</button>
                </div>
              </div>
            `;
          }).join('');

          listEl.classList.remove('hidden');

          // Confirm-Handler
          listEl.querySelectorAll('.btn-confirm-wb').forEach((btn) => {
            btn.addEventListener('click', async (e) => {
              const id = (e.target as HTMLElement).dataset.id;
              if (id && confirm('Workshop-Buchung bestätigen und Bestätigungs-E-Mail an Kunden senden?')) {
                await confirmWorkshopBooking(id);
              }
            });
          });

          // Cancel-Handler
          listEl.querySelectorAll('.btn-cancel-wb').forEach((btn) => {
            btn.addEventListener('click', async (e) => {
              const id = (e.target as HTMLElement).dataset.id;
              if (id && confirm('Workshop-Buchung wirklich stornieren?')) {
                await cancelWorkshopBooking(id);
              }
            });
          });
        }
      } catch (error) {
        console.error('Error loading workshop bookings:', error);
        if (loadingEl) loadingEl.classList.add('hidden');
      }
    }

    async function confirmWorkshopBooking(id: string) {
      try {
        const response = await fetch('/api/admin/workshop-bookings', {
          method: 'POST',
          headers: {
            'Authorization': `Basic ${authCredentials}`,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ id, action: 'confirm' }),
        });

        const result = await response.json();

        if (response.ok) {
          if (result.customerEmailSent) {
            alert('Buchung bestätigt und Bestätigungs-E-Mail an Kunden gesendet!');
          } else {
            alert('Buchung bestätigt. E-Mail konnte nicht gesendet werden: ' + (result.emailError || 'Unbekannter Fehler'));
          }
          await loadWorkshopBookings();
        } else {
          alert('Fehler beim Bestätigen: ' + (result.error || 'Unbekannter Fehler'));
        }
      } catch (error) {
        console.error('Error confirming workshop booking:', error);
        alert('Fehler beim Bestätigen der Buchung');
      }
    }

    async function cancelWorkshopBooking(id: string) {
      try {
        const response = await fetch('/api/admin/workshop-bookings', {
          method: 'POST',
          headers: {
            'Authorization': `Basic ${authCredentials}`,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ id, action: 'cancel' }),
        });

        if (response.ok) {
          await loadWorkshopBookings();
        } else {
          alert('Fehler beim Stornieren der Buchung');
        }
      } catch (error) {
        console.error('Error cancelling workshop booking:', error);
        alert('Fehler beim Stornieren der Buchung');
      }
    }

    // ========== GALERIE VERWALTUNG (S3) ==========
    const GALLERY_CATEGORIES = [
      { id: 'tassen', name: 'Tassen' },
      { id: 'teller', name: 'Teller' },
      { id: 'spardosen', name: 'Spardosen & Krüge & Boxen' },
      { id: 'anhaenger', name: 'Weihnachtsanhänger' },
    ];

    let galleryImages: any[] = [];
    let galleryMetadata: Record<string, { category: string | null }> = {};

    // Upload-Bereich initialisieren
    const uploadArea = document.getElementById('upload-drop-area');
    const fileInput = document.getElementById('gallery-file-input') as HTMLInputElement;
    const uploadStatus = document.getElementById('upload-status');

    uploadArea?.addEventListener('click', () => fileInput?.click());

    uploadArea?.addEventListener('dragover', (e) => {
      e.preventDefault();
      uploadArea.classList.add('drag-over');
    });

    uploadArea?.addEventListener('dragleave', () => {
      uploadArea?.classList.remove('drag-over');
    });

    uploadArea?.addEventListener('drop', (e) => {
      e.preventDefault();
      uploadArea?.classList.remove('drag-over');
      const files = (e as DragEvent).dataTransfer?.files;
      if (files?.[0]) uploadGalleryFile(files[0]);
    });

    fileInput?.addEventListener('change', () => {
      if (fileInput.files?.[0]) uploadGalleryFile(fileInput.files[0]);
    });

    async function uploadGalleryFile(file: File) {
      if (!uploadStatus) return;
      uploadStatus.className = 'upload-status uploading';
      uploadStatus.textContent = `Uploading ${file.name}...`;

      try {
        const formData = new FormData();
        formData.append('filename', file.name);
        formData.append('file', file);

        const response = await fetch('/api/gallery', {
          method: 'POST',
          headers: { 'Authorization': `Basic ${authCredentials}` },
          body: formData,
        });

        if (!response.ok) {
          const error = await response.json();
          throw new Error(error.error || 'Upload failed');
        }

        const result = await response.json();
        uploadStatus.className = 'upload-status success';
        uploadStatus.textContent = `✓ Hochgeladen: ${result.filename}`;
        fileInput.value = '';
        await loadGalleryData();
      } catch (error) {
        uploadStatus.className = 'upload-status error';
        uploadStatus.textContent = `✗ Fehler: ${error instanceof Error ? error.message : 'Unbekannt'}`;
      }
    }

    // Galerie-Daten laden (Bilder + Metadaten)
    async function loadGalleryData() {
      try {
        const [imagesRes, metaRes] = await Promise.all([
          fetch('/api/gallery'),
          fetch('/api/gallery-metadata'),
        ]);

        galleryImages = await imagesRes.json();
        const metaData = await metaRes.json();
        galleryMetadata = metaData.metadata || {};

        renderGallery();
      } catch (error) {
        console.error('Error loading gallery:', error);
      }
    }

    // Galerie rendern
    function renderGallery() {
      const categorizedEl = document.getElementById('gallery-categorized');
      const uncategorizedEl = document.getElementById('gallery-uncategorized');

      if (!categorizedEl || !uncategorizedEl) return;

      // Bilder nach Kategorie gruppieren
      const categorized: Record<string, any[]> = {};
      const uncategorized: any[] = [];

      galleryImages.forEach((img: any) => {
        const meta = galleryMetadata[img.filename];
        if (meta?.category) {
          if (!categorized[meta.category]) categorized[meta.category] = [];
          categorized[meta.category].push(img);
        } else {
          uncategorized.push(img);
        }
      });

      // Kategorisierte Bilder rendern
      categorizedEl.innerHTML = '';
      GALLERY_CATEGORIES.forEach(cat => {
        const images = categorized[cat.id] || [];
        if (images.length === 0) return;

        const section = document.createElement('div');
        section.className = 'category-section';
        section.innerHTML = `
          <h3>${escapeHtml(cat.name)} (${images.length})</h3>
          <div class="gallery-grid">
            ${images.map((img: any) => renderImageCard(img, cat.id)).join('')}
          </div>
        `;
        categorizedEl.appendChild(section);
      });

      if (categorizedEl.innerHTML === '') {
        categorizedEl.innerHTML = '<p class="hint">Noch keine Bilder mit Kategorien.</p>';
      }

      // Nicht kategorisierte Bilder rendern
      uncategorizedEl.innerHTML = uncategorized.length > 0
        ? uncategorized.map((img: any) => renderImageCard(img, null)).join('')
        : '<p class="hint">Alle Bilder sind kategorisiert.</p>';

      // Event Listener hinzufügen
      attachGalleryEventListeners();
    }

    function renderImageCard(img: any, category: string | null): string {
      return `
        <div class="gallery-item">
          <img src="${escapeHtml(img.url)}" alt="${escapeHtml(img.filename)}" loading="lazy">
          <div class="gallery-item__info">
            <div class="gallery-item__name">${escapeHtml(img.filename)}</div>
            <div class="gallery-item__size">${formatFileSize(img.size)}</div>
          </div>
          <div class="gallery-item__actions">
            <select class="category-select" data-filename="${escapeHtml(img.filename)}">
              <option value="">-- Keine Kategorie --</option>
              ${GALLERY_CATEGORIES.map(c =>
                `<option value="${c.id}" ${category === c.id ? 'selected' : ''}>${escapeHtml(c.name)}</option>`
              ).join('')}
            </select>
            <button class="btn btn-sm btn-danger btn-delete-image" data-filename="${escapeHtml(img.filename)}">🗑️</button>
          </div>
        </div>
      `;
    }

    function attachGalleryEventListeners() {
      // Kategorie-Änderung
      document.querySelectorAll('.category-select').forEach(select => {
        select.addEventListener('change', async (e) => {
          const el = e.target as HTMLSelectElement;
          const filename = el.dataset.filename;
          const category = el.value || null;

          try {
            const response = await fetch('/api/gallery-metadata', {
              method: 'POST',
              headers: {
                'Authorization': `Basic ${authCredentials}`,
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({ filename, category }),
            });

            if (response.ok) {
              await loadGalleryData();
            } else {
              alert('Fehler beim Speichern der Kategorie');
            }
          } catch (error) {
            console.error('Error updating category:', error);
          }
        });
      });

      // Löschen
      document.querySelectorAll('.btn-delete-image').forEach(btn => {
        btn.addEventListener('click', async () => {
          const filename = (btn as HTMLElement).dataset.filename;
          if (!filename || !confirm(`Bild "${filename}" wirklich löschen?`)) return;

          try {
            const response = await fetch(`/api/gallery?filename=${encodeURIComponent(filename)}`, {
              method: 'DELETE',
              headers: { 'Authorization': `Basic ${authCredentials}` },
            });

            if (response.ok) {
              await loadGalleryData();
            } else {
              alert('Fehler beim Löschen');
            }
          } catch (error) {
            console.error('Error deleting image:', error);
          }
        });
      });
    }

    // Galerie neu laden Button
    document.getElementById('reload-gallery-btn')?.addEventListener('click', () => {
      loadGalleryData();
    });

    // Hilfsfunktion: Dateigröße formatieren
    function formatFileSize(bytes: number): string {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(2) + ' KB';
      return (bytes / (1024 * 1024)).toFixed(2) + ' MB';
    }

    // ========================================
    // BEWERTUNGEN TAB
    // ========================================

    let currentReviewFilter = 'all';
    let allReviews: any[] = [];

    async function loadReviews() {
      const loadingEl = document.getElementById('reviews-loading');
      const listEl = document.getElementById('reviews-list');
      const noDataEl = document.getElementById('no-reviews');

      if (loadingEl) loadingEl.style.display = 'block';
      if (listEl) listEl.classList.add('hidden');
      if (noDataEl) noDataEl.classList.add('hidden');

      try {
        const response = await fetch('/api/reviews?all=true', {
          headers: {
            'Authorization': `Basic ${authCredentials}`
          }
        });

        if (!response.ok) throw new Error('Fehler beim Laden');

        allReviews = await response.json();
        updateReviewStats();
        displayReviews();
      } catch (error) {
        console.error('Fehler beim Laden der Bewertungen:', error);
        if (noDataEl) {
          noDataEl.textContent = 'Fehler beim Laden der Bewertungen';
          noDataEl.classList.remove('hidden');
        }
      } finally {
        if (loadingEl) loadingEl.style.display = 'none';
      }
    }

    function updateReviewStats() {
      const pending = allReviews.filter(r => !r.approved).length;
      const approved = allReviews.filter(r => r.approved).length;
      const total = allReviews.length;

      const pendingEl = document.getElementById('reviews-pending-count');
      const approvedEl = document.getElementById('reviews-approved-count');
      const totalEl = document.getElementById('reviews-total-count');

      if (pendingEl) pendingEl.textContent = pending.toString();
      if (approvedEl) approvedEl.textContent = approved.toString();
      if (totalEl) totalEl.textContent = total.toString();
    }

    function displayReviews() {
      const listEl = document.getElementById('reviews-list');
      const noDataEl = document.getElementById('no-reviews');

      if (!listEl || !noDataEl) return;

      let filteredReviews = allReviews;
      if (currentReviewFilter === 'pending') {
        filteredReviews = allReviews.filter(r => !r.approved);
      } else if (currentReviewFilter === 'approved') {
        filteredReviews = allReviews.filter(r => r.approved);
      }

      if (filteredReviews.length === 0) {
        listEl.classList.add('hidden');
        noDataEl.classList.remove('hidden');
        noDataEl.textContent = 'Keine Bewertungen in dieser Kategorie';
        return;
      }

      listEl.innerHTML = filteredReviews.map(review => `
        <div class="review-admin-card ${review.approved ? 'approved' : 'pending'}">
          <div class="review-admin-header">
            <div>
              <strong>${escapeHtml(review.name)}</strong>
              <span class="review-stars">${'★'.repeat(review.rating)}${'☆'.repeat(5 - review.rating)}</span>
            </div>
            <div class="review-date">${new Date(review.date).toLocaleDateString('de-DE')}</div>
          </div>
          <div class="review-admin-comment">${escapeHtml(review.comment)}</div>
          <div class="review-admin-actions">
            <span class="review-status ${review.approved ? 'status-approved' : 'status-pending'}">
              ${review.approved ? '✓ Freigegeben' : '⏳ Wartend'}
            </span>
            ${!review.approved ? `
              <button class="btn btn-success btn-sm" onclick="approveReview('${review.id}')">Freigeben</button>
            ` : `
              <button class="btn btn-warning btn-sm" onclick="unapproveReview('${review.id}')">Zurückziehen</button>
            `}
            <button class="btn btn-danger btn-sm" onclick="deleteReview('${review.id}')">Löschen</button>
          </div>
        </div>
      `).join('');

      listEl.classList.remove('hidden');
      noDataEl.classList.add('hidden');
    }

    async function approveReview(id: string) {
      try {
        const response = await fetch('/api/reviews', {
          method: 'PATCH',
          headers: {
            'Authorization': `Basic ${authCredentials}`,
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ id, approved: true })
        });

        if (response.ok) {
          await loadReviews();
        } else {
          alert('Fehler beim Freigeben der Bewertung');
        }
      } catch (error) {
        console.error('Fehler:', error);
        alert('Fehler beim Freigeben der Bewertung');
      }
    }

    async function unapproveReview(id: string) {
      try {
        const response = await fetch('/api/reviews', {
          method: 'PATCH',
          headers: {
            'Authorization': `Basic ${authCredentials}`,
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ id, approved: false })
        });

        if (response.ok) {
          await loadReviews();
        } else {
          alert('Fehler beim Zurückziehen der Bewertung');
        }
      } catch (error) {
        console.error('Fehler:', error);
        alert('Fehler beim Zurückziehen der Bewertung');
      }
    }

    async function deleteReview(id: string) {
      if (!confirm('Bewertung wirklich löschen?')) return;

      try {
        const response = await fetch(`/api/reviews?id=${id}`, {
          method: 'DELETE',
          headers: {
            'Authorization': `Basic ${authCredentials}`
          }
        });

        if (response.ok) {
          await loadReviews();
        } else {
          alert('Fehler beim Löschen der Bewertung');
        }
      } catch (error) {
        console.error('Fehler:', error);
        alert('Fehler beim Löschen der Bewertung');
      }
    }

    // Filter-Buttons
    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const filter = target.dataset.filter || 'all';

        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        target.classList.add('active');

        currentReviewFilter = filter;
        displayReviews();
      });
    });

    // Globale Funktionen für onclick-Handler
    (window as any).approveReview = approveReview;
    (window as any).unapproveReview = unapproveReview;
    (window as any).deleteReview = deleteReview;

    // ========== ÜBERSICHT & WOCHENKALENDER ==========

    function renderOverview() {
      const today = new Date();
      today.setHours(0, 0, 0, 0);
      const todayStr = today.toISOString().split('T')[0];

      // Heutige Termine rendern
      const todayBookings = cachedBookings.filter(b =>
        b.slotDate === todayStr && b.status !== 'cancelled'
      ).sort((a, b) => (a.slotTime || '').localeCompare(b.slotTime || ''));

      const todayListEl = document.getElementById('today-bookings-list');
      const todayLoadingEl = document.getElementById('today-bookings-loading');
      const noTodayEl = document.getElementById('no-today-bookings');

      if (todayLoadingEl) todayLoadingEl.classList.add('hidden');

      if (todayBookings.length === 0) {
        if (todayListEl) todayListEl.classList.add('hidden');
        if (noTodayEl) noTodayEl.classList.remove('hidden');
      } else {
        if (noTodayEl) noTodayEl.classList.add('hidden');
        if (todayListEl) {
          todayListEl.innerHTML = todayBookings.map(b => {
            const statusClass = b.status === 'pending' ? 'status-pending' : 'status-confirmed';
            const statusLabel = b.status === 'pending' ? '⏳ Offen' : '✅ Bestätigt';
            return `
              <div class="today-booking-card ${statusClass}">
                <div class="today-booking-time">${b.slotTime || '?'}${b.slotEndTime ? ' - ' + b.slotEndTime : ''} Uhr</div>
                <div class="today-booking-info">
                  <strong>${escapeHtml(b.name || '')}</strong>
                  <span>${b.participants || 1} Person(en)</span>
                  ${b.notes ? `<span class="today-booking-note">📝 ${escapeHtml(b.notes)}</span>` : ''}
                </div>
                <div class="today-booking-status ${statusClass}">${statusLabel}</div>
                <div class="today-booking-actions">
                  ${b.status === 'pending' ? `<button class="btn btn-success btn-sm btn-today-confirm" data-id="${b.id}">✓ Bestätigen</button>` : ''}
                  <button class="btn btn-danger btn-sm btn-today-cancel" data-id="${b.id}">✕ Absagen</button>
                </div>
              </div>
            `;
          }).join('');
          todayListEl.classList.remove('hidden');

          // Schnellaktionen für heutige Termine
          todayListEl.querySelectorAll('.btn-today-confirm').forEach(btn => {
            btn.addEventListener('click', async () => {
              const id = (btn as HTMLElement).dataset.id;
              if (id) { await confirmBookingAdmin(id); renderOverview(); }
            });
          });
          todayListEl.querySelectorAll('.btn-today-cancel').forEach(btn => {
            btn.addEventListener('click', async () => {
              const id = (btn as HTMLElement).dataset.id;
              if (id && confirm('Termin absagen?')) { await cancelBookingAdmin(id); renderOverview(); }
            });
          });
        }
      }

      // Warnhinweise
      const warningsEl = document.getElementById('overview-warnings');
      const warningsListEl = document.getElementById('warnings-list');
      const warnings: string[] = [];

      // Offene Anfragen
      const pendingCount = cachedBookings.filter(b => b.status === 'pending').length;
      if (pendingCount > 0) {
        warnings.push(`🔔 <strong>${pendingCount} offene Anfrage${pendingCount > 1 ? 'n' : ''}</strong> warten auf Bestätigung`);
      }

      // Doppelbelegungen prüfen
      const slotsByDate: Record<string, any[]> = {};
      cachedSlots.forEach(s => {
        if (!slotsByDate[s.date]) slotsByDate[s.date] = [];
        slotsByDate[s.date].push(s);
      });
      Object.entries(slotsByDate).forEach(([date, slots]) => {
        if (slots.length > 1) {
          // Zeitüberlappungen prüfen
          for (let i = 0; i < slots.length; i++) {
            for (let j = i + 1; j < slots.length; j++) {
              const a = slots[i], b = slots[j];
              if (a.time && b.time && a.endTime && b.endTime) {
                if (a.time < b.endTime && b.time < a.endTime) {
                  warnings.push(`⚠️ <strong>Zeitüberlappung</strong> am ${formatDate(date)}: ${a.time}-${a.endTime} und ${b.time}-${b.endTime}`);
                }
              }
            }
          }
        }
      });

      // Ausgebuchte Slots
      const fullSlots = cachedSlots.filter(s => {
        const slotDate = new Date(s.date + 'T00:00:00');
        return slotDate >= today && s.available === 0 && s.eventType === 'normal';
      });
      if (fullSlots.length > 0) {
        warnings.push(`📌 <strong>${fullSlots.length} Termin${fullSlots.length > 1 ? 'e' : ''}</strong> ausgebucht`);
      }

      if (warningsEl && warningsListEl) {
        if (warnings.length > 0) {
          warningsEl.classList.remove('hidden');
          warningsListEl.innerHTML = warnings.map(w => `<div class="warning-item">${w}</div>`).join('');
        } else {
          warningsEl.classList.add('hidden');
        }
      }

      // Gutschein-KPI laden
      loadVoucherCount();
    }

    async function loadVoucherCount() {
      try {
        const res = await fetch('/api/admin/vouchers', {
          headers: { Authorization: `Basic ${authCredentials}` },
        });
        const vouchers = await res.json();
        if (Array.isArray(vouchers)) {
          const active = vouchers.filter((v: any) => v.status === 'active').length;
          const el = document.getElementById('dashboard-voucher-count');
          if (el) el.textContent = String(active);
        }
      } catch {}
    }

    // ========== WOCHENKALENDER ==========
    function getWeekDates(offset: number): Date[] {
      const today = new Date();
      const dayOfWeek = today.getDay() || 7; // Montag = 1
      const monday = new Date(today);
      monday.setDate(today.getDate() - dayOfWeek + 1 + (offset * 7));
      monday.setHours(0, 0, 0, 0);

      const days: Date[] = [];
      for (let i = 0; i < 7; i++) {
        const d = new Date(monday);
        d.setDate(monday.getDate() + i);
        days.push(d);
      }
      return days;
    }

    function renderWeekCalendar() {
      const calEl = document.getElementById('week-calendar');
      const labelEl = document.getElementById('cal-week-label');
      if (!calEl) return;

      const days = getWeekDates(calendarWeekOffset);
      const todayStr = new Date().toISOString().split('T')[0];

      // Wochenlabel
      const startStr = days[0].toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit' });
      const endStr = days[6].toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' });
      if (labelEl) labelEl.textContent = `${startStr} – ${endStr}`;

      // Slots und Buchungen pro Tag gruppieren
      let html = '<div class="cal-grid">';

      const dayNames = ['Mo', 'Di', 'Mi', 'Do', 'Fr', 'Sa', 'So'];

      days.forEach((day, idx) => {
        const dateStr = day.toISOString().split('T')[0];
        const isToday = dateStr === todayStr;
        const isPast = day < new Date(todayStr + 'T00:00:00');

        const daySlots = cachedSlots.filter(s => s.date === dateStr);
        const dayBookings = cachedBookings.filter(b => b.slotDate === dateStr && b.status !== 'cancelled');

        const totalCapacity = daySlots.reduce((sum: number, s: any) => sum + (s.maxCapacity || 0), 0);
        const totalBooked = dayBookings.reduce((sum: number, b: any) => sum + (b.participants || 1), 0);
        const utilization = totalCapacity > 0 ? Math.round((totalBooked / totalCapacity) * 100) : 0;

        let utilizationClass = 'cal-free';
        if (utilization >= 80) utilizationClass = 'cal-full';
        else if (utilization >= 40) utilizationClass = 'cal-medium';

        html += `
          <div class="cal-day ${isToday ? 'cal-today' : ''} ${isPast ? 'cal-past' : ''}" data-cal-date="${dateStr}" style="cursor:pointer;" title="Klicken für Details">
            <div class="cal-day-header">
              <span class="cal-day-name">${dayNames[idx]}</span>
              <span class="cal-day-date">${day.getDate()}.${day.getMonth() + 1}</span>
            </div>
            <div class="cal-day-body">
        `;

        if (daySlots.length === 0) {
          html += `<div class="cal-empty">Keine Termine</div>`;
        } else {
          daySlots.forEach((slot: any) => {
            const slotBookings = dayBookings.filter(b => b.slotId === slot.id);
            const booked = slot.maxCapacity - slot.available;

            let badge = '';
            if (slot.eventType === 'kindergeburtstag') badge = '🎂';
            else if (slot.eventType === 'stammtisch') badge = '🍷';

            html += `
              <div class="cal-slot ${utilizationClass}">
                <div class="cal-slot-time">${badge} ${slot.time}${slot.endTime ? '-' + slot.endTime : ''}</div>
                <div class="cal-slot-capacity">${booked}/${slot.maxCapacity}</div>
                ${slotBookings.length > 0 ? `
                  <div class="cal-slot-names">
                    ${slotBookings.slice(0, 3).map((b: any) => `<span class="cal-name ${b.status === 'pending' ? 'cal-pending' : ''}">${escapeHtml(b.name || '?')}</span>`).join('')}
                    ${slotBookings.length > 3 ? `<span class="cal-more">+${slotBookings.length - 3} weitere</span>` : ''}
                  </div>
                ` : ''}
              </div>
            `;
          });
        }

        html += `</div></div>`;
      });

      html += '</div>';
      calEl.innerHTML = html;

      // Click-Handler auf Kalendertage
      calEl.querySelectorAll('.cal-day[data-cal-date]').forEach(dayEl => {
        dayEl.addEventListener('click', () => {
          const dateStr = (dayEl as HTMLElement).dataset.calDate;
          if (dateStr) showDayDetail(dateStr);
        });
      });
    }

    function showDayDetail(dateStr: string) {
      const panel = document.getElementById('day-detail-panel');
      const titleEl = document.getElementById('day-detail-title');
      const contentEl = document.getElementById('day-detail-content');
      if (!panel || !titleEl || !contentEl) return;

      const dateObj = new Date(dateStr + 'T00:00:00');
      const formatted = dateObj.toLocaleDateString('de-DE', { weekday: 'long', day: '2-digit', month: 'long', year: 'numeric' });
      titleEl.textContent = `📅 ${formatted}`;

      const daySlots = cachedSlots.filter((s: any) => s.date === dateStr);
      const dayBookings = cachedBookings.filter((b: any) => b.slotDate === dateStr && b.status !== 'cancelled');

      if (daySlots.length === 0 && dayBookings.length === 0) {
        contentEl.innerHTML = '<p class="no-data" style="padding:1rem">Keine Termine an diesem Tag.</p>';
      } else {
        let html = '';

        daySlots.forEach((slot: any) => {
          const slotBookings = dayBookings.filter((b: any) => b.slotId === slot.id);
          const booked = slot.maxCapacity - slot.available;

          let badge = '';
          if (slot.eventType === 'kindergeburtstag') badge = '🎂 Kindergeburtstag';
          else if (slot.eventType === 'stammtisch') badge = '🍷 Stammtisch';

          html += `<div class="day-detail-slot">`;
          html += `<div class="day-detail-slot-header">`;
          html += `<strong>${slot.time}${slot.endTime ? ' – ' + slot.endTime : ''} Uhr</strong>`;
          html += `<span class="day-detail-capacity">${booked}/${slot.maxCapacity} Plätze</span>`;
          if (badge) html += `<span class="day-detail-badge">${badge}</span>`;
          html += `</div>`;

          if (slotBookings.length === 0) {
            html += `<p class="day-detail-empty">Noch keine Buchungen</p>`;
          } else {
            html += `<div class="day-detail-bookings">`;
            slotBookings.forEach((b: any) => {
              const statusClass = b.status === 'pending' ? 'status-pending' : 'status-confirmed';
              const statusLabel = b.status === 'pending' ? '⏳ Offen' : '✓ Bestätigt';
              html += `
                <div class="day-detail-booking ${statusClass}">
                  <div class="day-detail-booking-name"><strong>${escapeHtml(b.name || '?')}</strong></div>
                  <div class="day-detail-booking-info">
                    ${b.participants ? b.participants + ' Person(en)' : ''}
                    ${b.email ? ' · ' + escapeHtml(b.email) : ''}
                    ${b.phone ? ' · ' + escapeHtml(b.phone) : ''}
                  </div>
                  <span class="day-detail-booking-status ${statusClass}">${statusLabel}</span>
                </div>
              `;
            });
            html += `</div>`;
          }

          html += `</div>`;
        });

        // Buchungen ohne Slot-Zuordnung
        const orphanBookings = dayBookings.filter((b: any) => !daySlots.some((s: any) => s.id === b.slotId));
        if (orphanBookings.length > 0) {
          html += `<div class="day-detail-slot"><div class="day-detail-slot-header"><strong>Weitere Buchungen</strong></div><div class="day-detail-bookings">`;
          orphanBookings.forEach((b: any) => {
            html += `<div class="day-detail-booking"><div class="day-detail-booking-name"><strong>${escapeHtml(b.name || '?')}</strong></div><div class="day-detail-booking-info">${b.participants ? b.participants + ' Person(en)' : ''} ${b.email ? ' · ' + escapeHtml(b.email) : ''}</div></div>`;
          });
          html += `</div></div>`;
        }

        contentEl.innerHTML = html;
      }

      panel.classList.remove('hidden');
      panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    // Detail-Panel schließen
    document.getElementById('day-detail-close')?.addEventListener('click', () => {
      document.getElementById('day-detail-panel')?.classList.add('hidden');
    });

    // Kalender-Navigation
    document.getElementById('cal-prev-week')?.addEventListener('click', () => {
      calendarWeekOffset--;
      renderWeekCalendar();
    });
    document.getElementById('cal-next-week')?.addEventListener('click', () => {
      calendarWeekOffset++;
      renderWeekCalendar();
    });

    function updateOverviewIfVisible() {
      const overviewTab = document.getElementById('tab-uebersicht');
      if (overviewTab && !overviewTab.classList.contains('hidden')) {
        renderOverview();
        renderWeekCalendar();
      }
    }

    // ========== GUTSCHEINE ==========
    let html5QrCode: any = null;
    let scannerRunning = false;

    function formatCents(cents: number): string {
      return (cents / 100).toFixed(2).replace('.', ',') + ' €';
    }

    function formatVoucherDate(iso: string): string {
      return new Date(iso).toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });
    }

    function statusBadge(status: string): string {
      const map: Record<string, { label: string; color: string }> = {
        active: { label: 'Aktiv', color: '#16a34a' },
        redeemed: { label: 'Eingelöst', color: '#dc2626' },
        expired: { label: 'Abgelaufen', color: '#9ca3af' },
      };
      const s = map[status] || { label: status, color: '#666' };
      return `<span style="background: ${s.color}; color: white; padding: 2px 10px; border-radius: 999px; font-size: 0.75rem; font-weight: 600;">${s.label}</span>`;
    }

    async function loadVouchers() {
      const loading = document.getElementById('voucher-loading');
      const list = document.getElementById('voucher-list');
      const noData = document.getElementById('no-vouchers');
      if (loading) loading.classList.remove('hidden');
      if (list) list.classList.add('hidden');
      if (noData) noData.classList.add('hidden');

      try {
        const res = await fetch('/api/admin/vouchers', {
          headers: { Authorization: `Basic ${authCredentials}` },
        });
        const vouchers = await res.json();

        if (loading) loading.classList.add('hidden');

        if (!Array.isArray(vouchers) || vouchers.length === 0) {
          if (noData) noData.classList.remove('hidden');
          return;
        }

        // Stats
        const active = vouchers.filter((v: any) => v.status === 'active').length;
        const redeemed = vouchers.filter((v: any) => v.status === 'redeemed').length;
        const el = (id: string) => document.getElementById(id);
        if (el('voucher-active-count')) el('voucher-active-count')!.textContent = String(active);
        if (el('voucher-redeemed-count')) el('voucher-redeemed-count')!.textContent = String(redeemed);
        if (el('voucher-total-count')) el('voucher-total-count')!.textContent = String(vouchers.length);

        if (list) {
          list.innerHTML = vouchers.map((v: any) => `
            <div class="voucher-card" style="background: white; border: 1px solid #e8e0d8; border-radius: 12px; padding: 1rem; margin-bottom: 0.75rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
              <div>
                <span style="font-family: monospace; font-size: 1.1rem; font-weight: 700; letter-spacing: 1px;">${escapeHtml(v.code)}</span>
                <span style="margin-left: 0.75rem; font-size: 1.1rem; font-weight: 600;">${formatCents(v.amount)}</span>
                ${statusBadge(v.status)}
              </div>
              <div style="font-size: 0.8rem; color: #888;">
                ${escapeHtml(v.customerEmail || '')} · ${formatVoucherDate(v.createdAt)}
                ${v.redeemedAt ? ' · Eingelöst: ' + formatVoucherDate(v.redeemedAt) : ''}
              </div>
              <div>
                ${v.status === 'active' ? `<button class="btn btn-sm" onclick="adminRedeemVoucher('${escapeHtml(v.code)}')" style="background: #dc2626; color: white; border: none; padding: 4px 12px; border-radius: 6px; cursor: pointer; font-size: 0.8rem;">Einlösen</button>` : ''}
                ${v.status === 'redeemed' ? `<button class="btn btn-sm" onclick="adminReactivateVoucher('${escapeHtml(v.code)}')" style="background: #8B6F47; color: white; border: none; padding: 4px 12px; border-radius: 6px; cursor: pointer; font-size: 0.8rem;">Reaktivieren</button>` : ''}
              </div>
            </div>
          `).join('');
          list.classList.remove('hidden');
        }
      } catch (err) {
        console.error('Fehler beim Laden der Gutscheine:', err);
        if (loading) loading.textContent = 'Fehler beim Laden';
      }
    }

    function showVoucherScanResult(voucher: any) {
      const el = document.getElementById('voucher-scan-result');
      if (!el) return;
      const isActive = voucher.status === 'active';
      el.style.display = 'block';
      el.innerHTML = `
        <div style="background: ${isActive ? '#f0fdf4' : '#fef2f2'}; border: 2px solid ${isActive ? '#16a34a' : '#dc2626'}; border-radius: 16px; padding: 1.5rem; text-align: center; max-width: 400px; margin: 0 auto;">
          <div style="font-size: 3rem;">${isActive ? '✅' : '⚠️'}</div>
          <h3 style="color: ${isActive ? '#16a34a' : '#dc2626'}; margin: 0.5rem 0;">${isActive ? 'Gutschein gültig' : (voucher.status === 'redeemed' ? 'Bereits eingelöst' : 'Abgelaufen')}</h3>
          <p style="font-family: monospace; font-size: 1.25rem; letter-spacing: 2px; margin: 0.5rem 0;">${escapeHtml(voucher.code)}</p>
          <p style="font-size: 2rem; font-weight: bold; margin: 0.5rem 0;">${formatCents(voucher.amount)}</p>
          <p style="font-size: 0.85rem; color: #666;">${escapeHtml(voucher.customerEmail || '')}${voucher.customerName ? ' (' + escapeHtml(voucher.customerName) + ')' : ''}</p>
          ${voucher.redeemedAt ? `<p style="font-size: 0.8rem; color: #999;">Eingelöst: ${formatVoucherDate(voucher.redeemedAt)}</p>` : ''}
          ${isActive ? `<button onclick="adminRedeemVoucher('${escapeHtml(voucher.code)}')" style="margin-top: 1rem; background: #dc2626; color: white; border: none; padding: 0.75rem 2rem; border-radius: 8px; font-size: 1rem; font-weight: 600; cursor: pointer;">🎟️ Jetzt einlösen</button>` : ''}
        </div>`;
    }

    async function adminRedeemVoucher(code: string) {
      if (!confirm(`Gutschein ${code} wirklich einlösen?`)) return;
      try {
        const res = await fetch('/api/admin/vouchers', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Authorization: `Basic ${authCredentials}` },
          body: JSON.stringify({ action: 'redeem', code }),
        });
        const data = await res.json();
        if (data.success) {
          alert('✅ Gutschein erfolgreich eingelöst!');
          showVoucherScanResult(data.voucher);
          loadVouchers();
        } else {
          alert('❌ ' + (data.error || 'Fehler'));
          if (data.voucher) showVoucherScanResult(data.voucher);
        }
      } catch (err) { alert('Fehler bei der Verbindung'); }
    }

    async function adminReactivateVoucher(code: string) {
      if (!confirm(`Gutschein ${code} wieder aktivieren?`)) return;
      try {
        const res = await fetch('/api/admin/vouchers', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Authorization: `Basic ${authCredentials}` },
          body: JSON.stringify({ action: 'update-status', code, status: 'active' }),
        });
        const data = await res.json();
        if (data.success) { alert('✅ Gutschein reaktiviert'); loadVouchers(); }
        else { alert('❌ ' + (data.error || 'Fehler')); }
      } catch (err) { alert('Fehler'); }
    }

    async function lookupVoucher(code: string) {
      try {
        const res = await fetch('/api/admin/vouchers', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Authorization: `Basic ${authCredentials}` },
          body: JSON.stringify({ action: 'lookup', code }),
        });
        const data = await res.json();
        if (data.voucher) { showVoucherScanResult(data.voucher); }
        else { alert('❌ Gutschein nicht gefunden'); }
      } catch (err) { alert('Fehler'); }
    }

    // QR-Scanner
    let availableCameras: any[] = [];

    function showScannerStatus(msg: string, type: 'info' | 'error' | 'success' = 'info') {
      const el = document.getElementById('scanner-status');
      if (!el) return;
      el.style.display = 'block';
      el.textContent = msg;
      el.style.background = type === 'error' ? '#fee' : type === 'success' ? '#efe' : '#f0f0f0';
      el.style.color = type === 'error' ? '#c00' : type === 'success' ? '#060' : '#333';
    }

    function hideScannerStatus() {
      const el = document.getElementById('scanner-status');
      if (el) el.style.display = 'none';
    }

    async function loadQrLibrary(): Promise<boolean> {
      if ((window as any).Html5Qrcode) return true;
      const script = document.createElement('script');
      script.src = 'https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js';
      document.head.appendChild(script);
      return new Promise((resolve) => {
        script.onload = () => resolve(true);
        script.onerror = () => resolve(false);
      });
    }

    async function requestCameraPermission(): Promise<boolean> {
      try {
        const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
        // Kamera-Berechtigung erhalten — Stream sofort wieder stoppen
        stream.getTracks().forEach(t => t.stop());
        return true;
      } catch (err: any) {
        console.error('Kamera-Berechtigung verweigert:', err);
        if (err.name === 'NotAllowedError') {
          showScannerStatus('Kamera-Zugriff wurde verweigert. Bitte erlaube den Kamera-Zugriff in den Browser-Einstellungen.', 'error');
        } else if (err.name === 'NotFoundError') {
          showScannerStatus('Keine Kamera gefunden. Bitte verwende ein Gerät mit Kamera.', 'error');
        } else if (err.name === 'NotReadableError') {
          showScannerStatus('Kamera wird von einer anderen App verwendet. Bitte schließe andere Kamera-Apps.', 'error');
        } else {
          showScannerStatus(`Kamera-Fehler: ${err.message || err.name}`, 'error');
        }
        return false;
      }
    }

    async function startScanner(cameraId?: string) {
      const startBtn = document.getElementById('start-scanner-btn');
      const stopBtn = document.getElementById('stop-scanner-btn');
      if (startBtn) startBtn.style.display = 'none';
      if (stopBtn) stopBtn.style.display = 'inline-block';

      showScannerStatus('Kamera wird gestartet...', 'info');

      // 1. Kamera-Berechtigung explizit anfragen
      const hasPermission = await requestCameraPermission();
      if (!hasPermission) {
        if (startBtn) startBtn.style.display = 'inline-block';
        if (stopBtn) stopBtn.style.display = 'none';
        return;
      }

      // 2. Library laden
      const loaded = await loadQrLibrary();
      if (!loaded) {
        showScannerStatus('QR-Scanner konnte nicht geladen werden. Bitte Seite neu laden.', 'error');
        if (startBtn) startBtn.style.display = 'inline-block';
        if (stopBtn) stopBtn.style.display = 'none';
        return;
      }

      // 3. Kameras auflisten
      try {
        availableCameras = await (window as any).Html5Qrcode.getCameras();
        if (!availableCameras || availableCameras.length === 0) {
          showScannerStatus('Keine Kamera gefunden.', 'error');
          if (startBtn) startBtn.style.display = 'inline-block';
          if (stopBtn) stopBtn.style.display = 'none';
          return;
        }

        // Kamera-Auswahl anzeigen wenn mehrere vorhanden
        if (availableCameras.length > 1) {
          const selectBox = document.getElementById('camera-select-box');
          const selectEl = document.getElementById('camera-select') as HTMLSelectElement;
          if (selectBox && selectEl) {
            selectBox.style.display = 'block';
            selectEl.innerHTML = availableCameras.map((c: any, i: number) =>
              `<option value="${c.id}" ${c.id === cameraId ? 'selected' : ''}>${c.label || 'Kamera ' + (i + 1)}</option>`
            ).join('');
          }
        }
      } catch (e: any) {
        console.error('Kamera-Liste Fehler:', e);
      }

      // 4. Scanner instanz erstellen (alte stoppen falls vorhanden)
      if (html5QrCode && scannerRunning) {
        try { await html5QrCode.stop(); } catch {}
      }
      html5QrCode = new (window as any).Html5Qrcode('qr-reader');

      // 5. Beste Kamera wählen: übergebene ID > Rückkamera > erste verfügbar
      let selectedCameraId = cameraId;
      if (!selectedCameraId && availableCameras.length > 0) {
        // Rückkamera bevorzugen (enthält oft "back", "rear", "environment", "rück")
        const backCam = availableCameras.find((c: any) =>
          /back|rear|environment|rück|hinten|0/i.test(c.label || '')
        );
        selectedCameraId = backCam ? backCam.id : availableCameras[availableCameras.length - 1].id;
      }

      // 6. Scanner starten
      scannerRunning = true;
      try {
        await html5QrCode.start(
          selectedCameraId || { facingMode: 'environment' },
          { fps: 10, qrbox: { width: 220, height: 220 }, aspectRatio: 1.0 },
          (decodedText: string) => {
            let code = decodedText;
            const match = decodedText.match(/einloesen\/([A-Z0-9-]+)/i);
            if (match) code = match[1];
            stopScanner();
            lookupVoucher(code);
          },
          () => {} // scan-Fehler ignorieren (kein QR im Bild)
        );
        hideScannerStatus();
      } catch (err: any) {
        console.error('Scanner start error:', err);
        scannerRunning = false;
        showScannerStatus(`Kamera konnte nicht gestartet werden: ${err.message || err}`, 'error');
        if (startBtn) startBtn.style.display = 'inline-block';
        if (stopBtn) stopBtn.style.display = 'none';
      }
    }

    function stopScanner() {
      const startBtn = document.getElementById('start-scanner-btn');
      const stopBtn = document.getElementById('stop-scanner-btn');
      if (startBtn) startBtn.style.display = 'inline-block';
      if (stopBtn) stopBtn.style.display = 'none';
      document.getElementById('camera-select-box')!.style.display = 'none';
      hideScannerStatus();
      if (html5QrCode && scannerRunning) {
        html5QrCode.stop().catch(() => {});
        scannerRunning = false;
      }
    }

    // Event-Listener
    document.getElementById('start-scanner-btn')?.addEventListener('click', () => startScanner());
    document.getElementById('stop-scanner-btn')?.addEventListener('click', stopScanner);
    document.getElementById('camera-select')?.addEventListener('change', (e) => {
      const select = e.target as HTMLSelectElement;
      if (select.value && scannerRunning) {
        startScanner(select.value);
      }
    });
    document.getElementById('lookup-voucher-btn')?.addEventListener('click', () => {
      const input = document.getElementById('manual-voucher-code') as HTMLInputElement;
      if (input?.value.trim()) lookupVoucher(input.value.trim());
    });
    document.getElementById('manual-voucher-code')?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        const input = e.target as HTMLInputElement;
        if (input.value.trim()) lookupVoucher(input.value.trim());
      }
    });

    // Gutscheine laden wenn Tab aktiv wird
    const tabBtns = document.querySelectorAll('.admin-nav__btn');
    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        if (btn.getAttribute('data-tab') === 'gutscheine') {
          loadVouchers();
        }
      });
    });

    (window as any).adminRedeemVoucher = adminRedeemVoucher;
    (window as any).adminReactivateVoucher = adminReactivateVoucher;

    // ========== ECHTZEIT-UPDATES (Auto-Refresh) ==========
    let autoRefreshInterval: ReturnType<typeof setInterval> | null = null;
    let lastRefreshTime: Date | null = null;

    function startAutoRefresh() {
      if (autoRefreshInterval) return;
      autoRefreshInterval = setInterval(async () => {
        // Nur refreshen wenn Admin-Panel sichtbar ist
        if (document.getElementById('admin-panel')?.classList.contains('hidden')) return;

        try {
          // Aktiven Tab ermitteln
          const activeTab = document.querySelector('.admin-nav__btn.active')?.getAttribute('data-tab');

          if (activeTab === 'termine' || activeTab === 'uebersicht') {
            await Promise.all([loadSlots(), loadBookings()]);
          } else if (activeTab === 'workshops') {
            await Promise.all([loadWorkshops(), loadWorkshopBookings()]);
          } else if (activeTab === 'gutscheine') {
            await loadVouchers();
          } else if (activeTab === 'bewertungen') {
            await loadReviews();
          }

          // Auch Übersicht aktualisieren wenn nicht aktiver Tab
          if (activeTab !== 'uebersicht') {
            updateOverviewIfVisible();
          }

          lastRefreshTime = new Date();
          updateRefreshIndicator();
        } catch (err) {
          console.error('Auto-refresh error:', err);
        }
      }, 30000); // Alle 30 Sekunden
    }

    function stopAutoRefresh() {
      if (autoRefreshInterval) {
        clearInterval(autoRefreshInterval);
        autoRefreshInterval = null;
      }
    }

    function updateRefreshIndicator() {
      const indicator = document.getElementById('refresh-indicator');
      if (indicator && lastRefreshTime) {
        indicator.textContent = `Aktualisiert: ${lastRefreshTime.toLocaleTimeString('de-DE')}`;
      }
    }

    // Auto-Refresh starten wenn Admin-Panel sichtbar wird
    const adminPanel = document.getElementById('admin-panel');
    if (adminPanel) {
      const observer = new MutationObserver(() => {
        if (!adminPanel.classList.contains('hidden')) {
          startAutoRefresh();
        } else {
          stopAutoRefresh();
        }
      });
      observer.observe(adminPanel, { attributes: true, attributeFilter: ['class'] });
    }

    // Seite verlassen: Refresh stoppen
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        stopAutoRefresh();
      } else if (!document.getElementById('admin-panel')?.classList.contains('hidden')) {
        startAutoRefresh();
        // Sofort refreshen wenn Seite wieder sichtbar
        loadSlots();
        loadBookings();
      }
    });
  </script>
</body>
</html>

