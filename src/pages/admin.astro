---
export const prerender = false;
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - Terminverwaltung | Atelier Auszeit</title>
  <link rel="stylesheet" href="/admin-styles.css">
</head>
<body>
  <div id="login-screen" class="login-container">
    <div class="login-box">
      <h1>🎨 Admin Login</h1>
      <p>Atelier Auszeit</p>
      <form id="login-form">
        <div class="form-group">
          <label for="username">Benutzername</label>
          <input type="text" id="username" name="username" value="admin" required>
        </div>
        <div class="form-group">
          <label for="password">Passwort</label>
          <input type="password" id="password" name="password" required>
        </div>
        <button type="submit" class="btn btn-primary">Anmelden</button>
        <div id="login-error" class="error-message hidden"></div>
      </form>
    </div>
  </div>

  <!-- 2FA Verification Screen -->
  <div id="twofa-screen" class="login-container hidden">
    <div class="login-box">
      <h1>🔐 2-Faktor-Authentifizierung</h1>
      <p>Bitte geben Sie den Code aus Ihrer Authenticator-App ein</p>
      <form id="twofa-form">
        <div class="form-group">
          <label for="twofa-code">6-stelliger Code</label>
          <input type="text" id="twofa-code" name="code"
                 pattern="[0-9]{6}" maxlength="6"
                 inputmode="numeric" autocomplete="one-time-code"
                 placeholder="000000" required
                 style="text-align: center; font-size: 1.5rem; letter-spacing: 0.5rem;">
        </div>
        <button type="submit" class="btn btn-primary">Bestätigen</button>
        <button type="button" id="twofa-cancel" class="btn btn-secondary" style="margin-top: 0.5rem;">Abbrechen</button>
        <div id="twofa-error" class="error-message hidden"></div>
      </form>
    </div>
  </div>

	  <div id="admin-panel" class="admin-container hidden">
	    <header class="admin-header">
	      <h1>🎨 Admin Panel</h1>
	      <div class="admin-header-buttons">
	        <button id="setup-2fa-btn" class="btn btn-secondary hidden" title="2FA für Admin einrichten">🔐 2FA Setup</button>
	        <button id="logout-btn" class="btn btn-secondary">Abmelden</button>
	      </div>
	    </header>

    <nav class="admin-nav">
      <button class="admin-nav__btn active" data-tab="uebersicht">📋 Übersicht</button>
      <button class="admin-nav__btn" data-tab="termine">Termine</button>
      <button class="admin-nav__btn" data-tab="workshops">Workshops</button>
      <button class="admin-nav__btn" data-tab="galerie">Galerie</button>
      <button class="admin-nav__btn" data-tab="bewertungen">Bewertungen</button>
      <button class="admin-nav__btn" data-tab="gutscheine">🎟️ Gutscheine</button>
    </nav>

	    		<main class="admin-main">
      <!-- Tab: Übersicht (Arbeitszentrale) -->
      <div id="tab-uebersicht" class="admin-tab active">
        <!-- Header mit Refresh-Indikator -->
        <div class="overview-top-bar">
          <h2>📋 Tagesübersicht</h2>
          <span id="refresh-indicator" class="refresh-indicator"></span>
        </div>

        <!-- KPI-Karten -->
        <div class="overview-kpis">
          <div class="kpi-card kpi-highlight">
            <div class="kpi-value" id="dashboard-today-count">-</div>
            <div class="kpi-label">Termine heute</div>
          </div>
          <div class="kpi-card kpi-warning">
            <div class="kpi-value" id="dashboard-new-count">-</div>
            <div class="kpi-label">Neue Anfragen</div>
          </div>
          <div class="kpi-card">
            <div class="kpi-value" id="dashboard-confirmed-count">-</div>
            <div class="kpi-label">Bestätigt</div>
          </div>
          <div class="kpi-card">
            <div class="kpi-value" id="dashboard-cancelled-count">-</div>
            <div class="kpi-label">Stornierungen</div>
          </div>
          <div class="kpi-card">
            <div class="kpi-value" id="dashboard-next7-count">-</div>
            <div class="kpi-label">Nächste 7 Tage</div>
          </div>
          <div class="kpi-card kpi-voucher">
            <div class="kpi-value" id="dashboard-voucher-count">-</div>
            <div class="kpi-label">Offene Gutscheine</div>
          </div>
        </div>

        <!-- Warnhinweise -->
        <section class="overview-card overview-warnings hidden" id="overview-warnings">
          <h3>⚠️ Handlungsbedarf</h3>
          <div id="warnings-list" class="warnings-list"></div>
        </section>

        <!-- Zwei-Spalten: Heutige Termine + Wochenkalender -->
        <div class="overview-content-grid">
          <!-- Heutige Termine -->
          <section class="overview-card">
            <h3>🕐 Heutige Termine</h3>
            <div id="today-bookings-loading" class="loading">Lade...</div>
            <div id="today-bookings-list" class="today-bookings-list hidden"></div>
            <div id="no-today-bookings" class="no-data hidden">Keine Termine für heute</div>
          </section>

          <!-- Wochenkalender -->
          <section class="overview-card overview-calendar-card">
            <div class="cal-header">
              <h3>📅 Wochenkalender</h3>
              <div class="cal-nav">
                <button id="cal-prev-week">← Vor</button>
                <span id="cal-week-label">Kalenderwoche</span>
                <button id="cal-next-week">Nächste →</button>
              </div>
            </div>
            <div id="week-calendar" class="week-calendar"></div>
          </section>
        </div>

        <!-- Tages-Detail-Panel (wird per Klick auf Kalendertag geöffnet) -->
        <div id="day-detail-panel" class="day-detail-panel hidden">
          <div class="day-detail-header">
            <h3 id="day-detail-title">Termine am ...</h3>
            <button id="day-detail-close" class="day-detail-close">&times;</button>
          </div>
          <div id="day-detail-content" class="day-detail-content"></div>
        </div>
      </div>

      <!-- Tab: Termine -->
      <div id="tab-termine" class="admin-tab hidden">
			      <section class="add-slot-section">
		        <h2 id="slot-form-title">Neuen Termin hinzufügen</h2>
		        <form id="add-slot-form">
		          <div class="form-row">
		            <div class="form-group">
		              <label for="slot-event-type">Event-Typ</label>
		              <select id="slot-event-type" name="eventType">
		                <option value="normal">Normaler Termin</option>
		                <option value="kindergeburtstag">🎂 Kindergeburtstag</option>
		                <option value="stammtisch">🍷 Stammtisch</option>
		              </select>
		            </div>
		            <div class="form-group">
		              <label for="slot-date">Datum</label>
		              <input type="date" id="slot-date" name="date" required>
		            </div>
		            <div class="form-group">
		              <label for="slot-start-time">Beginn</label>
		              <input type="time" id="slot-start-time" name="startTime" required>
		            </div>
		            <div class="form-group">
		              <label for="slot-end-time">Ende</label>
		              <input type="time" id="slot-end-time" name="endTime" required>
		            </div>
		            <div class="form-group">
		              <label for="slot-capacity">Max. Personen</label>
		              <input type="number" id="slot-capacity" name="maxCapacity" min="1" max="20" value="15" required>
		            </div>
		            <div class="form-group" id="initial-booked-group">
		              <label for="slot-initial-booked">Bereits gebuchte Plätze</label>
		              <input type="number" id="slot-initial-booked" name="initialBooked" min="0" max="20" value="0">
		            </div>
		          </div>
		          <p id="event-type-hint" class="event-type-hint hidden">
		            ℹ️ Dieses Zeitfenster wird im Kalender als belegt angezeigt. Andere Zeitfenster am selben Tag bleiben buchbar.
		          </p>
		          <div class="form-actions">
		            <button type="submit" class="btn btn-primary" id="slot-submit-btn">Termin hinzufügen</button>
		            <button type="button" class="btn btn-secondary hidden" id="cancel-edit-btn">Bearbeitung abbrechen</button>
		          </div>
		        </form>
		      </section>

	      <section class="slots-section">
	        <h2>Verfügbare Termine</h2>
	        <div id="slots-loading" class="loading">Lade Termine...</div>
	        <div id="slots-list" class="slots-list hidden"></div>
	        <div id="no-slots" class="no-data hidden">Keine Termine vorhanden</div>
	      </section>

	      <section class="bookings-section">
	        <h2>Buchungen</h2>
	        <!-- Filter und Suche -->
	        <div class="bookings-filter-bar">
	          <input type="text" id="booking-search" class="booking-search-input" placeholder="🔍 Name, E-Mail oder Telefon suchen...">
	          <div class="bookings-status-filter">
	            <button class="filter-btn active" data-booking-filter="active">Aktiv</button>
	            <button class="filter-btn" data-booking-filter="pending">⏳ Offen</button>
	            <button class="filter-btn" data-booking-filter="confirmed">✅ Bestätigt</button>
	            <button class="filter-btn" data-booking-filter="cancelled">❌ Storniert</button>
	            <button class="filter-btn" data-booking-filter="all">Alle</button>
	          </div>
	        </div>
	        <div id="bookings-loading" class="loading">Lade Buchungen...</div>
	        <div id="bookings-list" class="slots-list hidden"></div>
	        <div id="no-bookings" class="no-data hidden">Keine Buchungen vorhanden</div>
	      </section>
      </div>
      <!-- Ende Tab: Termine -->

      <!-- Tab: Workshops -->
      <div id="tab-workshops" class="admin-tab hidden">
        <section class="add-workshop-section">
          <h2 id="workshop-form-title">Neuen Workshop hinzufügen</h2>
          <form id="add-workshop-form">
            <div class="form-row">
              <div class="form-group">
                <label for="workshop-title">Titel</label>
                <input type="text" id="workshop-title" name="title" required>
              </div>
              <div class="form-group">
                <label for="workshop-date">Datum</label>
                <input type="date" id="workshop-date" name="date" required>
              </div>
              <div class="form-group">
                <label for="workshop-time">Uhrzeit</label>
                <input type="time" id="workshop-time" name="time" required>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="workshop-price">Preis</label>
                <input type="text" id="workshop-price" name="price" placeholder="z.B. 45€ pro Person" required>
              </div>
              <div class="form-group">
                <label for="workshop-max-participants">Max. Teilnehmer</label>
                <input type="number" id="workshop-max-participants" name="maxParticipants" min="1" max="50" value="10" required>
              </div>
              <div class="form-group">
                <label for="workshop-active">
                  <input type="checkbox" id="workshop-active" name="active" checked>
                  Aktiv (auf Hauptseite anzeigen)
                </label>
              </div>
            </div>
            <div class="form-group">
              <label for="workshop-description">Kurzbeschreibung (für Karte)</label>
              <textarea id="workshop-description" name="description" rows="2" required placeholder="Kurze Beschreibung für die Workshop-Karte"></textarea>
              <small class="form-hint">Wird auf der Workshop-Karte angezeigt (max. 2 Zeilen)</small>
            </div>
            <div class="form-group">
              <label for="workshop-detailed-description">Ausführliche Beschreibung (für Modal)</label>
              <textarea id="workshop-detailed-description" name="detailedDescription" rows="6" placeholder="Detaillierte Beschreibung, die im Modal angezeigt wird"></textarea>
              <small class="form-hint">Wird im Detail-Modal angezeigt (optional)</small>
            </div>
            <div class="form-group">
              <label for="workshop-image">Titelbild (optional)</label>
              <select id="workshop-image" name="imageFilename">
                <option value="">Kein Bild</option>
              </select>
              <small class="form-hint">Wählen Sie ein Bild aus der Galerie (nicht zugeordnete Bilder)</small>
              <div id="workshop-image-preview" class="workshop-image-preview"></div>
            </div>
            <div class="form-actions">
              <button type="submit" class="btn btn-primary" id="workshop-submit-btn">Workshop hinzufügen</button>
              <button type="button" class="btn btn-secondary hidden" id="cancel-workshop-edit-btn">Bearbeitung abbrechen</button>
            </div>
          </form>
        </section>

        <section class="workshops-list-section">
          <h2>Workshops</h2>
          <div id="workshops-loading" class="loading">Lade Workshops...</div>
          <div id="workshops-list" class="slots-list hidden"></div>
          <div id="no-workshops-admin" class="no-data hidden">Keine Workshops vorhanden</div>
        </section>

        <section class="workshop-bookings-section">
          <h2>Workshop-Buchungen</h2>
          <div id="workshop-bookings-loading" class="loading">Lade Workshop-Buchungen...</div>
          <div id="workshop-bookings-list" class="bookings-list hidden"></div>
          <div id="no-workshop-bookings" class="no-data hidden">Keine Workshop-Buchungen vorhanden</div>
        </section>
      </div>
      <!-- Ende Tab: Workshops -->

      <!-- Tab: Galerie -->
      <div id="tab-galerie" class="admin-tab hidden">
        <!-- Bild hochladen -->
        <section class="gallery-upload-section">
          <h2>Bild hochladen</h2>
          <div class="upload-area" id="upload-drop-area">
            <div class="upload-icon">📤</div>
            <p class="upload-text">Klicken oder Datei hierher ziehen</p>
            <p class="upload-hint">Max. 50MB | JPG, PNG, GIF, WebP</p>
            <input type="file" id="gallery-file-input" accept="image/*" hidden>
          </div>
          <div id="upload-status" class="upload-status"></div>
        </section>

        <!-- Bilder mit Kategorien -->
        <section class="gallery-list-section">
          <div class="gallery-header">
            <h2>Bilder für Hauptseite (mit Kategorie)</h2>
            <button type="button" class="btn btn-secondary" id="reload-gallery-btn">🔄 Neu laden</button>
          </div>
          <div id="gallery-categorized" class="gallery-categories"></div>
        </section>

        <!-- Bilder ohne Kategorie -->
        <section class="gallery-uncategorized-section">
          <h2>Nicht zugeordnete Bilder</h2>
          <p class="hint">Diese Bilder werden nicht auf der Hauptseite angezeigt. Weise ihnen eine Kategorie zu.</p>
          <div id="gallery-uncategorized" class="gallery-grid"></div>
        </section>
      </div>
      <!-- Ende Tab: Galerie -->

      <!-- Tab: Bewertungen -->
      <div id="tab-bewertungen" class="admin-tab hidden">
        <section class="reviews-section">
          <h2>Kundenbewertungen verwalten</h2>

          <div class="reviews-stats">
            <div class="stat-card">
              <div class="stat-label">Wartend</div>
              <div class="stat-value" id="reviews-pending-count">0</div>
            </div>
            <div class="stat-card">
              <div class="stat-label">Freigegeben</div>
              <div class="stat-value" id="reviews-approved-count">0</div>
            </div>
            <div class="stat-card">
              <div class="stat-label">Gesamt</div>
              <div class="stat-value" id="reviews-total-count">0</div>
            </div>
          </div>

          <div class="reviews-filter">
            <button class="filter-btn active" data-filter="all">Alle</button>
            <button class="filter-btn" data-filter="pending">Wartend</button>
            <button class="filter-btn" data-filter="approved">Freigegeben</button>
          </div>

          <div id="reviews-loading" class="loading">Lade Bewertungen...</div>
          <div id="reviews-list" class="reviews-admin-list hidden"></div>
          <div id="no-reviews" class="no-data hidden">Keine Bewertungen vorhanden</div>
        </section>
      </div>
      <!-- Ende Tab: Bewertungen -->

      <!-- Tab: Gutscheine -->
      <div id="tab-gutscheine" class="admin-tab hidden">
        <section class="voucher-section">
          <h2>Gutscheine verwalten</h2>

          <!-- QR-Scanner -->
          <div class="voucher-scanner-box">
            <h3>📷 QR-Code scannen</h3>
            <p style="font-size: 0.85rem; color: #666; margin-bottom: 0.5rem;">Kamera auf den QR-Code des Kunden halten</p>
            <div id="scanner-status" style="display: none; padding: 0.5rem; border-radius: 8px; margin-bottom: 0.5rem; font-size: 0.85rem; text-align: center;"></div>
            <div id="camera-select-box" style="display: none; margin-bottom: 0.5rem; text-align: center;">
              <label for="camera-select" style="font-size: 0.85rem; color: #666;">Kamera wählen: </label>
              <select id="camera-select" style="padding: 0.4rem; border-radius: 6px; border: 1px solid #ddd; font-size: 0.85rem;"></select>
            </div>
            <div id="qr-reader" style="width: 100%; max-width: 400px; margin: 0 auto; border-radius: 12px; overflow: hidden;"></div>
            <div style="text-align: center;">
              <button id="start-scanner-btn" class="btn btn-primary" style="margin-top: 1rem;">📷 Scanner starten</button>
              <button id="stop-scanner-btn" class="btn btn-secondary" style="margin-top: 1rem; display: none;">Scanner stoppen</button>
            </div>
          </div>

          <!-- Manuelle Code-Eingabe -->
          <div class="voucher-manual-box" style="margin-top: 1.5rem;">
            <h3>✏️ Code manuell eingeben</h3>
            <div style="display: flex; gap: 0.5rem; max-width: 400px; margin: 0.5rem auto;">
              <input type="text" id="manual-voucher-code" placeholder="AUSZ-XXXX-XXXX" style="flex: 1; padding: 0.5rem; border: 1px solid #ddd; border-radius: 8px; text-transform: uppercase; font-family: monospace; font-size: 1rem; text-align: center;">
              <button id="lookup-voucher-btn" class="btn btn-primary">Suchen</button>
            </div>
          </div>

          <!-- Scan-Ergebnis -->
          <div id="voucher-scan-result" style="display: none; margin-top: 1.5rem;"></div>

          <!-- Gutschein-Statistiken -->
          <div class="voucher-stats" style="margin-top: 2rem;">
            <div class="stat-card">
              <div class="stat-label">Aktiv</div>
              <div class="stat-value" id="voucher-active-count">0</div>
            </div>
            <div class="stat-card">
              <div class="stat-label">Eingelöst</div>
              <div class="stat-value" id="voucher-redeemed-count">0</div>
            </div>
            <div class="stat-card">
              <div class="stat-label">Gesamt</div>
              <div class="stat-value" id="voucher-total-count">0</div>
            </div>
          </div>

          <!-- Gutschein-Liste -->
          <div id="voucher-loading" class="loading">Lade Gutscheine...</div>
          <div id="voucher-list" class="voucher-admin-list hidden"></div>
          <div id="no-vouchers" class="no-data hidden">Keine Gutscheine vorhanden</div>
        </section>
      </div>
      <!-- Ende Tab: Gutscheine -->

	    </main>
  </div>

	  <script>
	    let authCredentials = sessionStorage.getItem('adminAuth') || '';
	    let editingSlotId: string | null = null;

    // Globale Datenspeicher für Übersicht & Kalender
    let cachedBookings: any[] = [];
    let cachedSlots: any[] = [];
    let calendarWeekOffset = 0; // 0 = aktuelle Woche

    // Auto-Login bei Seitenload wenn Session vorhanden
    if (authCredentials) {
      // Credentials validieren mit einem Test-Request
      fetch('/api/admin/slots', { headers: { 'Authorization': `Basic ${authCredentials}` } })
        .then(res => {
          if (res.ok) {
            document.getElementById('login-screen')?.classList.add('hidden');
            document.getElementById('admin-panel')?.classList.remove('hidden');
            Promise.all([loadSlots(), loadBookings()]).then(() => {
              renderOverview();
              renderWeekCalendar();
            });
          } else {
            // Credentials ungültig - Session löschen
            authCredentials = '';
            sessionStorage.removeItem('adminAuth');
          }
        })
        .catch(() => {
          authCredentials = '';
          sessionStorage.removeItem('adminAuth');
        });
    }

    // Hilfsfunktion: HTML escapen
    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    // Speichert die URL für das ausgewählte Bild (für Vorschau)
    let workshopImageUrlMap: Record<string, string> = {};

    function updateWorkshopImagePreview(imageValue: string | null) {
      const previewEl = document.getElementById('workshop-image-preview') as HTMLDivElement | null;
      if (!previewEl) return;

      if (!imageValue) {
        previewEl.innerHTML = '';
        return;
      }

      // Wenn es bereits eine URL ist (beginnt mit http), direkt verwenden
      // Sonst aus der Map holen
      const imageUrl = imageValue.startsWith('http')
        ? imageValue
        : (workshopImageUrlMap[imageValue] || '');

      if (!imageUrl) {
        previewEl.innerHTML = '';
        return;
      }

      previewEl.innerHTML = `
        <div class="workshop-image-preview__inner">
          <img src="${escapeHtml(imageUrl)}" alt="Ausgewähltes Titelbild" loading="lazy">
        </div>
      `;
    }

    // Pending 2FA Session für Admin-Login
    let pending2FASessionId = '';

    // Login-Handler mit 2FA-Unterstützung
    document.getElementById('login-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(e.target as HTMLFormElement);
      const username = formData.get('username');
      const password = formData.get('password');

      const credentials = btoa(`${username}:${password}`);

      try {
        // Step 1: Verify password and check if 2FA is required
        const response = await fetch('/api/admin/verify-2fa', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'init', credentials })
        });

        const result = await response.json();

        if (!result.success) {
          const errorEl = document.getElementById('login-error');
          if (errorEl) {
            errorEl.textContent = result.message || 'Ungültige Anmeldedaten';
            errorEl.classList.remove('hidden');
          }
          return;
        }

        // Superuser oder Admin ohne 2FA - direkter Login
        if (!result.requires2FA) {
          authCredentials = result.credentials;
          sessionStorage.setItem('adminAuth', authCredentials);
          document.getElementById('login-screen')?.classList.add('hidden');
          document.getElementById('admin-panel')?.classList.remove('hidden');

          // Zeige 2FA-Setup-Button nur für Superuser
          if (result.userType === 'superuser') {
            document.getElementById('setup-2fa-btn')?.classList.remove('hidden');
          }

          // Paralleles Laden für schnellere Ladezeiten + Übersicht
          Promise.all([loadSlots(), loadBookings()]).then(() => {
            renderOverview();
            renderWeekCalendar();
          });
          return;
        }

        // Admin mit 2FA - zeige 2FA-Screen
        pending2FASessionId = result.sessionId;
        authCredentials = credentials; // Temporär speichern
        document.getElementById('login-screen')?.classList.add('hidden');
        document.getElementById('twofa-screen')?.classList.remove('hidden');
        (document.getElementById('twofa-code') as HTMLInputElement)?.focus();

      } catch (error) {
        console.error('Login error:', error);
        const errorEl = document.getElementById('login-error');
        if (errorEl) {
          errorEl.textContent = 'Verbindungsfehler';
          errorEl.classList.remove('hidden');
        }
      }
    });

    // 2FA Code Verification
    document.getElementById('twofa-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const code = (document.getElementById('twofa-code') as HTMLInputElement)?.value;

      try {
        const response = await fetch('/api/admin/verify-2fa', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            action: 'verify',
            sessionId: pending2FASessionId,
            code
          })
        });

        const result = await response.json();

        if (result.success) {
          authCredentials = result.credentials;
          sessionStorage.setItem('adminAuth', authCredentials);
          document.getElementById('twofa-screen')?.classList.add('hidden');
          document.getElementById('admin-panel')?.classList.remove('hidden');

          // Zeige 2FA-Setup-Button für Superuser
          if (result.userType === 'superuser') {
            document.getElementById('setup-2fa-btn')?.classList.remove('hidden');
          }

          // Paralleles Laden für schnellere Ladezeiten + Übersicht
          Promise.all([loadSlots(), loadBookings()]).then(() => {
            renderOverview();
            renderWeekCalendar();
          });
        } else {
          const errorEl = document.getElementById('twofa-error');
          if (errorEl) {
            errorEl.textContent = result.message || 'Ungültiger Code';
            errorEl.classList.remove('hidden');
          }
          (document.getElementById('twofa-code') as HTMLInputElement).value = '';
          (document.getElementById('twofa-code') as HTMLInputElement)?.focus();
        }
      } catch (error) {
        console.error('2FA verification error:', error);
      }
    });

