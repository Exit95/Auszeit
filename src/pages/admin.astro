	    // Event-Typ Change Handler - zeigt Hinweis bei Kindergeburtstag/Stammtisch
	    const eventTypeSelect = document.getElementById('slot-event-type') as HTMLSelectElement | null;
	    const eventTypeHint = document.getElementById('event-type-hint');
	    const initialBookedGroup = document.getElementById('initial-booked-group');

	    eventTypeSelect?.addEventListener('change', () => {
	      const eventType = eventTypeSelect.value;
	      const isSpecialEvent = eventType === 'kindergeburtstag' || eventType === 'stammtisch';

	      // Hinweis anzeigen/verstecken
	      if (eventTypeHint) {
	        eventTypeHint.classList.toggle('hidden', !isSpecialEvent);
	      }

	      // Bei Kindergeburtstag/Stammtisch: "Bereits gebucht" ausblenden und auf max setzen
	      if (initialBookedGroup) {
	        initialBookedGroup.classList.toggle('hidden', isSpecialEvent);
	      }
	    });

	    // Termin hinzufügen / bearbeiten
	    document.getElementById('add-slot-form')?.addEventListener('submit', async (e) => {
	      e.preventDefault();
	      const form = e.target as HTMLFormElement;
	      const formData = new FormData(form);

	      const eventType = formData.get('eventType') || 'normal';
	      const isSpecialEvent = eventType === 'kindergeburtstag' || eventType === 'stammtisch';

	      const baseData = {
	        date: formData.get('date'),
	        startTime: formData.get('startTime'),
	        endTime: formData.get('endTime'),
	        maxCapacity: formData.get('maxCapacity'),
	        eventType: eventType
	      };

	      try {
	        let response: Response;

	        if (editingSlotId) {
	          // Vorhandenen Termin aktualisieren
	          const updatePayload = {
	            id: editingSlotId,
	            ...baseData,
	            initialBooked: isSpecialEvent
	              ? formData.get('maxCapacity') // Alles gebucht bei Spezial-Events
	              : (formData.get('initialBooked') || '0')
	          };

	          response = await fetch('/api/admin/slots', {
	            method: 'PUT',
	            headers: {
	              'Authorization': `Basic ${authCredentials}`,
	              'Content-Type': 'application/json'
	            },
	            body: JSON.stringify(updatePayload)
	          });
	        } else {
	          // Neuen Termin anlegen
	          // Bei Kindergeburtstag/Stammtisch: Tag ist komplett ausgebucht (available = 0)
	          const data = {
	            ...baseData,
	            initialBooked: isSpecialEvent
	              ? formData.get('maxCapacity') // Alles gebucht
	              : (formData.get('initialBooked') || '0')
	          };

	          response = await fetch('/api/admin/slots', {
	            method: 'POST',
	            headers: {
	              'Authorization': `Basic ${authCredentials}`,
	              'Content-Type': 'application/json'
	            },
	            body: JSON.stringify(data)
	          });
	        }

	        if (response.ok) {
	          form.reset();
	          resetSlotFormState();
	          // Hinweis wieder verstecken nach Reset
	          if (eventTypeHint) eventTypeHint.classList.add('hidden');
	          if (initialBookedGroup) initialBookedGroup.classList.remove('hidden');
	          loadSlots();
	        } else {
	          const errorText = await response.text().catch(() => '');
	          console.error('Error saving slot:', errorText);
	          alert('Fehler beim Speichern des Termins');
	        }
	      } catch (error) {
	        console.error('Error saving slot:', error);
	        alert('Fehler beim Speichern des Termins');
	      }
	    });

	    // Bearbeitung abbrechen
	    document.getElementById('cancel-edit-btn')?.addEventListener('click', () => {
	      const form = document.getElementById('add-slot-form') as HTMLFormElement | null;
	      if (form) {
	        form.reset();
	      }
	      resetSlotFormState();
	    });

    // Termine laden
    async function loadSlots() {
      const loadingEl = document.getElementById('slots-loading');
      const listEl = document.getElementById('slots-list');
      const noSlotsEl = document.getElementById('no-slots');

      if (loadingEl) loadingEl.classList.remove('hidden');
      if (listEl) listEl.classList.add('hidden');
      if (noSlotsEl) noSlotsEl.classList.add('hidden');

      try {
        const response = await fetch('/api/admin/slots', {
          headers: {
            'Authorization': `Basic ${authCredentials}`
          }
        });

        if (!response.ok) throw new Error('Failed to load slots');

        const slots = await response.json();
        cachedSlots = slots as any[];

        if (loadingEl) loadingEl.classList.add('hidden');

        if (slots.length === 0) {
          if (noSlotsEl) noSlotsEl.classList.remove('hidden');
          return;
        }

	        if (listEl) {
	          listEl.innerHTML = slots.map((slot: any) => {
	            // Event-Typ Badge
	            let eventBadge = '';
	            if (slot.eventType === 'kindergeburtstag') {
	              eventBadge = '<span class="event-badge event-kindergeburtstag">🎂 Kindergeburtstag</span>';
	            } else if (slot.eventType === 'stammtisch') {
	              eventBadge = '<span class="event-badge event-stammtisch">🍷 Stammtisch</span>';
	            }

	            return `
	              <div class="slot-card ${slot.eventType !== 'normal' && slot.eventType ? 'slot-special-event' : ''}" data-id="${slot.id}">
	                <div class="slot-info">
	                  <div class="slot-date">${formatDate(slot.date)} ${eventBadge}</div>
	                  <div class="slot-time">${slot.time}${slot.endTime ? ' - ' + slot.endTime : ''} Uhr</div>
	                  <div class="slot-capacity">
	                    ${slot.eventType === 'kindergeburtstag' || slot.eventType === 'stammtisch'
	                      ? '<strong>Zeitfenster belegt</strong>'
	                      : `${slot.available} / ${slot.maxCapacity} Plätze frei`}
	                  </div>
	                </div>
	                <div class="slot-actions">
	                  <button class="btn btn-secondary btn-edit" data-id="${slot.id}">Bearbeiten</button>
	                  <button class="btn btn-danger btn-delete" data-id="${slot.id}">Löschen</button>
	                </div>
	              </div>
	            `;
	          }).join('');
          listEl.classList.remove('hidden');

          // Delete-Handler
          listEl.querySelectorAll('.btn-delete').forEach(btn => {
            btn.addEventListener('click', async (e) => {
              const id = (e.target as HTMLElement).dataset.id;
              if (confirm('Termin wirklich löschen?')) {
                await deleteSlot(id!);
              }
            });
          });

	          // Edit-Handler
	          listEl.querySelectorAll('.btn-edit').forEach(btn => {
	            btn.addEventListener('click', (e) => {
	              const id = (e.target as HTMLElement).dataset.id;
	              const slot = (slots as any[]).find(s => s.id === id);
	              if (slot) {
	                startEditSlot(slot);
	              }
	            });
	          });
        }
      } catch (error) {
        console.error('Error loading slots:', error);
        if (loadingEl) loadingEl.classList.add('hidden');
      }
    }

		    // Dashboard-Kennzahlen aktualisieren
		    function updateDashboard(bookings: any[]) {
		      const today = new Date();
		      today.setHours(0, 0, 0, 0);
		      const todayStr = today.toISOString().split('T')[0];
		      const sevenDaysAhead = new Date(today);
		      sevenDaysAhead.setDate(sevenDaysAhead.getDate() + 7);

		      let todayCount = 0;
		      let newCount = 0;
		      let confirmedCount = 0;
		      let cancelledCount = 0;
		      let next7Count = 0;

		      (bookings as any[]).forEach((b) => {
		        if (!b.slotDate) return;
		        const slotDate = new Date(b.slotDate + 'T00:00:00');
		        const status = b.status || 'confirmed';

		        const isToday = b.slotDate === todayStr;
		        const isFutureOrToday = slotDate >= today;
		        const isWithinNext7 = slotDate >= today && slotDate <= sevenDaysAhead;

		        if (isToday && status !== 'cancelled') {
		          todayCount += 1;
		        }

		        if (isFutureOrToday) {
		          if (status === 'pending') newCount += 1;
		          if (status === 'confirmed') confirmedCount += 1;
		          if (status === 'cancelled') cancelledCount += 1;
		        }

		        if (isWithinNext7 && status !== 'cancelled') {
		          next7Count += 1;
		        }
		      });

		      const todayEl = document.getElementById('dashboard-today-count');
		      if (todayEl) todayEl.textContent = String(todayCount);

		      const newEl = document.getElementById('dashboard-new-count');
		      if (newEl) newEl.textContent = String(newCount);

		      const confirmedEl = document.getElementById('dashboard-confirmed-count');
		      if (confirmedEl) confirmedEl.textContent = String(confirmedCount);

		      const cancelledEl = document.getElementById('dashboard-cancelled-count');
		      if (cancelledEl) cancelledEl.textContent = String(cancelledCount);

		      const next7El = document.getElementById('dashboard-next7-count');
		      if (next7El) next7El.textContent = String(next7Count);
		    }

		    // Buchungen laden
		    async function loadBookings() {
	      const loadingEl = document.getElementById('bookings-loading');
	      const listEl = document.getElementById('bookings-list');
	      const noBookingsEl = document.getElementById('no-bookings');

	      if (loadingEl) loadingEl.classList.remove('hidden');
	      if (listEl) listEl.classList.add('hidden');
	      if (noBookingsEl) noBookingsEl.classList.add('hidden');

		      try {
		        const response = await fetch('/api/admin/bookings', {
		          headers: {
		            'Authorization': `Basic ${authCredentials}`,
		          },
		        });
		
		        if (!response.ok) throw new Error('Failed to load bookings');
		
		        const bookings = await response.json();
		        cachedBookings = bookings as any[];

		        // Dashboard aktualisieren (auch wenn es keine aktiven Buchungen mehr gibt)
		        updateDashboard(bookings as any[]);
		
		        if (loadingEl) loadingEl.classList.add('hidden');
		
		        // Filter und Suche anwenden
		        const today = new Date();
		        today.setHours(0, 0, 0, 0);

		        const searchInput = (document.getElementById('booking-search') as HTMLInputElement)?.value?.toLowerCase() || '';
		        const activeFilter = document.querySelector('[data-booking-filter].active')?.getAttribute('data-booking-filter') || 'active';

		        const activeBookings = (bookings as any[])
		          .filter((b) => {
		            // Statusfilter
		            if (activeFilter === 'active') {
		              if (b.status === 'cancelled') return false;
		              if (b.slotDate) {
		                const slotDate = new Date(b.slotDate + 'T00:00:00');
		                if (slotDate < today) return false;
		              }
		            } else if (activeFilter === 'pending') {
		              if (b.status !== 'pending') return false;
		            } else if (activeFilter === 'confirmed') {
		              if (b.status !== 'confirmed') return false;
		            } else if (activeFilter === 'cancelled') {
		              if (b.status !== 'cancelled') return false;
		            }
		            // 'all' zeigt alles

		            // Suchfilter
		            if (searchInput) {
		              const searchFields = [b.name, b.email, b.phone, b.notes].filter(Boolean).join(' ').toLowerCase();
		              if (!searchFields.includes(searchInput)) return false;
		            }

		            return true;
		          })
		          .sort((a, b) => {
		            const aDateBase = a.slotDate || (a.createdAt ? String(a.createdAt).split('T')[0] : '');
		            const bDateBase = b.slotDate || (b.createdAt ? String(b.createdAt).split('T')[0] : '');
		
		            if (!aDateBase || !bDateBase) return 0;
		
		            const aDate = new Date(`${aDateBase}T${a.slotTime || '00:00'}:00`);
		            const bDate = new Date(`${bDateBase}T${b.slotTime || '00:00'}:00`);
		            return aDate.getTime() - bDate.getTime();
		          });

	        if (activeBookings.length === 0) {
	          if (noBookingsEl) noBookingsEl.classList.remove('hidden');
	          return;
	        }

		        if (listEl) {
		          listEl.innerHTML = activeBookings
		            .map((booking: any) => {
		              const dateLabel = booking.slotDate
		                ? formatDate(booking.slotDate)
		                : 'Kein Datum';
		              const timeLabel = booking.slotTime
		                ? `${booking.slotTime}${booking.slotEndTime ? ' - ' + booking.slotEndTime : ''} Uhr`
		                : '';

		              const status = booking.status || 'confirmed';
		              let statusLabel = 'Bestätigt';
		              let statusClass = 'booking-status--confirmed';
		              if (status === 'pending') {
		                statusLabel = 'Neu / unbestätigt';
		                statusClass = 'booking-status--pending';
		              } else if (status === 'cancelled') {
		                statusLabel = 'Abgesagt';
		                statusClass = 'booking-status--cancelled';
		              }

		              const showConfirm = status === 'pending';
		              const showCancel = status !== 'cancelled';

		              return `
		                <div class="slot-card booking-card" data-id="${booking.id}">
		                  <div class="slot-info booking-info">
		                    <div class="booking-main">
		                      <div>
		                        <div class="slot-date">${dateLabel}</div>
		                        <div class="slot-time">${timeLabel}</div>
		                      </div>
		                      <div class="booking-status ${statusClass}">${statusLabel}</div>
		                    </div>
		                    <div class="booking-customer">
		                      <div><strong>${booking.name}</strong>${booking.email ? ` (${booking.email})` : ''}</div>
		                      <div>${booking.participants} Person(en)</div>
		                    </div>
		                  </div>
		                  <div class="slot-actions booking-actions">
		                    ${showConfirm ? `<button class="btn btn-success btn-confirm-booking" data-id="${booking.id}">✓ Bestätigen</button>` : ''}
		                    ${showCancel ? `<button class="btn btn-danger btn-cancel-booking" data-id="${booking.id}">✕ Absagen</button>` : ''}
		                    <button class="btn btn-secondary btn-edit-booking" data-id="${booking.id}">✎ Bearbeiten</button>
		                  </div>
		                </div>
		              `;
		            })
		            .join('');
		
		          listEl.classList.remove('hidden');
		
		          // Cancel-Handler
		          listEl.querySelectorAll('.btn-cancel-booking').forEach((btn) => {
		            btn.addEventListener('click', async (e) => {
		              const id = (e.target as HTMLElement).dataset.id;
		              if (id && confirm('Buchung wirklich stornieren?')) {
		                await cancelBookingAdmin(id);
		              }
		            });
		          });
		
		          // Confirm-Handler
		          listEl.querySelectorAll('.btn-confirm-booking').forEach((btn) => {
		            btn.addEventListener('click', async (e) => {
		              const id = (e.target as HTMLElement).dataset.id;
		              if (id && confirm('Buchung als bestätigt markieren?')) {
		                await confirmBookingAdmin(id);
		              }
		            });
		          });
		
		          // Edit-Handler (Teilnehmerzahl & Notizen mit einfachen Prompts bearbeiten)
		          listEl.querySelectorAll('.btn-edit-booking').forEach((btn) => {
		            btn.addEventListener('click', async (e) => {
		              const id = (e.target as HTMLElement).dataset.id;
		              if (!id) return;

		              const booking = (activeBookings as any[]).find((b) => b.id === id);
		              if (!booking) return;

		              const participantsInput = prompt('Anzahl Personen', String(booking.participants || 1));
		              if (participantsInput === null) return;
		              const participants = parseInt(participantsInput, 10);
		              if (!Number.isFinite(participants) || participants <= 0) {
		                alert('Bitte eine gültige Personenzahl eingeben.');
		                return;
		              }

		              const notesInput = prompt('Notizen (optional)', booking.notes || '');
		              try {
		                const response = await fetch('/api/admin/bookings', {
		                  method: 'PUT',
		                  headers: {
		                    'Authorization': `Basic ${authCredentials}`,
		                    'Content-Type': 'application/json',
		                  },
		                  body: JSON.stringify({
		                    id,
		                    participants,
		                    notes: notesInput ?? '',
		                  }),
		                });
		
		                if (response.ok) {
		                  await loadBookings();
		                  await loadSlots();
		                } else {
		                  const result = await response.json().catch(() => null);
		                  const message = result?.error || 'Fehler beim Aktualisieren der Buchung';
		                  alert(message);
		                }
		              } catch (error) {
		                console.error('Error updating booking:', error);
		                alert('Fehler beim Aktualisieren der Buchung');
		              }
		            });
		          });
		        }
	      } catch (error) {
	        console.error('Error loading bookings:', error);
	        if (loadingEl) loadingEl.classList.add('hidden');
	      }
	    }

    // Termin löschen
    async function deleteSlot(id: string) {
      try {
        const response = await fetch('/api/admin/slots', {
          method: 'DELETE',
          headers: {
            'Authorization': `Basic ${authCredentials}`,
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: JSON.stringify({ id })
        });

        if (response.ok) {
          loadSlots();
        } else {
          alert('Fehler beim Löschen');
        }
      } catch (error) {
        console.error('Error deleting slot:', error);
      }
    }

		    // Buchung stornieren
		    async function cancelBookingAdmin(id: string) {
	      try {
	        const response = await fetch('/api/admin/bookings', {
	          method: 'POST',
	          headers: {
	            'Authorization': `Basic ${authCredentials}`,
	            'Content-Type': 'application/json',
	          },
	          body: JSON.stringify({ id }),
	        });

	        if (response.ok) {
