---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Seite nicht gefunden — Keramik Auszeit" description="Diese Seite wurde nicht gefunden.">
  <section class="not-found">
    <h1>Diese Seite haben wir leider nicht gefunden</h1>
    <p>Vielleicht findest du hier, was du suchst:</p>
    <nav class="not-found__links">
      <a href="/">Startseite</a>
      <a href="/galerie">Galerie</a>
      <a href="/#termin-buchen">Termin buchen</a>
      <a href="/#kontakt">Kontakt</a>
    </nav>
  </section>
</MainLayout>

<style>
  .not-found {
    min-height: 60vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4rem 1.5rem;
    background: var(--bg-linen, #f5ede0);
  }

  .not-found h1 {
    font-family: var(--font-serif, 'Lora', Georgia, serif);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    color: var(--brand-espresso, #3d2316);
    margin: 0 0 1rem;
    max-width: 600px;
    line-height: 1.3;
  }

  .not-found p {
    font-family: var(--font-sans, 'Source Sans 3', sans-serif);
    font-size: 1.1rem;
    color: var(--color-sienna, #a0522d);
    margin: 0 0 2rem;
  }

  .not-found__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .not-found__links a {
    display: inline-block;
    padding: 0.6rem 1.5rem;
    border-radius: 999px;
    font-family: var(--font-sans, 'Source Sans 3', sans-serif);
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    background: var(--accent-terra, #a0522d);
    color: #fff;
    transition: background 0.2s;
  }

  .not-found__links a:hover {
    background: var(--brand-espresso, #3d2316);
  }
</style>
