---
import MainLayout from '../layouts/MainLayout.astro';
import Brush from '../components/Brush.astro';
---

<MainLayout
  title="Buchung stornieren — Malatelier Auszeit"
  description="Storniere deine Buchung im Malatelier Auszeit sicher und unkompliziert."
  noindex={true}
>
  <div class="wrap">
    <div class="pagehead">
      <span class="eyebrow">Buchungsverwaltung</span>
      <h1>Buchung stornieren</h1>
      <Brush />
    </div>

    <div class="cancel-wrap">
      <div id="cancel-container">
        <div id="loading" class="state">
          <p>Buchung wird geladen ...</p>
        </div>

        <div id="error" class="state" style="display:none;">
          <h2>Fehler</h2>
          <p id="error-message"></p>
          <a href="/" class="link-ul">Zurück zur Startseite</a>
        </div>

        <div id="booking-info" style="display:none;">
          <h2>Deine Buchung</h2>
          <div class="booking-card">
            <p><strong>Name:</strong> <span id="info-name"></span></p>
            <p><strong>Teilnehmer:</strong> <span id="info-participants"></span></p>
            <p id="info-date-row"><strong>Datum:</strong> <span id="info-date"></span></p>
            <p id="info-time-row"><strong>Uhrzeit:</strong> <span id="info-time"></span></p>
            <p><strong>Status:</strong> <span id="info-status"></span></p>
          </div>

          <div id="already-cancelled" class="notice notice--warn" style="display:none;">
            <p>Diese Buchung wurde bereits storniert.</p>
            <a href="/" class="link-ul">Zurück zur Startseite</a>
          </div>

          <div id="cancel-form" style="display:none;">
            <p class="cancel-hint">Möchtest du diese Buchung wirklich stornieren? Diese Aktion kann nicht rückgängig gemacht werden.</p>
            <button id="cancel-btn" class="btn btn-danger">Buchung stornieren</button>
            <a href="/" class="link-ul back-link">Abbrechen und zurück zur Startseite</a>
          </div>
        </div>

        <div id="success" class="state" style="display:none;">
          <h2>Buchung storniert</h2>
          <p>Deine Buchung wurde erfolgreich storniert. Danke für die rechtzeitige Absage.</p>
          <a href="/" class="btn btn-terra" style="margin-top:1.5rem;">Zurück zur Startseite</a>
        </div>
      </div>
    </div>
  </div>

  <script>
    const params = new URLSearchParams(window.location.search);
    const id = params.get('id');
    const token = params.get('token');
    const type = params.get('type') || 'booking';

    const loadingEl = document.getElementById('loading')!;
    const errorEl = document.getElementById('error')!;
    const errorMsg = document.getElementById('error-message')!;
    const bookingEl = document.getElementById('booking-info')!;
    const cancelForm = document.getElementById('cancel-form')!;
    const alreadyCancelled = document.getElementById('already-cancelled')!;
    const successEl = document.getElementById('success')!;
    const cancelBtn = document.getElementById('cancel-btn')!;

    function showError(msg: string) {
      loadingEl.style.display = 'none';
      errorMsg.textContent = msg;
      errorEl.style.display = 'block';
    }

    function formatStatus(status: string): string {
      switch (status) {
        case 'pending': return 'Ausstehend';
        case 'confirmed': return 'Bestätigt';
        case 'cancelled': return 'Storniert';
        default: return status;
      }
    }

    async function loadBooking() {
      if (!id || !token) {
        showError('Ungültiger Stornierungslink. Bitte verwenden Sie den Link aus Ihrer E-Mail.');
        return;
      }

      try {
        const res = await fetch(`/api/cancel?id=${encodeURIComponent(id)}&token=${encodeURIComponent(token)}&type=${type}`);
        const data = await res.json();

        if (!res.ok) {
          showError(data.error || 'Buchung konnte nicht geladen werden.');
          return;
        }

        loadingEl.style.display = 'none';
        bookingEl.style.display = 'block';

        document.getElementById('info-name')!.textContent = data.name;
        document.getElementById('info-participants')!.textContent = data.participants;
        document.getElementById('info-status')!.textContent = formatStatus(data.status);

        if (data.date) {
          document.getElementById('info-date')!.textContent = data.date;
        } else {
          document.getElementById('info-date-row')!.style.display = 'none';
        }
        if (data.time) {
          const timeDisplay = data.endTime ? `${data.time} bis ${data.endTime} Uhr` : `${data.time} Uhr`;
          document.getElementById('info-time')!.textContent = timeDisplay;
        } else {
          document.getElementById('info-time-row')!.style.display = 'none';
        }

        if (data.status === 'cancelled') {
          alreadyCancelled.style.display = 'block';
        } else {
          cancelForm.style.display = 'block';
        }
      } catch {
        showError('Verbindungsfehler. Bitte versuchen Sie es später erneut.');
      }
    }

    const cancelErrorEl = document.createElement('p');
    cancelErrorEl.style.cssText = 'color:var(--danger,#dc2626);margin-top:0.75rem;font-size:0.9rem;text-align:center;display:none;';
    cancelBtn.insertAdjacentElement('afterend', cancelErrorEl);

    const showCancelError = (msg: string) => {
      cancelErrorEl.textContent = msg;
      cancelErrorEl.style.display = 'block';
    };

    cancelBtn.addEventListener('click', async () => {
      cancelBtn.setAttribute('disabled', 'true');
      cancelBtn.textContent = 'Wird storniert ...';
      cancelErrorEl.style.display = 'none';

      try {
        const res = await fetch('/api/cancel', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, token, type }),
        });
        const data = await res.json();

        if (res.ok && data.success) {
          bookingEl.style.display = 'none';
          successEl.style.display = 'block';
        } else {
          showCancelError(data.error || 'Stornierung fehlgeschlagen. Bitte versuchen Sie es erneut.');
          cancelBtn.removeAttribute('disabled');
          cancelBtn.textContent = 'Buchung stornieren';
        }
      } catch {
        showCancelError('Verbindungsfehler. Bitte versuchen Sie es später erneut.');
        cancelBtn.removeAttribute('disabled');
        cancelBtn.textContent = 'Buchung stornieren';
      }
    });

    loadBooking();
  </script>
</MainLayout>

<style>
  .cancel-wrap {
    max-width: 540px;
    margin: 2.5rem 0 clamp(3rem, 6vw, 5rem);
  }

  .state {
    padding: 2rem 0;
    color: var(--ink-2);
  }

  .state h2 {
    margin-bottom: 0.75rem;
  }

  .booking-card {
    background: var(--surface);
    border-radius: var(--r-lg, 12px);
    padding: 1.5rem;
    margin: 1.5rem 0;
    border: 1px solid var(--hair);
  }

  .booking-card p {
    color: var(--ink-2);
    line-height: 1.7;
    margin-bottom: 0.5rem;
  }

  .booking-card p:last-child {
    margin-bottom: 0;
  }

  .booking-card strong {
    color: var(--ink);
  }

  .notice {
    border-radius: var(--r-lg, 12px);
    padding: 1.25rem 1.5rem;
    margin-top: 1rem;
  }

  .notice--warn {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #b91c1c;
  }

  .notice--warn p {
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .cancel-hint {
    color: var(--ink-2);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .btn-danger {
    display: inline-block;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 10px;
    padding: .82rem 1.7rem;
    cursor: pointer;
    border: 0;
    transition: background .18s;
    width: 100%;
    background: #dc2626;
    color: #fff;
  }

  .btn-danger:hover {
    background: #b91c1c;
  }

  .btn-danger:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .back-link {
    display: block;
    text-align: center;
    margin-top: 1rem;
  }
</style>
