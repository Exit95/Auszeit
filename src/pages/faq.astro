---
import MainLayout from '../layouts/MainLayout.astro';
import FAQ from '../sections/FAQ.astro';
import { content } from '../data/content';
---
<MainLayout title={content.pageMeta.faq.title} description={content.pageMeta.faq.description}>
  <h1 class="sr-only">Häufige Fragen — Malatelier Auszeit</h1>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": content.faq.items.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer
      }
    }))
  })} />
  <FAQ />
  <section class="faq-cta">
    <h2 class="faq-cta__title">Noch Fragen?</h2>
    <p class="faq-cta__text">Meld dich einfach bei mir, ich helfe dir gern.</p>
    <div class="faq-cta__links">
      <a href="/#termin-buchen">Termin buchen</a>
      <a href="https://wa.me/4917634255005?text=Hallo%2C%20ich%20habe%20eine%20Frage%20zum%20Keramik-Malatelier." target="_blank" rel="noopener">WhatsApp</a>
    </div>
  </section>
</MainLayout>

<style>
  .faq-cta {
    background: var(--bg-linen, #f5ede0);
    padding: 3rem 1.5rem;
    text-align: center;
  }

  .faq-cta__title {
    font-family: var(--font-serif, 'Lora', Georgia, serif);
    font-size: 1.4rem;
    color: var(--brand-espresso, #3d2316);
    margin: 0 0 0.5rem;
  }

  .faq-cta__text {
    font-family: var(--font-sans, 'Source Sans 3', sans-serif);
    color: var(--text-body, #6B5D56);
    margin: 0 0 1.5rem;
  }

  .faq-cta__links {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .faq-cta__links a {
    display: inline-block;
    padding: 0.65rem 1.75rem;
    border-radius: 999px;
    font-family: var(--font-sans, 'Source Sans 3', sans-serif);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
    background: var(--accent-terra, #a0522d);
    color: #fff;
  }

  .faq-cta__links a:hover {
    background: var(--brand-espresso, #3d2316);
    color: #fff;
  }
</style>
