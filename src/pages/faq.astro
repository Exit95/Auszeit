---
import MainLayout from '../layouts/MainLayout.astro';
import FAQ from '../sections/FAQ.astro';
import { content } from '../data/content';
---
<MainLayout title={content.pageMeta.faq.title} description={content.pageMeta.faq.description}>
  <FAQ />
  <section class="faq-cta">
    <p>Noch Fragen? Schreib uns!</p>
    <div class="faq-cta__links">
      <a href="https://wa.me/4917634255005">WhatsApp</a>
      <a href="mailto:keramik-auszeit@web.de">E-Mail</a>
    </div>
  </section>
  <section style="text-align:center; padding: 2rem var(--gutter); max-width: var(--max-width); margin: 0 auto;">
    <h3 style="font-size: 1.25rem; color: #423430; margin-bottom: 0.5rem;">Noch Fragen?</h3>
    <p style="color: #6B5D56; margin-bottom: 1.5rem;">Schreib uns per WhatsApp oder buche direkt deinen Termin.</p>
    <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
      <a href="/#termin-buchen" style="display: inline-block; padding: 14px 32px; background: #D96C4A; color: #fff; border-radius: 8px; text-decoration: none; font-weight: 700;">Termin buchen</a>
      <a href="https://wa.me/4917634255005?text=Hallo%2C%20ich%20habe%20eine%20Frage%20zum%20Keramik-Malatelier." target="_blank" rel="noopener" style="display: inline-block; padding: 14px 32px; background: #FAF7F2; color: #423430; border-radius: 8px; text-decoration: none; font-weight: 700; border: 1px solid #E0D6CC;">WhatsApp</a>
    </div>
  </section>
</MainLayout>

<style>
  .faq-cta {
    background: var(--bg-linen, #f5ede0);
    padding: 3rem 1.5rem;
    text-align: center;
  }

  .faq-cta p {
    font-family: var(--font-serif, 'Lora', Georgia, serif);
    font-size: 1.4rem;
    color: var(--brand-espresso, #3d2316);
    margin: 0 0 1.5rem;
  }

  .faq-cta__links {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .faq-cta__links a {
    display: inline-block;
    padding: 0.65rem 1.75rem;
    border-radius: 999px;
    font-family: var(--font-sans, 'Source Sans 3', sans-serif);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
    background: var(--accent-terra, #a0522d);
    color: #fff;
  }

  .faq-cta__links a:hover {
    background: var(--brand-espresso, #3d2316);
    color: #fff;
  }
</style>
