---
import MainLayout from '../layouts/MainLayout.astro';
import Brush from '../components/Brush.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Photo from '../components/Photo.astro';
---

<MainLayout
  title="Warum kostet Keramik bemalen so viel? | Malatelier Auszeit Gronau"
  description="Wir zeigen dir, was hinter einer Auszeit im Atelier steckt. Fixkosten, Vorbereitung, Nacharbeit und was du wirklich unterstützt, wenn du einen Termin buchst."
>
  <Breadcrumb name="Warum kostet das so viel?" path="/warum" />

  <!-- HERO -->
  <section class="blk">
    <div class="wrap">
      <div class="hero-grid">
        <div class="hero-text" data-animate="slide-right">
          <span class="eyebrow">Hinter den Kulissen</span>
          <h1>Warum kostet Keramik bemalen eigentlich so viel?</h1>
          <Brush />
          <p class="lead">
            Das fragen sich viele. Und ich finde die Frage berechtigt. Deshalb nehme ich euch heute mit hinter die Kulissen des Ateliers und zeige, was wirklich drinsteckt in einem Termin bei mir.
          </p>
        </div>
        <div class="hero-img photo-hover" data-animate="scale-up">
          <Photo
            src="/fotos/warum-hero.webp"
            alt="Beim Keramikbemalen im Malatelier Auszeit in Gronau"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- WAS DU SIEHST -->
  <section class="blk soft">
    <div class="wrap">
      <div class="split-reveal">
        <div class="reveal-card see" data-animate="fade-up">
          <span class="reveal-label">Was du siehst</span>
          <p>Ein paar schöne Stunden im Atelier, einen Rohling deiner Wahl, Farben, Pinsel und jemanden, der dir zeigt, wie es geht.</p>
          <p class="reveal-note">Das ist nicht wenig. Aber es ist nur die halbe Wahrheit.</p>
        </div>
        <div class="reveal-divider" aria-hidden="true"></div>
        <div class="reveal-card hide" data-animate="fade-up" data-animate-delay="150">
          <span class="reveal-label">Was du nicht siehst</span>
          <p>Alles, was vorher, nachher und im Hintergrund passiert. Und das ist eine ganze Menge.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FIXKOSTEN -->
  <section class="blk dark-editorial">
    <div class="wrap">
      <div class="section-intro" data-animate="fade-up">
        <span class="eyebrow eyebrow--light">Die laufenden Kosten</span>
        <h2>Jeden Monat, egal ob das Atelier voll ist oder leer</h2>
        <p class="intro-note">Diese Dinge laufen weiter, ob jemand kommt oder nicht. Sie tragen jeden einzelnen Termin mit.</p>
      </div>
      <ul class="cost-list" data-animate-stagger="70">
        <li data-animate="fade-up">Miete und Nebenkosten</li>
        <li data-animate="fade-up">Strom, Wasser und Heizung</li>
        <li data-animate="fade-up">Buchhaltung und Steuerberatung</li>
        <li data-animate="fade-up">Versicherungen fürs Gewerbe</li>
        <li data-animate="fade-up">Rohkeramiken und Glasuren</li>
        <li data-animate="fade-up">Brennofen und Verbrauchsmaterial</li>
        <li data-animate="fade-up">Website, Buchungssystem und Kassensoftware</li>
        <li data-animate="fade-up">Deko, Mobiliar und Atelier-Ausstattung</li>
      </ul>
    </div>
  </section>

  <!-- ORGANISATION -->
  <section class="blk">
    <div class="wrap">
      <div class="org-grid">
        <div class="org-img photo-hover" data-animate="scale-up">
          <Photo
            src="/fotos/warum-organisation.webp"
            alt="Vorbereitung im Atelier Auszeit, Pinsel und Keramik werden gerichtet"
          />
        </div>
        <div class="org-text" data-animate="slide-right" data-animate-delay="120">
          <span class="eyebrow">Organisation</span>
          <h2>Das läuft im Hintergrund, damit du einfach ankommen kannst</h2>
          <ul class="line-list">
            <li>Termine planen und das Buchungssystem pflegen</li>
            <li>Anfragen per Mail und WhatsApp beantworten</li>
            <li>Neues Sortiment auswählen und einkaufen</li>
            <li>Mobiliar und Ausstattung instand halten</li>
            <li>Buchhaltung führen</li>
            <li>Neue Techniken und Trends im Blick behalten</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- VOR / WÄHREND / NACH -->
  <section class="blk soft">
    <div class="wrap">
      <div class="section-head" data-animate="fade-up">
        <span class="eyebrow">Rund um deinen Termin</span>
        <h2>Was passiert, damit deine Auszeit wirklich eine Auszeit wird</h2>
        <Brush />
      </div>
      <div class="timeline-cards" data-animate-stagger="100">
        <div class="tl-card" data-animate="fade-up">
          <span class="tl-label">Bevor du kommst</span>
          <ul class="line-list">
            <li>Das Atelier wird geputzt und vorbereitet</li>
            <li>Alle Rohkeramiken und Glasuren werden aufgefüllt</li>
            <li>Kaffee und Tee sind bereit</li>
            <li>Die Musik läuft</li>
          </ul>
        </div>
        <div class="tl-card tl-card--mid" data-animate="fade-up">
          <span class="tl-label">Während deiner Auszeit</span>
          <ul class="line-list">
            <li>Ich begleite dich und erkläre die Techniken</li>
            <li>Kaffee, Tee und Wasser gibt es so viel du willst, kostenlos</li>
            <li>Bei der kleinen Gruppe hat jeder genug Zeit und Platz</li>
            <li>Ich bin da, wenn du Hilfe brauchst, und lasse dir Raum, wenn du alleine arbeiten möchtest</li>
          </ul>
        </div>
        <div class="tl-card" data-animate="fade-up">
          <span class="tl-label">Nachdem du gegangen bist</span>
          <ul class="line-list">
            <li>Aufräumen und Reinigen</li>
            <li>Deine Keramik glasieren und für den Brand vorbereiten</li>
            <li>Den Brennofen beladen und überwachen</li>
            <li>Dich benachrichtigen, wenn dein Stück abholbereit ist</li>
            <li>Glasuren und Material wieder auffüllen</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FOTO-QUOTE -->
  <section class="blk">
    <div class="wrap">
      <div class="quote-split">
        <div class="quote-img photo-hover" data-animate="scale-up">
          <Photo
            src="/fotos/warum-irena.webp"
            alt="Irena, Inhaberin des Malateliers Auszeit in Gronau"
          />
        </div>
        <div class="quote-text" data-animate="slide-right" data-animate-delay="120">
          <blockquote class="big-quote">
            „Du bezahlst nicht nur für zwei Stunden Pinsel in der Hand. Du bezahlst für alles, was vorher und nachher passiert. Für das Atelier, das auf dich wartet. Für die Glasur, die ich erst nach deinem Besuch auftrage. Für den Brand, der dein Stück fertig macht.“
            <cite>Irena, Inhaberin Malatelier Auszeit</cite>
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- WAS DU UNTERSTÜTZT -->
  <section class="blk support-blk">
    <div class="wrap">
      <div class="section-head" data-animate="fade-up">
        <span class="eyebrow">Was du unterstützt</span>
        <h2>Wenn du einen Termin im Auszeit buchst</h2>
        <Brush />
      </div>
      <div class="support-grid" data-animate-stagger="100">
        <article class="support-item" data-animate="fade-up">
          <div class="support-img">
            <Photo src="/fotos/warum-menschen.webp" alt="Irena im Atelier Auszeit" />
          </div>
          <div class="support-body">
            <h3>Ein kleines Unternehmen mit echten Menschen</h3>
            <p>Kein Konzern, keine Kette. Nur Irena, ihr Atelier und die Freude daran, Menschen kreative Auszeiten zu schenken.</p>
          </div>
        </article>
        <article class="support-item" data-animate="fade-up">
          <div class="support-img">
            <Photo src="/fotos/warum-handwerk.webp" alt="Farben, Pinsel und bemalte Keramik im Atelier" />
          </div>
          <div class="support-body">
            <h3>Handwerk und Kreativität vor Ort</h3>
            <p>Ein Angebot, das es in Gronau so nur einmal gibt. Und das es nur gibt, weil Menschen wie du kommen.</p>
          </div>
        </article>
        <article class="support-item" data-animate="fade-up">
          <div class="support-img">
            <Photo src="/fotos/warum-atelier.webp" alt="Das Malatelier Auszeit in Gronau von außen" />
          </div>
          <div class="support-body">
            <h3>Lokale Wertschöpfung in deiner Region</h3>
            <p>Dein Geld bleibt hier. Es fließt in Miete, Material und in den Fortbestand eines kleinen Ateliers mitten in Gronau.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="blk cta-blk">
    <div class="wrap">
      <div class="cta-box" data-animate="fade-up">
        <span class="eyebrow">Jetzt selbst erleben</span>
        <h2>Schau vorbei und mach dir ein eigenes Bild</h2>
        <p>Keine langen Erklärungen mehr. Komm einfach, mal drauf los und schau, was entsteht.</p>
        <a href="/#buchen" class="btn btn-terra cta-btn">Termin buchen</a>
      </div>
    </div>
  </section>

</MainLayout>

<style>
  /* ── HERO ── */
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  @media (min-width: 820px) {
    .hero-grid {
      grid-template-columns: 6fr 5fr;
    }
  }
  .hero-text h1 {
    font-size: clamp(2rem, 1.6rem + 2.2vw, 3.4rem);
    margin: .5rem 0 1rem;
    max-width: 22ch;
  }
  .lead {
    color: var(--ink-2);
    max-width: 52ch;
    margin-top: .8rem;
  }
  .hero-img {
    border-radius: var(--r-lg);
    overflow: hidden;
    min-height: clamp(280px, 35vw, 440px);
    box-shadow: var(--shadow-soft);
    position: relative;
  }
  :global(.hero-img img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── REVEAL SPLIT ── */
  .split-reveal {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1.5rem;
    align-items: stretch;
    max-width: 900px;
    margin: 0 auto;
  }
  @media (max-width: 640px) {
    .split-reveal {
      grid-template-columns: 1fr;
    }
  }
  .reveal-card {
    background: var(--card);
    border-radius: var(--r-lg);
    padding: 2rem;
    box-shadow: var(--shadow-card);
  }
  .reveal-card.hide {
    border-left: 3px solid var(--caramel);
  }
  .reveal-label {
    display: block;
    font-family: var(--font-sans);
    font-size: .72rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--terra-ink);
    margin-bottom: .8rem;
  }
  .reveal-card p {
    color: var(--ink-2);
  }
  .reveal-note {
    margin-top: .6rem;
    font-style: italic;
    color: var(--meta) !important;
    font-size: .9rem;
  }
  /* dezenter Trenner statt Pfeil-Icon */
  .reveal-divider {
    align-self: center;
    justify-self: center;
    width: 1px;
    height: 72px;
    background: linear-gradient(var(--caramel), transparent);
  }
  @media (max-width: 640px) {
    .reveal-divider {
      width: 48px;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--caramel), transparent);
      margin: .25rem auto;
    }
  }

  /* ── DARK EDITORIAL ── */
  .dark-editorial {
    background: var(--ink);
    color: var(--bg);
  }
  .dark-editorial .eyebrow--light {
    color: var(--caramel);
  }
  .dark-editorial h2 {
    color: var(--bg);
    font-size: clamp(1.6rem, 1.3rem + 1.5vw, 2.4rem);
    max-width: 34ch;
    margin-top: .4rem;
  }
  .section-intro {
    margin-bottom: 2.6rem;
  }
  .intro-note {
    color: rgba(247, 241, 234, .72);
    max-width: 48ch;
    margin-top: 1rem;
  }
  /* Kostenliste: editorial, mit Haarlinien statt Icons */
  .cost-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    column-gap: 3rem;
  }
  .cost-list li {
    font-family: var(--font-serif);
    font-size: clamp(1.05rem, 1rem + .3vw, 1.25rem);
    color: var(--bg);
    padding: 1.05rem 0;
    border-top: 1px solid rgba(247, 241, 234, .16);
  }

  /* ── ORGANISATION ── */
  .org-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  @media (min-width: 820px) {
    .org-grid {
      grid-template-columns: 5fr 6fr;
    }
  }
  .org-img {
    border-radius: var(--r-lg);
    overflow: hidden;
    min-height: clamp(280px, 36vw, 460px);
    box-shadow: var(--shadow-soft);
    position: relative;
  }
  :global(.org-img img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .org-text h2 {
    font-size: clamp(1.6rem, 1.3rem + 1.5vw, 2.4rem);
    margin: .5rem 0 1.2rem;
    max-width: 28ch;
  }

  /* ── LINE-LIST (icon-frei, Haarlinien) ── */
  .line-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .line-list li {
    color: var(--ink-2);
    padding: .8rem 0;
    border-bottom: 1px solid var(--hair);
  }
  .line-list li:first-child {
    border-top: 1px solid var(--hair);
  }

  /* ── TIMELINE CARDS ── */
  .section-head {
    margin-bottom: 3rem;
  }
  .section-head h2 {
    font-size: clamp(1.7rem, 1.4rem + 1.5vw, 2.6rem);
    max-width: 34ch;
    margin: .4rem 0 .6rem;
  }
  .timeline-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .tl-card {
    background: var(--card);
    border-radius: var(--r-lg);
    padding: 2rem 1.8rem;
    box-shadow: var(--shadow-card);
    border-top: 3px solid var(--hair);
  }
  .tl-card--mid {
    border-top-color: var(--caramel);
  }
  .tl-label {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--terra-ink);
    margin-bottom: 1rem;
  }
  .tl-card .line-list li {
    font-size: .95rem;
  }
  .tl-card .line-list li:first-child {
    border-top: 0;
    padding-top: 0;
  }
  .tl-card .line-list li:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  /* ── QUOTE SPLIT ── */
  .quote-split {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  @media (min-width: 820px) {
    .quote-split {
      grid-template-columns: 5fr 7fr;
    }
  }
  .quote-img {
    border-radius: var(--r-lg);
    overflow: hidden;
    min-height: clamp(300px, 38vw, 480px);
    box-shadow: var(--shadow-soft);
    position: relative;
  }
  :global(.quote-img img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }
  .big-quote {
    font-family: var(--font-serif);
    font-size: clamp(1.2rem, 1rem + 1vw, 1.6rem);
    font-style: italic;
    line-height: 1.5;
    color: var(--ink);
    border-left: 4px solid var(--caramel);
    padding-left: 1.4rem;
    margin: 0;
    text-wrap: pretty;
  }
  .big-quote cite {
    display: block;
    font-style: normal;
    font-family: var(--font-sans);
    font-size: .78rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--meta);
    margin-top: 1.2rem;
  }

  /* ── SUPPORT (Foto-Karten, icon-frei) ── */
  .support-blk {
    background: var(--surface);
  }
  .support-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2rem;
    margin-top: 1rem;
  }
  .support-item {
    background: var(--card);
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform .4s var(--ease-out), box-shadow .4s var(--ease-out);
  }
  .support-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 28px 54px -24px rgba(58, 45, 36, .38);
  }
  .support-img {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }
  :global(.support-img img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .5s var(--ease-out);
  }
  .support-item:hover :global(.support-img img) {
    transform: scale(1.04);
  }
  .support-body {
    padding: 1.6rem 1.8rem 1.9rem;
  }
  .support-item h3 {
    font-size: 1.15rem;
    margin-bottom: .5rem;
    max-width: 24ch;
  }
  .support-item p {
    color: var(--ink-2);
    font-size: .95rem;
  }

  /* ── FINAL CTA ── */
  .cta-box {
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }
  .cta-box h2 {
    font-size: clamp(1.7rem, 1.4rem + 1.5vw, 2.6rem);
    margin: .4rem 0 .8rem;
  }
  .cta-box p {
    color: var(--ink-2);
    margin-bottom: 1.8rem;
  }
  .cta-btn {
    display: inline-block;
    padding: .9rem 2.4rem;
    font-size: 1rem;
  }

  /* ── UTILITIES ── */
  .blk.soft { background: var(--surface); }

  :global(.photo-hover) { transition: transform .4s var(--ease-out); }
  :global(.photo-hover:hover) { transform: scale(1.015); }
</style>
