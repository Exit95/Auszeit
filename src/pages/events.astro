---
import MainLayout from '../layouts/MainLayout.astro';
import { content } from '../data/content';

const { events, pageMeta } = content;
---
<MainLayout title={pageMeta.events.title} description={pageMeta.events.description}>

  <!-- Page Hero -->
  <section class="events-hero">
    <div class="events-hero__inner">
      <h1 class="events-hero__title">{events.title}</h1>
      <p class="events-hero__subtitle">{events.subtitle}</p>
    </div>
  </section>

  <!-- Event Type Cards -->
  <section class="events-cards">
    <div class="events-cards__grid">
      {events.types.map((type) => (
        <article class="event-card" id={type.id}>
          <h2 class="event-card__title">{type.title}</h2>
          <p class="event-card__text">{type.text}</p>
          <ul class="event-card__features">
            {type.features.map((f) => (
              <li class="event-card__feature">{f}</li>
            ))}
          </ul>
          <button
            class="event-card__cta btn-anfragen"
            data-event={type.id}
            data-label={type.title}
          >
            Jetzt anfragen
          </button>
        </article>
      ))}
    </div>
  </section>

  <!-- Inquiry Form -->
  <section class="events-form-section" id="anfrage">
    <div class="events-form-container">
      <h2 class="events-form-title">Anfrage senden</h2>
      <p class="events-form-subtitle">
        Wähle oben deinen Anlass oder füll das Formular direkt aus. wir melden uns zeitnah bei dir.
      </p>

      <form id="eventsInquiryForm" class="inquiry-form">
        <div class="form-row">
          <div class="form-group">
            <label for="evtEventType">Anlass *</label>
            <select id="evtEventType" required>
              <option value="">Bitte wählen …</option>
              <option value="kindergeburtstag">Kindergeburtstag</option>
              <option value="jga">JGA (Junggesellenabschied)</option>
              <option value="stammtisch">Stammtisch / Gruppenabend</option>
              <option value="firmen_event">Firmen-Event / Teambuilding</option>
              <option value="privater_anlass">Privater Anlass</option>
              <option value="sonstiges">Sonstiges</option>
            </select>
          </div>
        </div>

        <div class="form-row form-row--2">
          <div class="form-group">
            <label for="evtName">Name *</label>
            <input type="text" id="evtName" required placeholder="Dein Name" />
          </div>
          <div class="form-group">
            <label for="evtEmail">E-Mail *</label>
            <input type="email" id="evtEmail" required placeholder="deine@email.de" />
          </div>
          <div class="form-group">
            <label for="evtPhone">Telefon *</label>
            <input type="tel" id="evtPhone" required placeholder="+49 …" />
          </div>
          <div class="form-group">
            <label for="evtDate">Wunschdatum</label>
            <input type="date" id="evtDate" />
          </div>
          <div class="form-group">
            <label for="evtParticipants">Anzahl Personen *</label>
            <input type="number" id="evtParticipants" min="1" max="50" value="1" required />
          </div>
        </div>

        <div class="form-group">
          <label for="evtMessage">Deine Wünsche / Anmerkungen</label>
          <textarea id="evtMessage" rows="4" placeholder="Erzähl uns von deinem Anlass …"></textarea>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn-submit">Anfrage absenden</button>
        </div>
      </form>

      <div id="eventsInquiryResult" class="inquiry-result hidden"></div>
    </div>
  </section>

</MainLayout>

<style>
  /* ── Hero ── */
  .events-hero {
    background: var(--bg-linen, #f5ede0);
    padding: 4rem 1.5rem 3rem;
    text-align: center;
  }
  .events-hero__inner {
    max-width: 720px;
    margin: 0 auto;
  }
  .events-hero__title {
    font-family: var(--font-serif, 'Lora', Georgia, serif);
    font-size: clamp(1.8rem, 5vw, 3rem);
    color: var(--brand-espresso, #3d2316);
    margin: 0 0 0.75rem;
    line-height: 1.2;
  }
  .events-hero__subtitle {
    font-family: var(--font-sans, 'Source Sans 3', sans-serif);
    font-size: 1.15rem;
    color: var(--color-sienna, #a0522d);
    margin: 0;
    line-height: 1.6;
  }

  /* ── Cards ── */
  .events-cards {
    padding: 3rem 1.5rem 4rem;
    background: var(--bg-cream, #fffaf4);
  }
  .events-cards__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.75rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .event-card {
    background: #fff;
    border: 1px solid var(--accent-caramel, #c8965a);
    border-radius: 16px;
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: box-shadow 0.2s;
  }
  .event-card:hover {
    box-shadow: 0 6px 24px rgba(61, 35, 22, 0.1);
  }

  .event-card__title {
    font-family: var(--font-serif, 'Lora', Georgia, serif);
    font-size: 1.35rem;
    color: var(--brand-espresso, #3d2316);
    margin: 0;
  }
  .event-card__text {
    font-family: var(--font-sans, 'Source Sans 3', sans-serif);
    font-size: 0.97rem;
    color: #4a3728;
    line-height: 1.65;
    margin: 0;
  }

  .event-card__features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .event-card__feature {
    font-family: var(--font-sans, 'Source Sans 3', sans-serif);
    font-size: 0.88rem;
    color: var(--color-sienna, #a0522d);
    padding-left: 1.2rem;
    position: relative;
  }
  .event-card__feature::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--accent-terra, #a0522d);
    font-weight: 700;
  }

  .event-card__cta {
    margin-top: auto;
    align-self: flex-start;
    padding: 0.6rem 1.5rem;
    border-radius: 999px;
    border: none;
    background: var(--accent-terra, #a0522d);
    color: #fff;
    font-family: var(--font-sans, 'Source Sans 3', sans-serif);
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }
  .event-card__cta:hover {
    background: var(--brand-espresso, #3d2316);
  }

  /* ── Form section ── */
  .events-form-section {
    padding: 4rem 1.5rem;
    background: var(--bg-paper, #fdf8f0);
  }
  .events-form-container {
    max-width: 760px;
    margin: 0 auto;
  }
  .events-form-title {
    font-family: var(--font-serif, 'Lora', Georgia, serif);
    font-size: 1.75rem;
    color: var(--brand-espresso, #3d2316);
    text-align: center;
    margin: 0 0 0.5rem;
  }
  .events-form-subtitle {
    font-family: var(--font-sans, 'Source Sans 3', sans-serif);
    font-size: 1rem;
    color: var(--color-sienna, #a0522d);
    text-align: center;
    margin: 0 auto 2rem;
    max-width: 540px;
    line-height: 1.6;
  }

  .inquiry-form {
    background: #fff;
    border: 1px solid var(--accent-caramel, #c8965a);
    border-radius: 16px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-row {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .form-row--2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 580px) {
    .form-row--2 {
      grid-template-columns: 1fr;
    }
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .form-group label {
    font-family: var(--font-sans, 'Source Sans 3', sans-serif);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--brand-espresso, #3d2316);
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 0.65rem 0.8rem;
    border: 1px solid #d9c9bc;
    border-radius: 8px;
    font-family: var(--font-sans, 'Source Sans 3', sans-serif);
    font-size: 0.95rem;
    color: #3d2316;
    background: #fff;
    transition: border-color 0.2s, box-shadow 0.2s;
    resize: vertical;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--accent-terra, #a0522d);
    box-shadow: 0 0 0 3px rgba(160, 82, 45, 0.12);
  }

  .form-actions {
    display: flex;
    justify-content: flex-end;
    margin-top: 0.5rem;
  }
  .btn-submit {
    padding: 0.75rem 2rem;
    border-radius: 999px;
    border: none;
    background: var(--accent-terra, #a0522d);
    color: #fff;
    font-family: var(--font-sans, 'Source Sans 3', sans-serif);
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s;
  }
  .btn-submit:hover {
    background: var(--brand-espresso, #3d2316);
  }
  .btn-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .inquiry-result {
    margin-top: 1.5rem;
    padding: 1.25rem;
    border-radius: 10px;
    text-align: center;
    font-family: var(--font-sans, 'Source Sans 3', sans-serif);
    font-weight: 600;
  }
  .inquiry-result.success {
    background: #e8f5e9;
    color: #2e7d32;
    border: 1px solid #a5d6a7;
  }
  .inquiry-result.error {
    background: #fbe9e7;
    color: #c62828;
    border: 1px solid #ef9a9a;
  }
  .hidden { display: none; }
</style>

<script>
  // Pre-fill form event type when a card CTA is clicked
  document.querySelectorAll<HTMLButtonElement>('.btn-anfragen').forEach((btn) => {
    btn.addEventListener('click', () => {
      const eventType = btn.dataset.event ?? '';
      const select = document.getElementById('evtEventType') as HTMLSelectElement | null;
      if (select) {
        select.value = eventType;
      }
      const formSection = document.getElementById('anfrage');
      formSection?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  // Set min date to today
  const dateInput = document.getElementById('evtDate') as HTMLInputElement | null;
  if (dateInput) {
    dateInput.setAttribute('min', new Date().toISOString().slice(0, 10));
  }

  // Form submission
  const form = document.getElementById('eventsInquiryForm') as HTMLFormElement | null;
  const resultDiv = document.getElementById('eventsInquiryResult');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]')!;
    const origText = submitBtn.textContent ?? 'Anfrage absenden';
    submitBtn.disabled = true;
    submitBtn.textContent = 'Wird gesendet …';

    try {
      const payload = {
        eventType: (document.getElementById('evtEventType') as HTMLSelectElement).value,
        name: (document.getElementById('evtName') as HTMLInputElement).value.trim(),
        email: (document.getElementById('evtEmail') as HTMLInputElement).value.trim(),
        phone: (document.getElementById('evtPhone') as HTMLInputElement).value.trim(),
        preferredDate: (document.getElementById('evtDate') as HTMLInputElement).value,
        participants: parseInt((document.getElementById('evtParticipants') as HTMLInputElement).value) || 1,
        message: (document.getElementById('evtMessage') as HTMLTextAreaElement).value.trim(),
      };

      const res = await fetch('/api/inquiries', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();

      if (resultDiv) {
        resultDiv.classList.remove('hidden', 'success', 'error');
        if (data.success) {
          resultDiv.classList.add('success');
          resultDiv.textContent = 'Vielen Dank! Deine Anfrage wurde gesendet. Wir melden uns zeitnah bei dir.';
          form.reset();
        } else {
          resultDiv.classList.add('error');
          resultDiv.textContent = data.message || 'Fehler beim Senden. Bitte versuche es erneut.';
        }
      }
    } catch {
      if (resultDiv) {
        resultDiv.classList.remove('hidden', 'success', 'error');
        resultDiv.classList.add('error');
        resultDiv.textContent = 'Verbindungsfehler. Bitte versuche es später erneut.';
      }
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = origText;
    }
  });
</script>
