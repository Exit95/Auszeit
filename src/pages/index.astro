---
// prerender disabled - Offerings.astro needs to load images from S3 at runtime
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../sections/Hero.astro';
import WasErwartet from '../sections/WasErwartet.astro';
import Offerings from '../sections/Offerings.astro';
import Process from '../sections/Process.astro';
import BookingCalendar from '../components/BookingCalendar.astro';
import Reviews from '../sections/Reviews.astro';
import Profil from '../sections/Profil.astro';
import Contact from '../sections/Contact.astro';

// SEO-optimierter Title und Description für lokale Suche
const seoTitle = "Keramik bemalen Gronau & Münsterland | Atelier Auszeit | Workshops & Kindergeburtstage";
const seoDescription = "Keramik selbst bemalen in Gronau (Westfalen) im Münsterland ✓ Kreative Workshops ✓ Kindergeburtstage ✓ JGA ✓ Erreichbar aus Münster, Steinfurt, Borken, Ahaus, Enschede. Jetzt Termin buchen!";
---

<MainLayout title={seoTitle} description={seoDescription}>
  <Hero />
  <WasErwartet />
  <Offerings />
  <Process />
  <BookingCalendar title="Termin buchen" />
  <Reviews />
  <Profil />
  <Contact />
</MainLayout>
