---
// prerender disabled - SSR required for booking calendar
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../sections/Hero.astro';
import WasErwartet from '../sections/WasErwartet.astro';
import Process from '../sections/Process.astro';
import Gastgeberin from '../sections/Gastgeberin.astro';
import AngebotPreise from '../sections/AngebotPreise.astro';
import GalerieTeaser from '../sections/GalerieTeaser.astro';
import Band from '../sections/Band.astro';
import BookingCalendar from '../components/BookingCalendar.astro';
import Reviews from '../sections/Reviews.astro';
import FAQ from '../sections/FAQ.astro';
import FinalCTA from '../sections/FinalCTA.astro';

// SEO Title und Description fuer lokale Suche
const seoTitle = "Keramik bemalen in Gronau & Münsterland | Malatelier Auszeit";
const seoDescription = "Keramik selbst bemalen in Gronau (Westfalen) im Münsterland. Kreative Workshops, Kindergeburtstage und JGA, gut erreichbar aus Münster, Steinfurt, Borken, Ahaus und Enschede. Jetzt Termin buchen.";
---

<MainLayout title={seoTitle} description={seoDescription}>
  <Hero />
  <WasErwartet />
  <Process />
  <Gastgeberin />
  <AngebotPreise />
  <GalerieTeaser />
  <Band />
  <BookingCalendar />
  <Reviews />
  <FAQ />
  <FinalCTA />
</MainLayout>
