---
export const prerender = false;
import BrennLayout from '../../../../layouts/BrennLayout.astro';
---

<BrennLayout title="Abgeholt (Archiv)" activeNav="abgeholt">
  <div class="brenn-card">
    <h2>Abgeholte Aufträge</h2>

    <div class="brenn-filters">
      <input type="search" class="brenn-input" id="archiv-search" placeholder="Referenz-ID oder Kundenname…" />
      <input type="date" class="brenn-input" id="archiv-from" title="Ab Datum" style="width:auto" />
      <input type="date" class="brenn-input" id="archiv-to" title="Bis Datum" style="width:auto" />
    </div>

    <div id="archiv-content" class="brenn-loading">Wird geladen…</div>
    <div id="archiv-pagination" class="brenn-pagination"></div>
  </div>
</BrennLayout>

<script is:inline>
  let archivPage = 1;
  let archivTimeout;

  document.getElementById('archiv-search').addEventListener('input', () => {
    clearTimeout(archivTimeout);
    archivTimeout = setTimeout(() => { archivPage = 1; loadArchiv(); }, 300);
  });
  ['archiv-from', 'archiv-to'].forEach(id => {
    document.getElementById(id).addEventListener('change', () => { archivPage = 1; loadArchiv(); });
  });

  async function loadArchiv() {
    const q = document.getElementById('archiv-search').value.trim();
    const from = document.getElementById('archiv-from').value;
    const to = document.getElementById('archiv-to').value;

    const params = new URLSearchParams({ status: 'ABGEHOLT', page: archivPage, limit: 25 });
    if (q) params.set('q', q);
    if (from) params.set('from', from);
    if (to) params.set('to', to);

    try {
      const data = await brennFetch('/api/admin/brenn/orders?' + params);
      renderArchiv(data.data);
    } catch(e) {
      document.getElementById('archiv-content').innerHTML = '<p style="color:#dc2626">Fehler beim Laden</p>';
    }
  }

  function renderArchiv(data) {
    const el = document.getElementById('archiv-content');
    if (!data.orders.length) {
      el.innerHTML = '<div class="brenn-empty-state"><p>Keine abgeholten Aufträge gefunden</p></div>';
      document.getElementById('archiv-pagination').innerHTML = '';
      return;
    }

    let html = '<div class="brenn-table-wrapper"><table class="brenn-table brenn-table--responsive"><thead><tr>' +
      '<th>Referenz</th><th>Kunde</th><th>Besuchsdatum</th><th>Werkstücke</th><th></th></tr></thead><tbody>';

    data.orders.forEach(o => {
      const itemsSummary = (o.items || []).map(i => i.quantity + '× ' + i.item_type).join(', ') || '-';
      html += '<tr>' +
        '<td data-label="Referenz"><a href="/admin/brenn/auftraege/' + o.id + '/">' + escapeHtml(o.reference_code) + '</a></td>' +
        '<td data-label="Kunde">' + escapeHtml(o.last_name) + ', ' + escapeHtml(o.first_name) + '</td>' +
        '<td data-label="Besuchsdatum">' + formatDate(o.visit_date) + '</td>' +
        '<td data-label="Werkstücke" style="font-size:0.8125rem">' + escapeHtml(itemsSummary) + '</td>' +
        '<td><a href="/admin/brenn/auftraege/' + o.id + '/" class="brenn-btn brenn-btn--secondary brenn-btn--small">Details</a></td>' +
        '</tr>';
    });
    html += '</tbody></table></div>';
    el.innerHTML = html;

    const p = data.pagination;
    const pagEl = document.getElementById('archiv-pagination');
    if (p.pages <= 1) { pagEl.innerHTML = ''; return; }
    let pagHtml = '<button ' + (p.page <= 1 ? 'disabled' : '') + ' onclick="archivGoPage(' + (p.page-1) + ')">‹</button>';
    for (let i = 1; i <= Math.min(p.pages, 10); i++) {
      pagHtml += '<button class="' + (i === p.page ? 'active' : '') + '" onclick="archivGoPage(' + i + ')">' + i + '</button>';
    }
    pagHtml += '<button ' + (p.page >= p.pages ? 'disabled' : '') + ' onclick="archivGoPage(' + (p.page+1) + ')">›</button>';
    pagEl.innerHTML = pagHtml;
  }

  function archivGoPage(p) { archivPage = p; loadArchiv(); }

  loadArchiv();
</script>
