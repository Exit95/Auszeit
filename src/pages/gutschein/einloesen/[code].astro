---
import MainLayout from "../../../layouts/MainLayout.astro";
import Brush from "../../../components/Brush.astro";
import { getVoucherByCode, formatAmount } from "../../../lib/voucher-storage";
export const prerender = false;

const { code } = Astro.params;
const voucher = code ? await getVoucherByCode(code) : null;

const redeemDate = voucher?.redeemedAt
  ? new Date(voucher.redeemedAt).toLocaleDateString('de-DE', {
      day: '2-digit', month: '2-digit', year: 'numeric',
      hour: '2-digit', minute: '2-digit',
    })
  : '';
---

<MainLayout title="Gutschein einlösen | Atelier Auszeit" description="Gutschein-Status prüfen und einlösen im Atelier Auszeit in Gronau.">

  <div class="wrap">
    <div class="pagehead center">
      <span class="eyebrow">Gutschein einlösen</span>
      <h1>Atelier Auszeit</h1>
      <Brush />
    </div>

    <div class="check-card">

      {!voucher ? (
        <div class="check-status check-status--invalid">
          <div class="check-icon check-icon--invalid" aria-hidden="true"></div>
          <h2>Gutschein nicht gefunden</h2>
          <p>Dieser Gutschein-Code ist ungültig oder existiert nicht.</p>
          <a href="/" class="btn btn-ghost check-back">Zur Startseite</a>
        </div>

      ) : voucher.status === 'active' ? (
        <div class="check-status check-status--valid">
          <div class="check-icon check-icon--valid" aria-hidden="true"></div>
          <h2>Gutschein gültig</h2>
          <div class="check-amount">{formatAmount(voucher.amount)}</div>
          <span class="check-code">{voucher.code}</span>
          <p class="check-hint">Bitte zeige diesen Bildschirm im Atelier vor.</p>
          <a href="/" class="btn btn-terra check-back">Zur Startseite</a>
        </div>

      ) : voucher.status === 'redeemed' ? (
        <div class="check-status check-status--redeemed">
          <div class="check-icon check-icon--redeemed" aria-hidden="true"></div>
          <h2>Bereits eingelöst</h2>
          <div class="check-amount check-amount--muted">{formatAmount(voucher.amount)}</div>
          <span class="check-code">{voucher.code}</span>
          <p class="check-hint">Eingelöst am {redeemDate}</p>
          <a href="/" class="btn btn-ghost check-back">Zur Startseite</a>
        </div>

      ) : (
        <div class="check-status check-status--expired">
          <div class="check-icon check-icon--expired" aria-hidden="true"></div>
          <h2>Gutschein abgelaufen</h2>
          <span class="check-code">{voucher.code}</span>
          <a href="/" class="btn btn-ghost check-back">Zur Startseite</a>
        </div>
      )}

    </div>
  </div>

</MainLayout>

<style>
  /* ── Pagehead ────────────────────────────────────────────── */
  .pagehead {
    padding: clamp(2.5rem, 5vw, 4rem) 0 2rem;
  }

  .pagehead.center {
    text-align: center;
  }

  .pagehead.center .brush {
    margin-inline: auto;
  }

  .pagehead h1 {
    font-size: clamp(2.2rem, 4.5vw, 3.4rem);
    margin: 0.6rem 0 0;
  }

  /* ── Card ────────────────────────────────────────────────── */
  .check-card {
    background: #fff;
    border: 1px solid var(--hair, #E4D8CB);
    border-radius: var(--r-xl, 20px);
    padding: clamp(2rem, 5vw, 3rem);
    max-width: 480px;
    margin: 0 auto clamp(3rem, 7vw, 6rem);
    box-shadow: 0 20px 50px -30px rgba(58, 45, 36, 0.2);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.9rem;
  }

  /* ── Status Variants ─────────────────────────────────────── */
  .check-status {
    display: contents;
  }

  /* Icon circle */
  .check-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
    margin-bottom: 0.25rem;
  }

  /* Valid: green checkmark */
  .check-icon--valid {
    background: rgba(74, 124, 89, 0.12);
    border: 2px solid rgba(74, 124, 89, 0.3);
  }

  .check-icon--valid::after {
    content: '';
    width: 26px;
    height: 14px;
    border-left: 3px solid #4A7C59;
    border-bottom: 3px solid #4A7C59;
    transform: rotate(-45deg) translateY(-4px);
    display: block;
  }

  /* Invalid: red X */
  .check-icon--invalid {
    background: rgba(185, 74, 72, 0.1);
    border: 2px solid rgba(185, 74, 72, 0.25);
  }

  .check-icon--invalid::before,
  .check-icon--invalid::after {
    content: '';
    position: absolute;
    width: 22px;
    height: 3px;
    background: #B94A48;
    border-radius: 2px;
  }

  .check-icon--invalid::before { transform: rotate(45deg); }
  .check-icon--invalid::after  { transform: rotate(-45deg); }

  /* Redeemed: neutral */
  .check-icon--redeemed {
    background: rgba(148, 129, 111, 0.1);
    border: 2px solid rgba(148, 129, 111, 0.25);
  }

  .check-icon--redeemed::after {
    content: '';
    width: 22px;
    height: 3px;
    background: #94816F;
    border-radius: 2px;
    display: block;
  }

  /* Expired */
  .check-icon--expired {
    background: rgba(148, 129, 111, 0.1);
    border: 2px solid rgba(148, 129, 111, 0.25);
  }

  .check-icon--expired::before,
  .check-icon--expired::after {
    content: '';
    position: absolute;
    background: #94816F;
    border-radius: 2px;
  }

  .check-icon--expired::before {
    width: 3px;
    height: 20px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .check-icon--expired::after {
    width: 3px;
    height: 8px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, calc(-50% + 10px));
  }

  /* ── Text ────────────────────────────────────────────────── */
  .check-card h2 {
    font-size: 1.5rem;
    color: var(--ink, #3A2D24);
    margin: 0;
    font-weight: 500;
  }

  .check-amount {
    font-family: var(--font-serif, 'Fraunces', Georgia, serif);
    font-size: clamp(2rem, 8vw, 2.8rem);
    font-weight: 600;
    color: var(--ink, #3A2D24);
    line-height: 1;
  }

  .check-amount--muted {
    opacity: 0.5;
  }

  .check-code {
    font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--ink-2, #5D4A3C);
    background: rgba(242, 235, 229, 0.6);
    padding: 0.55rem 1.1rem;
    border-radius: 10px;
    border: 1px dashed rgba(207, 168, 116, 0.4);
    display: inline-block;
  }

  .check-hint {
    font-size: 0.875rem;
    color: var(--meta, #94816F);
    line-height: 1.6;
    margin: 0;
  }

  .check-back {
    margin-top: 0.5rem;
  }
</style>
