---
import WhatsAppFloat from "../components/WhatsAppFloat.astro";
import MobileMenu from "../components/MobileMenu.astro";
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const {
  title,
  description,
  ogImage = "/og-image.jpg",
  canonicalUrl
} = Astro.props;

const siteUrl = "https://keramik-auszeit.de";
const currentUrl = canonicalUrl || Astro.url.pathname;
const fullUrl = new URL(currentUrl, siteUrl).href;
const fullOgImage = new URL(ogImage, siteUrl).href;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Font Preloads (self-hosted, no CDN) -->
    <link rel="preload" href="/fonts/Fraunces-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/SourceSans3-Regular.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Performance: hero image -->
    <link rel="preload" href="/hero-banner.webp" as="image" type="image/webp" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon-64.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Irena Woschkowiak" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="language" content="German" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#D96C4A" />

    <!-- Lokale SEO Meta Tags -->
    <meta name="geo.region" content="DE-NW" />
    <meta name="geo.placename" content="Gronau (Westfalen)" />
    <meta name="geo.position" content="52.2079;7.0391" />
    <meta name="ICBM" content="52.2079, 7.0391" />
    <meta name="city" content="Gronau" />
    <meta name="country" content="Germany" />
    <meta name="zipcode" content="48599" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={fullUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Malatelier Auszeit - Keramik Malatelier in Gronau im Munsterland" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Malatelier Auszeit | Malatelier in Gronau" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={fullUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />
    <meta name="twitter:image:alt" content="Malatelier Auszeit - Keramik Malatelier in Gronau im Munsterland" />

    <!-- Canonical URL -->
    <link rel="canonical" href={fullUrl} />

    <!-- LocalBusiness JSON-LD -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "LocalBusiness",
            "@id": "https://keramik-auszeit.de/#business",
            "name": "Malatelier Auszeit",
            "alternateName": ["Malatelier Auszeit", "Auszeit Keramik", "Keramik Gronau"],
            "description": "Keramik selbst bemalen in Gronau (Westfalen) im Munsterland. Kreative Workshops, Kindergeburtstage, JGA und individuelle Termine. Grosse Auswahl: Tassen, Teller, Spardosen. Perfekt erreichbar aus Munster, Steinfurt, Borken, Ahaus, Ochtrup und Enschede.",
            "url": "https://keramik-auszeit.de",
            "telephone": "+49 176 34255005",
            "email": "atelier@keramik-auszeit.de",
            "image": [
              "https://keramik-auszeit.de/og-image.jpg",
              "https://keramik-auszeit.de/tasse.webp",
              "https://keramik-auszeit.de/teller.webp"
            ],
            "logo": "https://keramik-auszeit.de/logo-header-3x.png",
            "priceRange": "EUR",
            "openingHours": ["Tu-Su 10:00-18:00"],
            "openingHoursSpecification": [
              {
                "@type": "OpeningHoursSpecification",
                "dayOfWeek": ["Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
                "opens": "10:00",
                "closes": "18:00"
              }
            ],
            "address": {
              "@type": "PostalAddress",
              "streetAddress": "Feldstiege 6a",
              "addressLocality": "Gronau (Westfalen)",
              "addressRegion": "Nordrhein-Westfalen",
              "postalCode": "48599",
              "addressCountry": "DE"
            },
            "geo": {
              "@type": "GeoCoordinates",
              "latitude": 52.2079,
              "longitude": 7.0391
            },
            "founder": {
              "@type": "Person",
              "name": "Irena Woschkowiak",
              "jobTitle": "Inhaberin"
            },
            "sameAs": [
              "https://www.instagram.com/keramik_auszeit/"
            ],
            "aggregateRating": {
              "@type": "AggregateRating",
              "ratingValue": "5.0",
              "reviewCount": "23",
              "bestRating": "5",
              "worstRating": "1"
            }
          },
          {
            "@type": "WebSite",
            "@id": "https://keramik-auszeit.de/#website",
            "url": "https://keramik-auszeit.de",
            "name": "Malatelier Auszeit | Keramik Malatelier im Munsterland",
            "publisher": {"@id": "https://keramik-auszeit.de/#business"},
            "inLanguage": "de-DE"
          }
        ]
      }
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Zum Hauptinhalt springen</a>

    <!-- ── Header / Nav ───────────────────────── -->
    <header>
      <div class="nav">
        <a class="brand" href="/">
          <img
            src="/logo-header.png"
            srcset="/logo-header.png 1x, /logo-header-3x.png 2x"
            alt="Malatelier Auszeit Logo"
            width="46"
            height="46"
          />
          <span class="brand__txt">
            <b>Auszeit</b>
            <small>Malatelier · Gronau</small>
          </span>
        </a>

        <ul>
          <li class="hide-m"><a class="lnk" href="/#keramik-preise">Keramik bemalen</a></li>
          <li class="hide-m"><a class="lnk" href="/workshops">Workshops</a></li>
          <li class="hide-m"><a class="lnk" href="/events">Anlasse</a></li>
          <li class="hide-m"><a class="lnk" href="/galerie">Galerie</a></li>
          <li class="hide-m"><a class="lnk" href="/gutscheine">Gutscheine</a></li>
          <li><a class="btn btn-terra" href="/#termin-buchen">Termin buchen</a></li>
        </ul>

        <MobileMenu />
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <script src="../scripts/scroll-animations.js"></script>
    <script src="../scripts/modal.js"></script>

    <WhatsAppFloat />

    <!-- ── Footer ─────────────────────────────── -->
    <footer>
      <div class="wrap">
        <div>
          <div class="brand-f">
            <img src="/logo-header-3x.png" alt="Malatelier Auszeit Logo" width="50" height="50" />
            <b>Auszeit</b>
          </div>
          <p style="max-width:26ch">Dein Malatelier in Gronau. Keramik bemalen, durchatmen, gluecklich nach Hause gehen.</p>
        </div>

        <div>
          <h4>Komm vorbei</h4>
          <ul>
            <li>Feldstiege 6a</li>
            <li>48599 Gronau (Westf.)</li>
            <li style="margin-top:.4rem"><a href="tel:+4917634255005">+49 176 34255005</a></li>
            <li><a href="mailto:atelier@keramik-auszeit.de">atelier@keramik-auszeit.de</a></li>
          </ul>
        </div>

        <div>
          <h4>Offnungszeiten</h4>
          <ul>
            <li>Dienstag bis Sonntag</li>
            <li>10:00 bis 18:00 Uhr</li>
            <li style="color:#9c8a7c;margin-top:.4rem">Montag Ruhetag</li>
          </ul>
        </div>

        <div>
          <h4>Mehr</h4>
          <ul>
            <li><a href="/galerie">Galerie</a></li>
            <li><a href="/workshops">Workshops</a></li>
            <li><a href="/gutscheine">Gutscheine</a></li>
            <li><a href="https://www.instagram.com/keramik_auszeit/" target="_blank" rel="noopener noreferrer">Instagram</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bar">
        &copy; {new Date().getFullYear()} Malatelier Auszeit &middot; Irena Woschkowiak
        &middot; <a href="/impressum">Impressum</a>
        &middot; <a href="/datenschutz">Datenschutz</a>
      </div>
    </footer>

    <!-- ── Sticky Mobile CTA Bar ───────────────── -->
    <div class="mobile-cta-bar" id="mobile-cta-bar">
      <a href="tel:+4917634255005" class="mobile-cta-bar__phone" aria-label="Anrufen">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        Anrufen
      </a>
      <a href="/#termin-buchen" class="mobile-cta-bar__book">Jetzt Termin buchen</a>
    </div>

    <script is:inline>
    (function() {
      var bar = document.getElementById('mobile-cta-bar');
      var booking = document.getElementById('termin-buchen');
      if (!bar || !booking) return;
      var io = new IntersectionObserver(function(entries) {
        bar.style.transform = entries[0].isIntersecting ? 'translateY(100%)' : 'translateY(0)';
        bar.style.transition = 'transform 0.3s ease';
      }, { threshold: 0.1 });
      io.observe(booking);
    })();
    </script>
  </body>
</html>

<style is:global>
  /* Deutsche Silbentrennung */
  html {
    -webkit-hyphens: auto;
    hyphens: auto;
    word-break: break-word;
    overflow-wrap: break-word;
  }

  /* Kein horizontaler Scroll */
  body {
    overflow-x: hidden;
  }

  /* ── Sticky Mobile CTA Bar ────────────────── */
  .mobile-cta-bar {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 48;
    padding: 8px 12px;
    padding-bottom: max(8px, env(safe-area-inset-bottom));
    background: #fff;
    border-top: 1px solid var(--hair);
    box-shadow: 0 -2px 12px rgba(58, 45, 36, 0.1);
    gap: 8px;
  }

  @media (max-width: 768px) {
    .mobile-cta-bar { display: flex; }
    body { padding-bottom: 70px; }
  }

  .mobile-cta-bar__phone {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 12px 16px;
    background: var(--surface);
    color: var(--ink);
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    white-space: nowrap;
    min-height: 44px;
  }

  .mobile-cta-bar__book {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px 20px;
    background: var(--terra);
    color: #fff;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
    white-space: nowrap;
    min-height: 44px;
  }

  .mobile-cta-bar__book:hover {
    background: var(--terra-h);
  }
</style>

<style>
  /* ── Header ───────────────────────────────── */
  header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: rgba(247, 241, 234, 0.88);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 1px 0 rgba(212, 196, 178, 0.5);
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0.7rem var(--gutter);
    max-width: var(--maxw);
    margin: 0 auto;
  }

  /* ── Brand ────────────────────────────────── */
  .brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .brand img {
    height: 46px;
    width: auto;
    display: block;
  }

  .brand__txt {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .brand__txt b {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 500;
    font-size: 1.5rem;
    color: var(--ink);
  }

  .brand__txt small {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--meta);
    margin-top: 0.25rem;
  }

  /* ── Nav links ────────────────────────────── */
  .nav ul {
    list-style: none;
    display: flex;
    gap: 1.4rem;
    margin-left: auto;
    align-items: center;
    padding: 0;
  }

  .nav a.lnk {
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--ink-2);
    padding-bottom: 3px;
    border-bottom: 2px solid transparent;
    transition: color 180ms, border-color 180ms;
    white-space: nowrap;
  }

  .nav a.lnk:hover {
    color: var(--ink);
    border-color: var(--terra);
  }

  .nav .btn {
    padding: 0.6rem 1.3rem;
    font-size: 0.92rem;
    white-space: nowrap;
  }

  /* Hide nav text links at narrow widths; burger takes over */
  @media (max-width: 880px) {
    .nav ul li.hide-m {
      display: none;
    }
  }

  /* ── Footer ───────────────────────────────── */
  footer {
    background: #2E241D;
    color: #CDBaa9;
    font-size: 0.9rem;
    margin-top: var(--section);
  }

  footer .wrap {
    padding: 3.5rem var(--gutter) 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
  }

  footer h4 {
    font-family: var(--font-serif);
    color: #F7F1EA;
    font-weight: 500;
    font-size: 1.05rem;
    margin-bottom: 0.8rem;
  }

  footer a {
    color: #CDBaa9;
    text-decoration: none;
  }

  footer a:hover {
    color: #fff;
  }

  .brand-f {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.6rem;
  }

  .brand-f img {
    height: 50px;
    width: auto;
  }

  .brand-f b {
    font-family: var(--font-serif);
    font-style: italic;
    color: #F7F1EA;
    font-size: 1.6rem;
  }

  footer ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 0;
    margin: 0;
  }

  footer p {
    line-height: 1.6;
    color: #CDBaa9;
    margin: 0;
  }

  .footer-bar {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    text-align: center;
    padding: 1.2rem;
    font-size: 0.8rem;
    color: #9c8a7c;
  }

  .footer-bar a {
    color: #9c8a7c;
  }

  .footer-bar a:hover {
    color: #fff;
  }
</style>
