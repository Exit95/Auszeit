---
import Modal from "../components/Modal.astro";
import WhatsAppFloat from "../components/WhatsAppFloat.astro";

interface Props {
  title: string;
  description: string;
  keywords?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

// Erweiterte lokale Keywords inkl. häufiger Schreibfehler und Nachbarorte
const defaultKeywords = [
  // Hauptkeywords
  "Keramik bemalen", "Keramik Malatelier", "Keramik Workshop",
  // Ort Gronau
  "Gronau", "Gronau Westfalen", "48599 Gronau",
  // Nachbarorte im Umkreis
  "Epe", "Ochtrup", "Ahaus", "Enschede", "Losser", "Nordhorn", "Bad Bentheim", "Schüttorf", "Metelen", "Heek", "Legden",
  // Keramik-Variationen
  "Keramik selbst bemalen", "Keramik gestalten", "Keramik Kunst", "Keramikmalerei", "Töpfern",
  // Angebote
  "Kindergeburtstag Keramik", "Kreativ Workshop", "Malen mit Kindern", "JGA Keramik", "Junggesellinnenabschied",
  // Produkte
  "Tassen bemalen", "Teller bemalen", "Spardose bemalen", "Geschenke selbst gestalten",
  // Häufige Schreibfehler (SEO-Trick)
  "Keramick", "Keramic", "Keramiek", "Ceramik",
  "Woschkowiak", "Woshkowiak", "Woschkowiack",
  "Gronau Keramik", "Keramik Gronau",
  // Emotionale Keywords
  "kreativ entspannen", "Auszeit vom Alltag", "handgemacht", "individuelle Geschenke"
].join(", ");

const {
  title,
  description,
  keywords = defaultKeywords,
  ogImage = "/og-image.jpg",
  canonicalUrl
} = Astro.props;

const siteUrl = "https://keramik-auszeit.de";
const currentUrl = canonicalUrl || Astro.url.pathname;
const fullUrl = new URL(currentUrl, siteUrl).href;
const fullOgImage = new URL(ogImage, siteUrl).href;
