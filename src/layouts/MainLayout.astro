    <script>
      // Canvas Menu - Fullscreen Overlay
      const navToggle = document.getElementById('nav-toggle');
      const canvasMenu = document.getElementById('canvas-menu');
      const canvasClose = document.getElementById('canvas-close');

      function openMenu() {
        canvasMenu?.classList.add('is-open');
        canvasMenu?.setAttribute('aria-hidden', 'false');
        navToggle?.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }

      function closeMenu() {
        canvasMenu?.classList.remove('is-open');
        canvasMenu?.setAttribute('aria-hidden', 'true');
        navToggle?.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }

      navToggle?.addEventListener('click', openMenu);
      canvasClose?.addEventListener('click', closeMenu);

      // Links schließen das Menü
      canvasMenu?.querySelectorAll('.canvas-menu__link').forEach(link => {
        link.addEventListener('click', closeMenu);
      });

      // Escape schließt das Menü
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && canvasMenu?.classList.contains('is-open')) {
          closeMenu();
        }
      });
    </script>
