    <meta name="city" content="Gronau" />
    <meta name="country" content="Germany" />
    <meta name="zipcode" content="48599" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={fullUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Atelier Auszeit - Keramik Malatelier in Gronau" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Atelier Auszeit Keramik Malatelier Gronau" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={fullUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />
    <meta name="twitter:image:alt" content="Atelier Auszeit - Keramik Malatelier in Gronau" />

    <!-- Canonical URL -->
    <link rel="canonical" href={fullUrl} />

