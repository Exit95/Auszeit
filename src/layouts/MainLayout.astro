---
import Modal from "../components/Modal.astro";

interface Props {
  title: string;
  description: string;
  keywords?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

// Erweiterte lokale Keywords inkl. häufiger Schreibfehler und Nachbarorte
const defaultKeywords = [
  // Hauptkeywords
  "Keramik bemalen", "Keramik Malatelier", "Keramik Workshop",
  // Ort Gronau
  "Gronau", "Gronau Westfalen", "48599 Gronau",
  // Nachbarorte im Umkreis
  "Epe", "Ochtrup", "Ahaus", "Enschede", "Losser", "Nordhorn", "Bad Bentheim", "Schüttorf", "Metelen", "Heek", "Legden",
  // Keramik-Variationen
  "Keramik selbst bemalen", "Keramik gestalten", "Keramik Kunst", "Keramikmalerei", "Töpfern",
  // Angebote
  "Kindergeburtstag Keramik", "Kreativ Workshop", "Malen mit Kindern", "JGA Keramik", "Junggesellinnenabschied",
  // Produkte
  "Tassen bemalen", "Teller bemalen", "Spardose bemalen", "Geschenke selbst gestalten",
  // Häufige Schreibfehler (SEO-Trick)
  "Keramick", "Keramic", "Keramiek", "Ceramik",
  "Woschkowiak", "Woshkowiak", "Woschkowiack",
  "Gronau Keramik", "Keramik Gronau",
  // Emotionale Keywords
  "kreativ entspannen", "Auszeit vom Alltag", "handgemacht", "individuelle Geschenke"
].join(", ");

const {
  title,
  description,
  keywords = defaultKeywords,
  ogImage = "/og-image.jpg",
  canonicalUrl
} = Astro.props;

const siteUrl = "https://keramik-auszeit.de";
const currentUrl = canonicalUrl || Astro.url.pathname;
const fullUrl = new URL(currentUrl, siteUrl).href;
const fullOgImage = new URL(ogImage, siteUrl).href;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Performance: DNS Prefetch & Preconnect -->
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link rel="dns-prefetch" href="https://www.google.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Performance: Preload kritische Ressourcen -->
    <link rel="preload" href="/favicon.svg" as="image" type="image/svg+xml" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Irena Woschkowiak" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="language" content="German" />
    <meta name="revisit-after" content="3 days" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#B1735C" />

    <!-- Lokale SEO Meta Tags -->
    <meta name="geo.region" content="DE-NW" />
    <meta name="geo.placename" content="Gronau (Westfalen)" />
