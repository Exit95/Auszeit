  <script is:inline>
  (function() {
    var bar = document.getElementById('mobile-cta-bar');
    var booking = document.getElementById('termin-buchen');
    if (!bar || !booking) return;
    var io = new IntersectionObserver(function(entries) {
      bar.style.transform = entries[0].isIntersecting ? 'translateY(100%)' : 'translateY(0)';
      bar.style.transition = 'transform 0.3s ease';
    }, { threshold: 0.1 });
    io.observe(booking);
  })();
