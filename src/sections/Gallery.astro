---
// Galerie-Section: Lädt Bilder aus S3 und zeigt sie in einem Masonry-Grid mit Lightbox
---

<section id="galerie" class="galerie" style="scroll-margin-top: 60px;">
  <div class="galerie__head">
    <span class="galerie__overline">Galerie</span>
    <h2 class="galerie__title">Unsere Arbeiten</h2>
    <p class="galerie__sub">Jedes Stück ist ein Unikat — lass dich inspirieren</p>
    <div class="galerie__filter" id="galerie-filter" role="tablist">
      <button class="gf-btn active" data-cat="all" role="tab" aria-selected="true">Alle</button>
    </div>
  </div>

  <div class="galerie__body">
    <div id="galerie-loading" class="galerie__loading">
      <div class="galerie__loading-dots">
        <span></span><span></span><span></span>
      </div>
      <span>Galerie wird geladen</span>
    </div>

    <div id="galerie-empty-all" class="galerie__empty hidden">
      <div class="galerie__empty-icon">
        <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="2"></rect>
          <circle cx="8.5" cy="8.5" r="1.5"></circle>
          <polyline points="21 15 16 10 5 21"></polyline>
        </svg>
      </div>
      <h3 class="galerie__empty-title">Galerie ist in Arbeit</h3>
      <p class="galerie__empty-text">Bald zeigen wir dir hier unsere Keramiken. Schau gerne bald wieder vorbei!</p>
    </div>

    <div id="galerie-empty-cat" class="galerie__empty hidden">
      <p class="galerie__empty-text">Noch keine Bilder in dieser Kategorie.</p>
    </div>

    <div id="galerie-grid" class="galerie__masonry hidden"></div>

    <div id="galerie-more-wrap" class="galerie__more-wrap hidden">
      <button id="galerie-more-btn" class="galerie__more-btn" type="button">
        Mehr anzeigen
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>
    </div>
  </div>

  <!-- Lightbox -->
  <div id="glb" class="glb hidden" role="dialog" aria-modal="true">
    <div class="glb__bg" id="glb-bg"></div>
    <div class="glb__ui">
      <button class="glb__close" id="glb-close" aria-label="Schließen">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      <button class="glb__arrow glb__arrow--l" id="glb-prev" aria-label="Zurück">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <div class="glb__stage">
        <img id="glb-img" class="glb__img" src="" alt="Galerie">
      </div>
      <button class="glb__arrow glb__arrow--r" id="glb-next" aria-label="Weiter">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
      <div class="glb__count" id="glb-count">1 / 1</div>
    </div>
  </div>
</section>

<style>
  .galerie {
    padding: var(--space-12) var(--gutter);
    background-color: var(--color-background);
  }

  .galerie__head {
    text-align: center;
    margin-bottom: var(--space-8);
  }

  .galerie__overline {
    display: block;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.75rem;
    color: var(--color-terracotta);
    font-weight: 600;
    margin-bottom: var(--space-2);
  }

  .galerie__title {
    font-family: var(--font-serif);
    color: var(--color-clay-brown);
    font-size: 2.5rem;
    margin-bottom: var(--space-2);
  }

  .galerie__sub {
    color: var(--color-text-secondary);
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-6);
  }

  .galerie__filter {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2);
  }

  :global(.gf-btn) {
    padding: var(--space-2) var(--space-4);
    border: 2px solid var(--color-warm-beige);
    border-radius: 999px;
    background: transparent;
    color: var(--color-clay-brown);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: var(--font-sans);
  }

  :global(.gf-btn:hover) {
    border-color: var(--color-terracotta);
    color: var(--color-terracotta);
  }

  :global(.gf-btn.active) {
    background: var(--color-terracotta);
    border-color: var(--color-terracotta);
    color: white;
  }

  .galerie__body {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .galerie__loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-10);
    color: var(--color-text-secondary);
  }

  .galerie__loading-dots {
    display: flex;
    gap: 6px;
  }

  .galerie__loading-dots span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-terracotta);
    animation: dotPulse 1.2s infinite ease-in-out;
  }

  .galerie__loading-dots span:nth-child(2) { animation-delay: 0.15s; }
  .galerie__loading-dots span:nth-child(3) { animation-delay: 0.3s; }

  @keyframes dotPulse {
    0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
    40% { opacity: 1; transform: scale(1); }
  }

  .galerie__empty {
    text-align: center;
    padding: var(--space-10);
  }

  .galerie__empty-icon {
    color: var(--color-warm-beige);
    margin-bottom: var(--space-4);
  }

  .galerie__empty-title {
    font-family: var(--font-serif);
    color: var(--color-clay-brown);
    margin-bottom: var(--space-2);
  }

  .galerie__empty-text {
    color: var(--color-text-secondary);
  }

  :global(.galerie__masonry) {
    columns: 4;
    column-gap: var(--space-3);
  }

  :global(.g-item) {
    break-inside: avoid;
    margin-bottom: var(--space-3);
    border-radius: var(--radius);
    overflow: hidden;
    position: relative;
    cursor: pointer;
    animation: fadeInUp 0.4s ease forwards;
    opacity: 0;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  :global(.g-item img) {
    width: 100%;
    display: block;
    transition: transform 0.3s ease;
  }

  :global(.g-item:hover img) {
    transform: scale(1.03);
  }

  :global(.g-item__hover) {
    position: absolute;
    inset: 0;
    background: rgba(107, 91, 83, 0);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease;
  }

  :global(.g-item:hover .g-item__hover) {
    background: rgba(107, 91, 83, 0.25);
  }

  :global(.g-item__hover-icon) {
    color: white;
    opacity: 0;
    transform: scale(0.8);
    transition: all 0.3s ease;
  }

  :global(.g-item:hover .g-item__hover-icon) {
    opacity: 1;
    transform: scale(1);
  }

  .galerie__more-wrap {
    text-align: center;
    margin-top: var(--space-6);
  }

  .galerie__more-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    border: 2px solid var(--color-warm-beige);
    border-radius: 999px;
    background: transparent;
    color: var(--color-clay-brown);
    font-size: 0.9375rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: var(--font-sans);
  }

  .galerie__more-btn:hover {
    border-color: var(--color-terracotta);
    color: var(--color-terracotta);
  }

  /* Lightbox */
  .glb {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .glb__bg {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(8px);
  }

  .glb__ui {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
    height: 100%;
    padding: var(--space-4);
  }

  .glb__close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    background: rgba(255, 255, 255, 0.15);
    border: none;
    border-radius: 50%;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    cursor: pointer;
    transition: background 0.2s;
    z-index: 10;
  }

  .glb__close:hover {
    background: rgba(255, 255, 255, 0.3);
  }

  .glb__arrow {
    background: rgba(255, 255, 255, 0.1);
    border: none;
    border-radius: 50%;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    cursor: pointer;
    transition: background 0.2s;
    flex-shrink: 0;
  }

  .glb__arrow:hover {
    background: rgba(255, 255, 255, 0.25);
  }

  .glb__stage {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 var(--space-4);
    min-width: 0;
  }

  .glb__img {
    max-width: 100%;
    max-height: 85vh;
    object-fit: contain;
    border-radius: var(--radius);
  }

  .glb__count {
    position: absolute;
    bottom: var(--space-4);
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.875rem;
  }

  .hidden {
    display: none !important;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    :global(.galerie__masonry) {
      columns: 3;
    }
  }

  @media (max-width: 768px) {
    :global(.galerie__masonry) {
      columns: 2;
    }

    .galerie__title {
      font-size: 2rem;
    }

    .glb__arrow {
      width: 40px;
      height: 40px;
    }
  }

  @media (max-width: 480px) {
    :global(.galerie__masonry) {
      columns: 2;
      column-gap: var(--space-2);
    }

    :global(.g-item) {
      margin-bottom: var(--space-2);
    }

    .galerie {
      padding: var(--space-8) var(--gutter);
    }

    .galerie__title {
      font-size: 1.75rem;
    }
  }
</style>

<script>
  // Galerie-Daten und Zustand
  interface GalleryImage {
    url: string;
    filename: string;
    category: string;
  }

  let allImages: GalleryImage[] = [];
  let filteredImages: GalleryImage[] = [];
  let visibleCount = 12;
  let currentIndex = 0;
  let currentFilter = 'all';

  const CATEGORY_LABELS: Record<string, string> = {
    tassen: 'Tassen & Becher',
    teller: 'Teller & Schalen',
    figuren: 'Figuren & Deko',
    spardosen: 'Spardosen & Krüge',
    anhaenger: 'Anhänger & Schmuck',
    kindergeburtstag: 'Kindergeburtstage',
    sonstiges: 'Sonstiges',
  };

  async function loadGallery() {
    try {
      const [galleryRes, metadataRes] = await Promise.all([
        fetch('/api/gallery'),
        fetch('/api/gallery-metadata'),
      ]);

      if (!galleryRes.ok) throw new Error('Gallery API failed');

      const galleryData = await galleryRes.json();
      const metadataData = metadataRes.ok ? (await metadataRes.json()).metadata || {} : {};

      // Nur gallery-Bilder mit gültigen URLs
      allImages = galleryData
        .filter((img: any) => img.source === 'gallery' && img.url && /\.(jpe?g|png|webp|gif)(\?|$)/i.test(img.url))
        .map((img: any) => ({
          url: img.url,
          filename: img.filename,
          category: metadataData[img.filename]?.category || '',
        }));
    } catch {
      const loading = document.getElementById('galerie-loading');
      if (loading) loading.textContent = 'Bilder konnten nicht geladen werden.';
      return;
    }

    hide('galerie-loading');

    if (allImages.length === 0) {
      show('galerie-empty-all');
      return;
    }

    buildFilterButtons();
    show('galerie-grid');
    renderImages('all');
  }

  function buildFilterButtons() {
    const categories = new Set(allImages.map(img => img.category).filter(Boolean));
    const filterContainer = document.getElementById('galerie-filter');
    if (!filterContainer) return;

    categories.forEach(cat => {
      const btn = document.createElement('button');
      btn.className = 'gf-btn';
      btn.dataset.cat = cat;
      btn.setAttribute('role', 'tab');
      btn.setAttribute('aria-selected', 'false');
      btn.textContent = CATEGORY_LABELS[cat] || cat;
      filterContainer.appendChild(btn);
    });

    filterContainer.querySelectorAll('.gf-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        filterContainer.querySelectorAll('.gf-btn').forEach(b => {
          b.classList.remove('active');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');
        visibleCount = 12;
        renderImages((btn as HTMLElement).dataset.cat || 'all');
      });
    });
  }

  function renderImages(category: string) {
    currentFilter = category;
    filteredImages = category === 'all' ? [...allImages] : allImages.filter(img => img.category === category);

    const grid = document.getElementById('galerie-grid');
    const moreWrap = document.getElementById('galerie-more-wrap');
    if (!grid || !moreWrap) return;

    if (filteredImages.length === 0) {
      grid.innerHTML = '';
      hide('galerie-grid');
      moreWrap.classList.add('hidden');
      show(category === 'all' ? 'galerie-empty-all' : 'galerie-empty-cat');
      return;
    }

    hide('galerie-empty-all');
    hide('galerie-empty-cat');
    show('galerie-grid');

    const visible = filteredImages.slice(0, visibleCount);
    grid.innerHTML = visible.map((img, i) => `
      <div class="g-item" data-i="${i}" tabindex="0" role="button" aria-label="Bild ${i + 1} ansehen" style="animation-delay: ${Math.min(i * 0.04, 0.5)}s">
        <img src="${img.url}" alt="Keramik aus dem Atelier Auszeit" loading="lazy" decoding="async">
        <div class="g-item__hover">
          <div class="g-item__hover-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
          </div>
        </div>
      </div>
    `).join('');

    // Click-Handler für Grid-Items
    grid.querySelectorAll('.g-item').forEach(item => {
      const el = item as HTMLElement;
      el.addEventListener('click', () => openLightbox(parseInt(el.dataset.i || '0', 10)));
      el.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter') openLightbox(parseInt(el.dataset.i || '0', 10));
      });
    });

    // Mehr-Button ein-/ausblenden
    if (filteredImages.length > visibleCount) {
      moreWrap.classList.remove('hidden');
    } else {
      moreWrap.classList.add('hidden');
    }
  }

  // Mehr-Button
  document.getElementById('galerie-more-btn')?.addEventListener('click', () => {
    visibleCount += 12;
    renderImages(currentFilter);
  });

  // Lightbox
  function openLightbox(index: number) {
    currentIndex = index;
    document.getElementById('glb')?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    updateLightbox();
  }

  function closeLightbox() {
    document.getElementById('glb')?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  function updateLightbox() {
    const img = document.getElementById('glb-img') as HTMLImageElement;
    const count = document.getElementById('glb-count');
    if (img) img.src = filteredImages[currentIndex]?.url || '';
    if (count) count.textContent = `${currentIndex + 1} / ${filteredImages.length}`;
  }

  function prevImage() {
    currentIndex = (currentIndex - 1 + filteredImages.length) % filteredImages.length;
    updateLightbox();
  }

  function nextImage() {
    currentIndex = (currentIndex + 1) % filteredImages.length;
    updateLightbox();
  }

  // Lightbox Event-Listener
  document.getElementById('glb-close')?.addEventListener('click', closeLightbox);
  document.getElementById('glb-bg')?.addEventListener('click', closeLightbox);
  document.getElementById('glb-prev')?.addEventListener('click', prevImage);
  document.getElementById('glb-next')?.addEventListener('click', nextImage);

  document.addEventListener('keydown', (e) => {
    if (document.getElementById('glb')?.classList.contains('hidden')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') prevImage();
    if (e.key === 'ArrowRight') nextImage();
  });

  // Touch-Swipe für Lightbox
  let touchStartX = 0;
  const glbEl = document.getElementById('glb');
  glbEl?.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
  }, { passive: true });
  glbEl?.addEventListener('touchend', (e) => {
    const diff = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(diff) > 50) {
      diff > 0 ? prevImage() : nextImage();
    }
  }, { passive: true });

  // Hilfsfunktionen
  function hide(id: string) {
    document.getElementById(id)?.classList.add('hidden');
  }

  function show(id: string) {
    document.getElementById(id)?.classList.remove('hidden');
  }

  // Galerie laden
  loadGallery();
</script>
