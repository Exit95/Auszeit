---
import Brush from "../components/Brush.astro";
import { content } from "../data/content";

const items = content.faq.items;
---

<section class="blk soft">
  <div class="wrap">
    <div class="head center">
      <span class="eyebrow">Oft gefragt</span>
      <h2>Gern beantwortet</h2>
      <Brush />
    </div>
    <div class="faq">
      {items.map((item, i) => (
        <details open={i === 0 || undefined}>
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq {
    max-width: 760px;
    margin: 2.5rem auto 0;
  }

  details {
    border-bottom: 1px solid var(--hair, #e4d8cb);
  }

  summary {
    cursor: pointer;
    list-style: none;
    padding: 1.1rem 0;
    font-family: var(--serif, serif);
    font-size: 1.2rem;
    font-weight: 500;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary::after {
    content: "+";
    color: var(--terra, #d96c4a);
    font-family: var(--sans, sans-serif);
    font-weight: 400;
    font-size: 1.5rem;
    line-height: 1;
    transition: transform 0.2s;
    flex-shrink: 0;
  }

  details[open] summary::after {
    transform: rotate(45deg);
  }

  details p {
    padding: 0 0 1.2rem;
    color: var(--ink-2, #5d4a3c);
  }
</style>
