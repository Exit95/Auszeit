---
import FAQItem from "../components/FAQItem.astro";
import { content } from "../data/content";
---

<section class="faq">
  <div class="container">
    <h2 class="faq__title">{content.faq.title}</h2>
    <div class="faq__list">
      {
        content.faq.items.map((item) => (
          <FAQItem question={item.question} answer={item.answer} />
        ))
      }
    </div>
  </div>
</section>

<style>
  .faq {
    padding: var(--space-8) var(--gutter);
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
    background: rgba(255, 255, 255, 0.58);
    border: 1px solid rgba(66, 52, 48, 0.10);
    border-radius: 18px;
    padding: var(--space-5);
    box-shadow: 0 10px 26px rgba(66, 52, 48, 0.08);
  }

  .faq__title {
    font-family: var(--font-serif);
    color: var(--brand-espresso, #423430);
    text-align: center;
    margin-bottom: var(--space-5);
    font-size: 1.5rem;
    letter-spacing: -0.01em;
  }

  .faq__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  /* Mobile Optimierungen */
  @media (max-width: 374px) {
    .faq {
      padding: var(--space-6) var(--gutter);
    }

    .container {
      padding: var(--space-3);
    }

    .faq__title {
      font-size: 1.25rem;
      margin-bottom: var(--space-4);
    }

    .faq__list {
      gap: var(--space-2);
    }
  }

  @media (min-width: 375px) and (max-width: 639px) {
    .faq {
      padding: var(--space-6) var(--gutter);
    }

    .container {
      padding: var(--space-4);
    }

    .faq__title {
      font-size: 1.35rem;
      margin-bottom: var(--space-4);
    }
  }
</style>
