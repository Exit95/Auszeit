---
import StepItem from '../components/StepItem.astro';
import { content } from '../data/content';
---

<section class="process">
  <div class="container animate-on-scroll">
    <span class="process__eyebrow">In 3 Schritten</span>
    <h2 class="process__title">{content.process.title}</h2>
    <div class="process__steps">
      {
        content.process.steps.map((step, index) => (
          <StepItem
            icon={step.icon}
            title={step.title}
            text={step.text}
            number={index + 1}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  .process {
    padding: var(--space-10) var(--gutter);
    background-color: var(--bg-linen, #EDE4DA);
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .process__eyebrow {
    display: block;
    text-align: center;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-sienna);
    margin-bottom: 0.75rem;
  }

  .process__title {
    font-family: var(--font-serif, 'Lora', serif);
    font-size: var(--text-3xl);
    color: var(--brand-espresso, #423430);
    text-align: center;
    margin-bottom: var(--space-8);
  }

  .process__steps {
    display: grid;
    gap: var(--space-8);
    max-width: 900px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .process__steps {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-6);
    }
  }
</style>
