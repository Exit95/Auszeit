---
import { content } from '../data/content';

const accentColors = [
  'var(--accent-terra)',
  'var(--color-sienna)',
  'var(--accent-caramel)',
  'var(--brand-espresso)',
];
---

<section class="was-erwartet animate-on-scroll" aria-labelledby="was-erwartet-title">
  <div class="was-erwartet__container">
    <h2 class="was-erwartet__title" id="was-erwartet-title">{content.wasErwartet.title}</h2>
    <div class="was-erwartet__grid">
      {content.wasErwartet.items.map((item, i) => (
        <a href={item.link} class="was-erwartet__card" style={`--card-accent: ${accentColors[i]}`}>
          <div class="was-erwartet__card-accent" />
          <h3 class="was-erwartet__card-title">{item.title}</h3>
          <p class="was-erwartet__card-text">{item.text}</p>
          <span class="was-erwartet__card-cta">Mehr erfahren →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .was-erwartet {
    padding: var(--space-12) var(--gutter);
    background: var(--bg-paper);
  }

  .was-erwartet__container {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .was-erwartet__title {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    color: var(--brand-espresso);
    text-align: center;
    margin: 0 0 var(--space-8);
  }

  .was-erwartet__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .was-erwartet__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .was-erwartet__card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: var(--radius);
    padding: var(--space-5) var(--space-4) var(--space-4);
    box-shadow: var(--shadow-card);
    text-decoration: none;
    color: inherit;
    gap: var(--space-2);
    position: relative;
    overflow: hidden;
    transition: transform var(--duration-normal) var(--easing),
                box-shadow var(--duration-normal) var(--easing);
  }

  .was-erwartet__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .was-erwartet__card-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--card-accent);
  }

  .was-erwartet__card-title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    color: var(--brand-espresso);
    margin: 0;
    line-height: 1.3;
  }

  .was-erwartet__card-text {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  .was-erwartet__card-cta {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--card-accent);
    margin-top: var(--space-1);
    transition: opacity var(--duration-fast) var(--easing);
  }

  .was-erwartet__card:hover .was-erwartet__card-cta {
    opacity: 0.8;
  }

  @media (prefers-reduced-motion: reduce) {
    .was-erwartet__card {
      transition: none;
    }

    .was-erwartet__card:hover {
      transform: none;
    }
  }
</style>
