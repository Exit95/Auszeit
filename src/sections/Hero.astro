---
import Button from "../components/Button.astro";
import { content } from "../data/content";
---

<section class="hero" aria-label="Willkommen bei Malatelier Auszeit">
  <div class="hero__content">
    <img
      src="/auszeit2.png"
      alt="Malatelier Auszeit | Malatelier in Gronau"
      class="hero__logo"
      width="339"
      height="158"
      loading="eager"
    />
    <h1 class="hero__claim">{content.hero.claim}</h1>
    <p class="hero__sub">{content.hero.subline}</p>
    <nav class="hero__actions" aria-label="Hauptaktionen">
      <Button href="#termin-buchen" variant="primary" size="large">
        {content.hero.ctaPrimary}
      </Button>
      <a href="#keramik-preise" class="hero__cta-secondary">
        {content.hero.ctaSecondary}
      </a>
    </nav>
  </div>
</section>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-10) var(--gutter) var(--space-12);
    text-align: center;
    background: #fff;
  }

  .hero__content {
    max-width: 640px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    animation: heroFade 0.6s ease;
  }

  .hero__logo {
    display: block;
    width: auto;
    height: auto;
    max-width: 280px;
    margin-bottom: var(--space-6);
  }

  .hero__claim {
    font-family: var(--font-serif);
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--brand-espresso);
    margin: 0 0 var(--space-3);
    line-height: 1.15;
  }

  .hero__sub {
    font-family: var(--font-sans);
    color: var(--color-text-secondary);
    font-size: 1.1rem;
    margin: 0 0 var(--space-6);
    line-height: 1.6;
  }

  .hero__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .hero__cta-secondary {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-sienna);
    text-decoration: none;
    padding: 0.6rem 1.5rem;
    border: 2px solid var(--color-sienna);
    border-radius: var(--radius-sm);
    transition: background 0.15s ease, color 0.15s ease;
  }

  .hero__cta-secondary:hover {
    background: var(--color-sienna);
    color: #fff;
  }

  @media (min-width: 640px) {
    .hero__actions {
      flex-direction: row;
      justify-content: center;
    }
  }

  @media (max-width: 639px) {
    .hero {
      padding: var(--space-8) var(--gutter);
    }

    .hero__logo {
      max-width: 220px;
    }

    .hero__actions {
      width: 100%;
      max-width: 300px;
    }

    .hero__cta-secondary {
      width: 100%;
      text-align: center;
    }
  }

  @keyframes heroFade {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__content { animation: none; }
  }
</style>
