---
import Button from "../components/Button.astro";
import { content } from "../data/content";
---

<section class="hero" aria-label="Willkommen bei Malatelier Auszeit">
  <img
    src="/hero-banner.webp"
    alt="Schaufenster von Auszeit Keramik-Malatelier in Gronau"
    class="hero__bg"
    width="1920"
    height="1280"
    loading="eager"
    fetchpriority="high"
  />
  <div class="hero__overlay"></div>
  <div class="hero__content">
    <nav class="hero__actions" aria-label="Hauptaktionen">
      <Button href="#termin-buchen" variant="primary" size="large">
        {content.hero.ctaPrimary}
      </Button>
      <a href="#keramik-preise" class="hero__cta-secondary">
        {content.hero.ctaSecondary}
      </a>
    </nav>
  </div>
</section>
<div class="hero-fade" aria-hidden="true"></div>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    min-height: 560px;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
    z-index: 0;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(66, 52, 48, 0.05) 0%,
      rgba(66, 52, 48, 0.12) 50%,
      rgba(66, 52, 48, 0.55) 100%
    );
    z-index: 1;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--max-width);
    padding: 0 var(--gutter) calc(var(--space-10) + 60px);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    animation: heroFade 0.6s ease;
  }

  .hero__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .hero__cta-secondary {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    color: #fff;
    text-decoration: none;
    padding: 0.6rem 1.5rem;
    border: 2px solid rgba(255, 255, 255, 0.6);
    border-radius: var(--radius-sm);
    transition: background 0.15s ease, border-color 0.15s ease;
    backdrop-filter: blur(4px);
    background: rgba(255,255,255,0.08);
  }

  .hero__cta-secondary:hover {
    background: rgba(255, 255, 255, 0.18);
    border-color: #fff;
  }

  /* Sanfter Farbverlauf als Übergang zur nächsten Section */
  .hero-fade {
    height: 80px;
    margin-top: -80px;
    position: relative;
    z-index: 4;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      var(--bg-paper) 100%
    );
    pointer-events: none;
  }

  @media (min-width: 640px) {
    .hero__actions {
      flex-direction: row;
      justify-content: center;
    }
  }

  @media (max-width: 639px) {
    .hero {
      min-height: 440px;
    }

    .hero__content {
      padding-bottom: calc(var(--space-6) + 30px);
    }

    .hero__actions {
      width: 100%;
      max-width: 300px;
    }

    .hero__cta-secondary {
      width: 100%;
      text-align: center;
    }

    .hero-fade {
      height: 60px;
      margin-top: -60px;
    }
  }

  @keyframes heroFade {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__content { animation: none; }
  }
</style>
