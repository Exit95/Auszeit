---
import Button from "../components/Button.astro";
import WhatsAppLink from "../components/WhatsAppLink.astro";
import InstagramLink from "../components/InstagramLink.astro";
import { content } from "../data/content";
---

<section class="hero" aria-label="Willkommen bei Atelier Auszeit">
  <div class="hero__content">
    <div class="hero__logo-card">
      <div class="hero__logo-card-inner">
        <img
          src="/auszeit2.png"
          alt="Atelier Auszeit Keramik Malatelier Logo in Gronau, Nordrhein-Westfalen"
          class="hero__logo-image"
          width="400"
          height="400"
          loading="eager"
        />
      </div>
    </div>
    <p class="hero__claim">{content.hero.claim}</p>
    <p class="hero__sub">Keramik selbst bemalen in Gronau, für Groß und Klein. Wähle dein Lieblingsstück, bemale es nach deinen Vorstellungen und nimm dein Unikat mit nach Hause.</p>
    <nav class="hero__actions" aria-label="Hauptaktionen">
      <Button href="#calendar-section" variant="primary" size="large">
        {content.hero.ctaPrimary}
      </Button>
      <WhatsAppLink
        phone={content.contact.whatsapp}
        message={content.contact.whatsappMessage}
        text={content.hero.ctaSecondary}
      />
    </nav>
    <div class="hero__secondary">
      <a href="#gutschein-section" class="hero__link">Gutschein verschenken</a>
      <span class="hero__dot">·</span>
      <InstagramLink
        url="https://www.instagram.com/auszeit_keramik_malatelier?igsh=MW90eGY0cGxlemt5cw=="
        text={content.hero.ctaTertiary}
      />
    </div>
  </div>
</section>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(
      135deg,
      var(--color-clay-brown) 0%,
      var(--color-warm-beige) 100%
    );
    padding: var(--space-2) var(--gutter);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero__logo-card {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-1);
  }

  .hero__logo-card-inner {
    background: transparent;
    padding: var(--space-3) var(--space-4);
    border-radius: 20px;
    box-shadow: none;
    border: 0;
    max-width: min(440px, 85vw);
    backdrop-filter: none;
  }

  .hero__logo-image {
    width: 100%;
    height: auto;
    display: block;
    margin: 0 auto;
    border-radius: 14px;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    opacity: 0.5;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 800px;
    width: 100%;
    animation: fadeIn var(--duration-slow) var(--easing);
  }

  .hero__claim {
    font-family: var(--font-script);
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    color: #fff;
    text-align: center;
    margin: 0 0 0.75rem;
    line-height: 1.3;
    text-shadow: 0 2px 12px rgba(0,0,0,0.15);
  }

  .hero__sub {
    color: rgba(255,255,255,0.72);
    text-align: center;
    font-size: clamp(0.9rem, 1.5vw, 1.05rem);
    max-width: 520px;
    margin: 0 auto 2rem;
    line-height: 1.65;
  }

  .hero__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .hero__secondary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 1.5rem;
    padding-bottom: 0.5rem;
  }

  .hero__link {
    color: rgba(255,255,255,0.6);
    font-size: 0.85rem;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }

  .hero__link:hover {
    color: #fff;
  }

  .hero__dot {
    color: rgba(255,255,255,0.3);
    font-size: 0.85rem;
  }

  .hero__secondary :global(.instagram-link) {
    width: auto;
    min-height: unset;
    padding: 0;
    color: rgba(255,255,255,0.6);
    font-size: 0.85rem;
    font-weight: 400;
    text-decoration: underline;
    text-underline-offset: 3px;
    background: none;
    gap: 0.4rem;
  }

  .hero__secondary :global(.instagram-link:hover) {
    color: #fff;
    background: none;
    transform: none;
  }

  .hero__secondary :global(.instagram-link svg) {
    width: 14px;
    height: 14px;
  }

  /* Sehr kleine Bildschirme (< 375px) */
  @media (max-width: 374px) {
    .hero {
      padding: var(--space-2) var(--gutter);
    }

    .hero__logo-card-inner {
      padding: var(--space-3) var(--space-3);
      border-radius: 18px;
    }

    .hero__actions {
      width: 100%;
      gap: var(--space-2);
      margin: 0 auto;
    }
  }

  /* Kleine Smartphones (375px - 479px) */
  @media (min-width: 375px) and (max-width: 479px) {
    .hero__actions {
      width: 100%;
      max-width: 320px;
      margin: 0 auto;
    }
  }

  /* Größere Smartphones (480px - 639px) */
  @media (min-width: 480px) and (max-width: 639px) {
    .hero__actions {
      max-width: 400px;
      margin: 0 auto;
    }
  }

  @media (min-width: 640px) {
    .hero__actions {
      flex-direction: row;
      justify-content: center;
    }

    .hero__claim {
      font-size: 1.5rem;
    }
  }

	  @media (min-width: 768px) {
    .hero__claim {
      font-size: 1.75rem;
    }
  }

  @media (max-width: 639px) {
    .hero__actions {
      width: 100%;
      max-width: 300px;
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__content {
      animation: none;
    }
  }
</style>
