---
import Button from '../components/Button.astro';
import Photo from '../components/Photo.astro';
import Stars from '../components/Stars.astro';
---

<section class="hero" aria-label="Malatelier Auszeit">
  <div class="hero__text">
    <span class="eyebrow">Malatelier Auszeit · Gronau</span>
    <h1>Dein Ort zum Ankommen und <em>Kreativsein</em></h1>
    <p class="sub">Keramik bemalen, durchatmen, gluecklich nach Hause gehen. Wir glasieren und brennen fuer dich, abholbereit in 10 bis 14 Tagen.</p>
    <div class="cta">
      <Button href="#buchen">Termin buchen</Button>
      <a class="link-ul" href="/galerie">Unsere Keramik ansehen</a>
    </div>
    <div class="trust">
      <Stars label="Fuenf von fuenf Sternen" />
      bei Google, von echten Gaesten aus dem Muensterland
    </div>
  </div>
  <div class="hero__img">
    <Photo
      src="/fotos/sh-hero.jpg"
      alt="Beim Bemalen mit Pinsel im Atelier"
      loading="eager"
      fetchpriority="high"
      width={1000}
      height={1500}
    />
    <div class="hero__cap">Mitten im Atelier, Gronau</div>
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    padding-top: clamp(1rem, 2vw, 2rem);
  }

  @media (min-width: 860px) {
    .hero {
      grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    }
  }

  .hero__text {
    padding: clamp(2rem, 4vw, 4rem) var(--gutter);
  }

  .hero h1 {
    font-size: clamp(2.6rem, 5.4vw, 4.4rem);
    margin: 1rem 0 1.1rem;
    max-width: 13ch;
  }

  .hero h1 em {
    font-style: italic;
    color: var(--terra);
  }

  .hero .sub {
    font-size: 1.12rem;
    line-height: 1.6;
    color: var(--ink-2);
    max-width: 42ch;
  }

  .hero .cta {
    display: flex;
    gap: 1.3rem;
    align-items: center;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  .hero .trust {
    margin-top: 1.7rem;
    font-size: .9rem;
    color: var(--meta);
    display: flex;
    gap: .6rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .hero__img {
    position: relative;
    min-height: clamp(340px, 46vw, 560px);
    margin: clamp(1rem, 2vw, 1.6rem);
    border-radius: var(--r-lg);
    overflow: hidden;
    box-shadow: var(--shadow-soft);
  }

  .hero__img :global(img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
  }

  .hero__cap {
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    color: #fff;
    font-size: .74rem;
    letter-spacing: .04em;
    padding: 3rem 1.2rem 1rem;
    background: linear-gradient(transparent, rgba(58, 45, 36, .5));
  }
</style>
