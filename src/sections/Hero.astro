---
import Button from "../components/Button.astro";
import { content } from "../data/content";
---

<section class="hero" aria-label="Willkommen bei Keramik Auszeit">
  <div class="hero__content">
    <div class="hero__logo-card">
      <img
        src="/auszeit2.png"
        alt="Keramik Auszeit — Malatelier in Gronau"
        class="hero__logo-image"
        width="400"
        height="400"
        loading="eager"
      />
    </div>
    <h1 class="hero__claim">{content.hero.claim}</h1>
    <p class="hero__sub">{content.hero.subline}</p>
    <nav class="hero__actions" aria-label="Hauptaktionen">
      <Button href="#termin-buchen" variant="primary" size="large">
        {content.hero.ctaPrimary}
      </Button>
      <a href="#keramik-preise" class="hero__cta-secondary">
        {content.hero.ctaSecondary}
      </a>
    </nav>
  </div>
</section>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 70vh;
    background: var(--bg-cream);
    padding: var(--space-8) var(--gutter) var(--space-10);
    text-align: center;
    position: relative;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 680px;
    width: 100%;
    animation: fadeIn var(--duration-slow) var(--easing);
  }

  .hero__logo-card {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-4);
  }

  .hero__logo-image {
    width: 100%;
    max-width: 320px;
    height: auto;
    display: block;
    margin: 0 auto;
    border-radius: var(--radius-lg);
  }

  .hero__claim {
    font-family: var(--font-serif);
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--brand-espresso);
    margin: 0 0 var(--space-2);
    line-height: 1.15;
  }

  .hero__sub {
    font-family: var(--font-sans);
    color: var(--color-text-secondary);
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    max-width: 460px;
    margin: 0 auto var(--space-6);
    line-height: 1.65;
  }

  .hero__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .hero__cta-secondary {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-sienna);
    text-decoration: none;
    padding: 0.6rem 1.5rem;
    border: 2px solid var(--color-sienna);
    border-radius: var(--radius-sm);
    transition: background 0.15s ease, color 0.15s ease;
  }

  .hero__cta-secondary:hover {
    background: var(--color-sienna);
    color: #fff;
  }

  @media (min-width: 640px) {
    .hero__actions {
      flex-direction: row;
      justify-content: center;
    }
  }

  @media (max-width: 639px) {
    .hero {
      min-height: auto;
      padding: var(--space-6) var(--gutter) var(--space-8);
    }

    .hero__logo-image {
      max-width: 240px;
    }

    .hero__actions {
      width: 100%;
      max-width: 300px;
    }

    .hero__cta-secondary {
      width: 100%;
      text-align: center;
    }
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__content {
      animation: none;
    }
  }
</style>
