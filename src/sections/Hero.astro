---
import Button from "../components/Button.astro";
import WhatsAppLink from "../components/WhatsAppLink.astro";
import InstagramLink from "../components/InstagramLink.astro";
import { content } from "../data/content";
---

<section class="hero" aria-label="Willkommen bei Atelier Auszeit">
  <div class="hero__content">
    <div class="hero__logo-card">
      <div class="hero__logo-card-inner">
        <img
          src="/auszeit2.png"
          alt="Atelier Auszeit – Keramik Malatelier Logo in Gronau, Nordrhein-Westfalen"
          class="hero__logo-image"
          width="400"
          height="400"
          loading="eager"
        />
      </div>
    </div>
    <nav class="hero__actions" aria-label="Hauptaktionen">
      <Button href="#calendar-section" variant="primary" size="large">
        {content.hero.ctaPrimary}
      </Button>
      <Button href="#gutschein-section" variant="secondary" size="large">
        🎁 Gutschein kaufen
      </Button>
    </nav>
    <div class="hero__social">
      <WhatsAppLink
        phone={content.contact.whatsapp}
        message={content.contact.whatsappMessage}
        text={content.hero.ctaSecondary}
      />
      <InstagramLink
        url="https://www.instagram.com/auszeit_keramik_malatelier?igsh=MW90eGY0cGxlemt5cw=="
        text={content.hero.ctaTertiary}
      />
    </div>
  </div>
</section>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.58);
    border-bottom: 1px solid rgba(66, 52, 48, 0.10);
    padding: var(--space-4) var(--gutter);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero__logo-card {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-2);
  }

  .hero__logo-card-inner {
    background: rgba(255, 255, 255, 0.62);
    padding: var(--space-3) var(--space-4);
    border-radius: 18px;
    box-shadow: 0 10px 24px rgba(66, 52, 48, 0.10);
    border: 1px solid rgba(66, 52, 48, 0.10);
    max-width: min(380px, 85vw);
  }

  .hero__logo-image {
    width: 100%;
    height: auto;
    display: block;
    margin: 0 auto;
    border-radius: 14px;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 800px;
    width: 100%;
    animation: fadeIn var(--duration-slow) var(--easing);
  }

  .hero__actions {
    display: flex;
    flex-direction: row;
    justify-content: center;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    margin-bottom: var(--space-3);
  }

  .hero__social {
    display: flex;
    flex-direction: row;
    justify-content: center;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
  }

  /* Sehr kleine Bildschirme (< 375px) */
  @media (max-width: 374px) {
    .hero {
      padding: var(--space-2) var(--gutter);
    }

    .hero__logo-card-inner {
      padding: var(--space-2) var(--space-2);
      border-radius: 16px;
    }

    .hero__actions {
      flex-direction: column;
      width: 100%;
      gap: 10px;
    }

    .hero__social {
      flex-direction: column;
      width: 100%;
      gap: 10px;
    }
  }

  /* Kleine Smartphones (375px - 479px) */
  @media (min-width: 375px) and (max-width: 479px) {
    .hero__actions {
      flex-direction: column;
      width: 100%;
      max-width: 320px;
      margin: 0 auto var(--space-3);
    }

    .hero__social {
      flex-direction: column;
      width: 100%;
      max-width: 320px;
      margin: 0 auto;
    }
  }

  /* Größere Smartphones (480px - 639px) */
  @media (min-width: 480px) and (max-width: 639px) {
    .hero__actions {
      max-width: 400px;
      margin: 0 auto var(--space-3);
    }

    .hero__social {
      max-width: 400px;
      margin: 0 auto;
    }
  }

  @media (min-width: 640px) {
    .hero__actions {
      flex-direction: row;
      justify-content: center;
      flex-wrap: wrap;
    }

    .hero__claim {
      font-size: 1.5rem;
    }
  }

	  @media (min-width: 768px) {
    .hero__claim {
      font-size: 1.75rem;
    }
  }

  @media (max-width: 639px) {
    .hero__actions {
      width: 100%;
      max-width: 300px;
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__content {
      animation: none;
    }
  }
</style>
