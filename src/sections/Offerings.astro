---
import { content } from '../data/content';
import ProductModal from '../components/ProductModal.astro';
import fs from 'fs';
import path from 'path';
import { isS3Configured, listS3Objects, getS3Key, readJsonFromS3 } from '../lib/s3-storage';

// Kategorie-Mapping für Produkte (für neues Galerie-System)
const categoryMapping: Record<string, { id: string; folder: string; mainImage: string }> = {
  'Tassen': { id: 'tassen', folder: 'tassen', mainImage: '/becher.jpeg' },
  'Teller': { id: 'teller', folder: 'teller', mainImage: '/teller.jpeg' },
  'Spardosen & Krüge & Boxen': { id: 'spardosen', folder: 'spardosen', mainImage: '/spardose.jpeg' },
  'Weihnachtsanhänger': { id: 'anhaenger', folder: 'anhaenger', mainImage: '/anhänger.png' },
};

async function loadGalleryMetadata(): Promise<Record<string, { category: string | null }>> {
  try {
    return await readJsonFromS3('gallery-metadata.json', {});
  } catch {
    return {};
  }
}

async function loadGalleryImages(): Promise<{ filename: string; url: string }[]> {
  try {
    const s3Key = getS3Key('gallery/');
    const s3Objects = await listS3Objects(s3Key);
    const endpoint = process.env.S3_ENDPOINT || import.meta.env.S3_ENDPOINT || '';
    const bucket = process.env.S3_BUCKET || import.meta.env.S3_BUCKET || '';
    return s3Objects
      .filter(obj => {
        const ext = obj.key.split('.').pop()?.toLowerCase();
        return ['jpg', 'jpeg', 'png', 'webp', 'gif'].includes(ext || '');
      })
      .map(obj => ({
        filename: obj.key.split('/').pop() || '',
        url: `${endpoint}/${bucket}/${obj.key}`,
      }));
  } catch {
    return [];
  }
}

async function getImagesFromS3(category: string): Promise<string[]> {
  const config = categoryMapping[category];
  if (!config) return [];
  const images: string[] = [config.mainImage];
  try {
    const s3Key = getS3Key(`products/${config.folder}/`);
    const s3Objects = await listS3Objects(s3Key);
    const imageFiles = s3Objects
      .filter(obj => {
        const ext = obj.key.split('.').pop()?.toLowerCase();
        return ['jpg', 'jpeg', 'png', 'webp'].includes(ext || '');
      })
      .sort((a, b) => a.key.localeCompare(b.key))
      .map(obj => {
        const filename = obj.key.split('/').pop() || '';
        return `/products/${config.folder}/${filename}`;
      });
    images.push(...imageFiles);
  } catch (error) {
    console.warn(`Konnte S3-Ordner für ${category} nicht lesen:`, error);
  }
  return images;
}

function getImagesFromFolder(folderPath: string, mainImage: string): string[] {
  const publicDir = path.join(process.cwd(), 'public');
  const distClientDir = path.join(process.cwd(), 'dist', 'client');
  let fullPath = path.join(publicDir, folderPath);
  if (!fs.existsSync(fullPath)) {
    fullPath = path.join(distClientDir, folderPath);
  }
  const images = [mainImage];
  try {
    if (fs.existsSync(fullPath)) {
      const files = fs.readdirSync(fullPath);
      const imageFiles = files
        .filter(file => /\.(jpeg|jpg|png|webp)$/i.test(file))
        .sort()
        .map(file => `/${folderPath}/${file}`);
      images.push(...imageFiles);
    }
  } catch (error) {
    console.warn(`Konnte Ordner ${folderPath} nicht lesen:`, error);
  }
  return images;
}

let productGalleries: Record<string, string[]> = {};

if (isS3Configured()) {
  const categories = Object.keys(categoryMapping);
  const oldResults = await Promise.all(
    categories.map(async (category) => ({
      category,
      images: await getImagesFromS3(category)
    }))
  );
  for (const result of oldResults) {
    const config = categoryMapping[result.category];
    const localImages = config ? getImagesFromFolder(`products/${config.folder}`, config.mainImage) : [];
    const merged = [...new Set([...result.images, ...localImages])];
    productGalleries[result.category] = merged;
  }
  try {
    const [galleryImages, metadata] = await Promise.all([loadGalleryImages(), loadGalleryMetadata()]);
    for (const [productName, config] of Object.entries(categoryMapping)) {
      const newImages = galleryImages
        .filter((img) => metadata[img.filename]?.category === config.id)
        .map((img) => img.url);
      if (newImages.length > 0) {
        productGalleries[productName] = [...(productGalleries[productName] || [config.mainImage]), ...newImages];
      }
    }
  } catch (error) {
    console.warn('Fehler beim Laden der neuen Galerie-Daten:', error);
  }
} else {
  productGalleries = {
    'Tassen': getImagesFromFolder('products/tassen', '/becher.jpeg'),
    'Teller': getImagesFromFolder('products/teller', '/teller.jpeg'),
    'Spardosen & Krüge & Boxen': getImagesFromFolder('products/spardosen', '/spardose.jpeg'),
    'Weihnachtsanhänger': getImagesFromFolder('products/anhaenger', '/anhänger.png'),
  };
}

// Produkte mit Zusatzinfos
const products = [
  {
    name: 'Tassen',
    subtitle: 'Dein persönlicher Lieblingsbecher',
    price: 'ab 14,50€',
    image: '/becher.jpeg',
    images: productGalleries['Tassen'] || ['/becher.jpeg'],
    isPng: false,
  },
  {
    name: 'Teller',
    subtitle: 'Handgemalt, einzigartig, deins',
    price: 'ab 12,50€',
    image: '/teller.jpeg',
    images: productGalleries['Teller'] || ['/teller.jpeg'],
    isPng: false,
  },
  {
    name: 'Spardosen & Krüge & Boxen',
    subtitle: 'Für jeden Anlass das passende Stück',
    price: 'ab 8,00€',
    image: '/spardose.jpeg',
    images: productGalleries['Spardosen & Krüge & Boxen'] || ['/spardose.jpeg'],
    isPng: false,
  },
  {
    name: 'Weihnachtsanhänger',
    subtitle: 'Festliche Unikate zum Verschenken',
    price: 'ab 6,00€',
    image: '/anhänger.png',
    images: productGalleries['Weihnachtsanhänger'] || ['/anhänger.png'],
    isPng: true,
  },
];
---

<section class="off" id="angebote" style="scroll-margin-top: 60px;" aria-labelledby="off-title">

  <!-- Header -->
  <div class="off__head">
    <span class="off__eyebrow">Handbemalte Keramik aus Gronau</span>
    <h2 id="off-title" class="off__title">Unser Angebot</h2>
    <p class="off__sub">Wähle dein Lieblingsstück und gestalte es ganz nach deinen Vorstellungen – ein echtes Unikat, das bleibt.</p>
  </div>

  <!-- Bento-Grid -->
  <div class="off__bento">
    {products.map((p, i) => (
      <article
        class={`ocard ocard--${i}`}
        data-product-name={p.name}
        data-product-price={p.price}
        data-product-images={JSON.stringify(p.images)}
        role="button"
        tabindex="0"
        aria-label={`${p.name} – Bilder ansehen`}
      >
        <div class="ocard__img-wrap">
          <img
            src={p.image}
            alt={p.name}
            class={p.isPng ? 'ocard__img ocard__img--contain' : 'ocard__img'}
            loading={i < 2 ? 'eager' : 'lazy'}
          />
          <div class="ocard__overlay"></div>
        </div>

        <div class="ocard__body">
          <div class="ocard__text">
            <p class="ocard__sub">{p.subtitle}</p>
            <h3 class="ocard__name">{p.name}</h3>
          </div>
          <div class="ocard__footer">
            <span class="ocard__price">{p.price}</span>
            <span class="ocard__cta">
              Entdecken
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </div>
        </div>
      </article>
    ))}
  </div>

  <!-- Mehr-Hinweis -->
  <div class="off__more-row">
    <span class="off__more-line"></span>
    <span class="off__more-text">und noch vieles mehr im Atelier</span>
    <span class="off__more-line"></span>
  </div>

  <!-- Preise -->
  <div class="off__pricing">
    <div class="off__pricing-inner">
      <div class="off__pricing-head">
        <h3 class="off__pricing-title">Farb- &amp; Brennpauschale</h3>
        <p class="off__pricing-note">Farben, Pinsel und Glasurbrand sind immer inklusive.</p>
      </div>
      <div class="off__tiers">
        {content.offerings.pricing.map((item) => (
          <div class="otier">
            <div class="otier__label">{item.description}</div>
            <div class="otier__price">{item.price}</div>
          </div>
        ))}
      </div>
      <p class="off__pickup">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        {content.offerings.note}
      </p>
    </div>
  </div>

</section>

<ProductModal />

<style>
  /* ── Section ── */
  .off {
    background: #423430;
    color: #fff;
  }

  /* ── Head ── */
  .off__head {
    text-align: center;
    padding: 5rem var(--gutter, 1.5rem) 3rem;
    max-width: var(--max-width, 1400px);
    margin: 0 auto;
  }

  .off__eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #c9956e;
    margin-bottom: 1rem;
  }

  .off__title {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    color: #fff;
    margin: 0 0 1rem;
    line-height: 1.1;
  }

  .off__sub {
    color: rgba(255,255,255,0.55);
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.65;
  }

  /* ── 2×2 Grid ── */
  .off__bento {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 420px 420px;
    gap: 6px;
    padding: 0 6px 6px;
  }

  /* ── Karte ── */
  .ocard {
    position: relative;
    overflow: hidden;
    border-radius: 4px;
    cursor: pointer;
    background: #3a2a24;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .ocard__img-wrap {
    position: absolute;
    inset: 0;
  }

  .ocard__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  .ocard__img--contain {
    object-fit: contain;
    padding: 2rem;
    background: #3a2a24;
  }

  .ocard__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(10, 6, 4, 0.88) 0%,
      rgba(10, 6, 4, 0.4) 45%,
      rgba(10, 6, 4, 0.05) 100%
    );
    transition: opacity 0.3s ease;
  }

  .ocard:hover .ocard__img { transform: scale(1.07); }
  .ocard:hover .ocard__overlay { opacity: 0.85; }

  /* Tag badge */
  .ocard__tag {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: #c9956e;
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.65rem;
    border-radius: 99px;
    z-index: 2;
  }

  /* Body text */
  .ocard__body {
    position: relative;
    z-index: 2;
    padding: 1.25rem 1.4rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .ocard__sub {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.55);
    margin: 0;
    letter-spacing: 0.02em;
    line-height: 1.4;
  }

  .ocard__name {
    font-family: var(--font-serif);
    font-size: clamp(1.15rem, 2vw, 1.55rem);
    color: #fff;
    margin: 0;
    line-height: 1.15;
  }

  .ocard__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.2rem;
  }

  .ocard__price {
    font-size: 1.05rem;
    font-weight: 700;
    color: #e8b48a;
  }

  .ocard__cta {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: rgba(255,255,255,0.45);
    letter-spacing: 0.04em;
    transition: color 0.2s;
  }

  .ocard:hover .ocard__cta { color: #e8b48a; }

  /* ── More divider ── */
  .off__more-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 2.5rem var(--gutter, 1.5rem);
    max-width: var(--max-width, 1400px);
    margin: 0 auto;
  }

  .off__more-line {
    flex: 1;
    height: 1px;
    background: rgba(255,255,255,0.12);
  }

  .off__more-text {
    color: rgba(255,255,255,0.38);
    font-size: 0.85rem;
    white-space: nowrap;
    font-style: italic;
  }

  /* ── Pricing ── */
  .off__pricing {
    padding: 0 var(--gutter, 1.5rem) 5rem;
    max-width: var(--max-width, 1400px);
    margin: 0 auto;
  }

  .off__pricing-inner {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 12px;
    padding: 2.5rem;
    max-width: 760px;
    margin: 0 auto;
  }

  .off__pricing-head {
    text-align: center;
    margin-bottom: 2rem;
  }

  .off__pricing-title {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    color: #fff;
    margin: 0 0 0.5rem;
  }

  .off__pricing-note {
    color: rgba(255,255,255,0.45);
    font-size: 0.9rem;
    margin: 0;
  }

  .off__tiers {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .otier {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .otier:last-child { border-bottom: none; }

  .otier__label {
    color: rgba(255,255,255,0.72);
    font-size: 0.95rem;
    line-height: 1.4;
    max-width: 70%;
  }

  .otier__price {
    font-size: 1.2rem;
    font-weight: 700;
    color: #e8b48a;
    white-space: nowrap;
    margin-left: 1rem;
  }

  .off__pickup {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255,255,255,0.38);
    font-size: 0.85rem;
    margin: 1.5rem 0 0;
    justify-content: center;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .off__bento {
      grid-template-rows: 280px 280px;
      gap: 4px;
      padding: 0 4px 4px;
    }
    .off__pricing-inner { padding: 1.75rem 1.25rem; }
    .otier { flex-direction: column; align-items: flex-start; gap: 0.25rem; }
    .otier__label { max-width: 100%; }
    .otier__price { margin-left: 0; }
  }

  @media (max-width: 480px) {
    .off__head { padding: 3.5rem 1.25rem 2rem; }
    .off__bento { grid-template-rows: 200px 200px; }
    .ocard__name { font-size: 1rem; }
    .ocard__body { padding: 0.9rem 1rem; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('productModal');
    const modalTitle = modal?.querySelector('.pmodal__title');
    const modalPrice = modal?.querySelector('.pmodal__price');
    const modalClose = modal?.querySelector('.pmodal__close');
    const modalOverlay = modal?.querySelector('.pmodal__overlay');
    const mainImg = document.getElementById('pmc-main') as HTMLImageElement | null;
    const counter = document.getElementById('pmc-counter');
    const prevBtn = document.getElementById('pmc-prev');
    const nextBtn = document.getElementById('pmc-next');

    let images: string[] = [];
    let currentIdx = 0;

    function showImage(idx: number) {
      if (!images.length || !mainImg) return;
      currentIdx = (idx + images.length) % images.length;
      mainImg.classList.add('loading');
      const newSrc = images[currentIdx];
      const tmp = new Image();
      tmp.onload = () => { mainImg.src = newSrc; mainImg.classList.remove('loading'); };
      tmp.src = newSrc;
      if (counter) counter.textContent = `${currentIdx + 1} / ${images.length}`;
    }

    function openModal(productName: string, productPrice: string, imgs: string[]) {
      if (!modal) return;
      images = imgs.filter(Boolean);
      currentIdx = 0;
      if (modalTitle) modalTitle.textContent = productName;
      if (modalPrice) modalPrice.textContent = productPrice;
      if (mainImg) {
        mainImg.src = images[0] || '';
        mainImg.alt = productName;
        mainImg.onclick = () => window.open(images[currentIdx], '_blank');
      }
      if (counter) counter.textContent = `1 / ${images.length}`;
      modal.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal?.classList.remove('active');
      document.body.style.overflow = '';
    }

    prevBtn?.addEventListener('click', () => showImage(currentIdx - 1));
    nextBtn?.addEventListener('click', () => showImage(currentIdx + 1));
    modalClose?.addEventListener('click', closeModal);
    modalOverlay?.addEventListener('click', closeModal);

    document.addEventListener('keydown', (e) => {
      if (!modal?.classList.contains('active')) return;
      if (e.key === 'Escape') closeModal();
      if (e.key === 'ArrowLeft') showImage(currentIdx - 1);
      if (e.key === 'ArrowRight') showImage(currentIdx + 1);
    });

    document.querySelectorAll('.ocard').forEach((card) => {
      card.addEventListener('click', () => {
        const name = card.getAttribute('data-product-name') || '';
        const price = card.getAttribute('data-product-price') || '';
        const imgs = JSON.parse(card.getAttribute('data-product-images') || '[]');
        openModal(name, price, imgs);
      });
      card.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
          (card as HTMLElement).click();
        }
      });
    });
  });
</script>
