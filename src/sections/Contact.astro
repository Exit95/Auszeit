---
import WhatsAppLink from "../components/WhatsAppLink.astro";
import InstagramLink from "../components/InstagramLink.astro";
import { content } from "../data/content";
---

<section class="contact" id="kontakt" style="scroll-margin-top: 60px;" aria-labelledby="contact-title">
  <div class="container">
    <span class="contact__eyebrow" data-animate="fade-in">So findest du uns</span>
    <h2 id="contact-title" class="contact__title" data-animate="fade-up" data-animate-delay="80">{content.contact.title}</h2>
    <div class="contact__grid">
      <address class="contact__info" data-animate="slide-right" data-animate-delay="160">
        <div class="contact__block">
          <h3>Adresse</h3>
          <p itemprop="streetAddress">{content.contact.address.street}</p>
          <p>
            <span itemprop="postalCode">48599</span> <span itemprop="addressLocality">{content.contact.address.city}</span>
          </p>
        </div>
          <div class="contact__block">
            <h3>Parkmöglichkeiten</h3>
            <p>Es gibt keine Parkmöglichkeiten direkt vor dem Atelier. Bitte umliegend parken.</p>
          </div>
        <div class="contact__block">
          <h3>Termine</h3>
          <p>Feste Öffnungszeiten gibt es bei uns nicht. Ich gebe Termine frei, du suchst dir deinen Wunschtermin einfach online aus.</p>
        </div>
        <div class="contact__block">
          <h3>Kontakt</h3>
          <p>
            <a href={`tel:${content.contact.phone}`} itemprop="telephone" aria-label="Telefonnummer anrufen">{content.contact.phone}</a>
          </p>
          <p>
            <a href={`mailto:${content.contact.email}`} itemprop="email" aria-label="E-Mail senden"
              >{content.contact.email}</a
            >
          </p>
          <div class="contact__whatsapp">
            <WhatsAppLink
              phone={content.contact.whatsapp}
              message={content.contact.whatsappMessage}
              text="WhatsApp"
            />
          </div>
          <div class="contact__instagram">
            <InstagramLink
              url="https://www.instagram.com/auszeit_keramik_malatelier/"
              text="Instagram"
            />
          </div>
        </div>
      </address>
      <div class="contact__map" id="map-container" data-animate="scale-up" data-animate-delay="240">
        <button class="contact__map-placeholder" id="load-map-btn" type="button" aria-label="Google Maps Karte laden">
          <img
            src="/map-placeholder.webp"
            alt="Standort Malatelier Auszeit, Feldstiege 6a, 48599 Gronau"
            width="600"
            height="400"
            loading="lazy"
            onerror="this.style.display='none'"
          />
          <span class="contact__map-consent">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Karte laden
            <small>Dabei werden Daten an Google übermittelt</small>
          </span>
        </button>
      </div>
      <script is:inline>
        document.getElementById('load-map-btn')?.addEventListener('click', function() {
          const container = document.getElementById('map-container');
          if (!container) return;
          container.innerHTML = '<iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2444.9517364026356!2d7.039116876952842!3d52.20792455928731!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47b83e5bd7ba24d9%3A0xe587407671767893!2sFeldstiege%206A%2C%2048599%20Gronau%20(Westfalen)!5e0!3m2!1sde!2sde!4v1764054745840!5m2!1sde!2sde" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" title="Google Maps: Atelier Auszeit, Feldstiege 6a, 48599 Gronau" aria-label="Interaktive Karte mit Standort des Ateliers" referrerpolicy="no-referrer-when-downgrade"></iframe>';
        });
      </script>
    </div>
  </div>
</section>

<style>
  .contact {
    padding: var(--space-10) var(--gutter);
    background-color: var(--surface);
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .contact__eyebrow {
    display: block;
    text-align: center;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--terra);
    margin-bottom: 0.75rem;
  }

  .contact__title {
    font-family: var(--font-serif, 'Lora', serif);
    font-size: var(--text-h2);
    color: var(--ink);
    text-align: center;
    margin-bottom: var(--space-8);
  }

  .contact__grid {
    display: grid;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .contact__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .contact__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .contact__block h3 {
    font-family: var(--font-serif, 'Lora', serif);
    color: var(--ink);
    margin-bottom: var(--space-2);
    font-size: 1.125rem;
  }

  .contact__block p {
    font-family: var(--font-sans, 'Source Sans 3', sans-serif);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-1);
  }

  .contact__block a {
    color: var(--terra);
    text-decoration: underline;
    transition: color var(--dur-mid) var(--ease-smooth);
  }

  .contact__block a:hover {
    color: var(--terra-h);
  }

  .contact__whatsapp {
    margin-top: var(--space-3);
  }

  .contact__instagram {
    margin-top: var(--space-2);
  }

  .contact__map {
    min-height: 400px;
  }

  .contact__map-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    min-height: 400px;
    background: var(--bg);
    border: 2px dashed var(--hair);
    border-radius: var(--radius-sm, 8px);
    cursor: pointer;
    position: relative;
    overflow: hidden;
    padding: 0;
    font-family: inherit;
    color: inherit;
  }

  .contact__map-placeholder img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    inset: 0;
    filter: brightness(0.7);
  }

  .contact__map-consent {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans, 'Source Sans 3', sans-serif);
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink);
    background: rgba(250, 247, 242, 0.9);
    padding: 1.25rem 2rem;
    border-radius: var(--radius-sm, 8px);
  }

  .contact__map-consent small {
    font-size: 0.8rem;
    font-weight: 400;
    opacity: 0.7;
  }

  .contact__map-placeholder:hover .contact__map-consent {
    background: rgba(250, 247, 242, 1);
  }

  .map-placeholder {
    width: 100%;
    height: 100%;
    min-height: 400px;
    background-color: var(--hair);
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    color: var(--ink);
  }

  .map-placeholder svg {
    width: 64px;
    height: 64px;
    opacity: 0.5;
  }

  .map-placeholder p {
    font-size: 0.875rem;
    opacity: 0.7;
  }

  /* Mobile Optimierungen */
  @media (max-width: 374px) {
    .contact {
      padding: var(--space-8) var(--gutter);
    }

    .contact__title {
      font-size: 1.75rem;
      margin-bottom: var(--space-6);
    }

    .contact__grid {
      gap: var(--space-6);
    }

    .contact__info {
      gap: var(--space-4);
    }

    .contact__block h3 {
      font-size: 1rem;
    }

    .contact__block p {
      font-size: 0.9375rem;
    }

    .contact__map {
      min-height: 300px;
    }

    .map-placeholder {
      min-height: 300px;
    }
  }

  @media (min-width: 375px) and (max-width: 639px) {
    .contact {
      padding: var(--space-10) var(--gutter);
    }

    .contact__title {
      font-size: 1.875rem;
      margin-bottom: var(--space-6);
    }

    .contact__grid {
      gap: var(--space-6);
    }

    .contact__map {
      min-height: 350px;
    }

    .map-placeholder {
      min-height: 350px;
    }
  }

  @media (min-width: 640px) and (max-width: 767px) {
    .contact__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
