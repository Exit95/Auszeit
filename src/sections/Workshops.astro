---
import WorkshopCard from "../components/WorkshopCard.astro";
import WorkshopModal from "../components/WorkshopModal.astro";
import { getWorkshops } from "../lib/storage";
import { isS3Configured, readJsonFromS3 } from "../lib/s3-storage";
import fs from "fs/promises";
import path from "path";

interface WorkshopBooking {
  workshopId: string;
  participants: number;
  status: 'pending' | 'confirmed' | 'cancelled';
}

// Buchungen laden um aktuelle Teilnehmerzahl zu berechnen
async function getWorkshopBookings(): Promise<WorkshopBooking[]> {
  if (isS3Configured()) {
    try {
      return await readJsonFromS3<WorkshopBooking[]>('workshop-bookings.json', []);
    } catch {
      // S3 nicht erreichbar (lokal), Fallback
    }
  }
  try {
    const filePath = path.join(process.cwd(), 'data', 'workshop-bookings.json');
    const data = await fs.readFile(filePath, 'utf-8');
    return JSON.parse(data);
  } catch {
    return [];
  }
}

const [workshops, bookings] = await Promise.all([getWorkshops(), getWorkshopBookings()]);

// Aktive Workshops mit berechneter Teilnehmerzahl
const activeWorkshops = workshops
  .filter((w) => w.active)
  .map((workshop) => {
    const workshopBookings = bookings.filter(
      (b) => b.workshopId === workshop.id && b.status !== 'cancelled'
    );
    const currentParticipants = workshopBookings.reduce(
      (sum, b) => sum + b.participants,
      0
    );
    return {
      ...workshop,
      currentParticipants,
    };
  });
---

<section id="workshops" class="workshops animate-on-scroll" style="scroll-margin-top: 60px;">
  <div class="container">
    {
      activeWorkshops.length > 0 ? (
        <div class="workshops__grid">
          {activeWorkshops.map((workshop) => (
            <WorkshopCard workshop={workshop} />
          ))}
        </div>
      ) : (
        <div class="workshops__empty">
          <div class="workshops__empty-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          </div>
          <h3 class="workshops__empty-title">Aktuell keine Workshops geplant</h3>
          <p class="workshops__empty-text">Schau bald wieder vorbei, neue Termine kommen regelmäßig dazu!</p>
          <p class="workshops__empty-text">Oder schreib uns per <a href="https://wa.me/4917634255005">WhatsApp</a>, um als Erste/r informiert zu werden.</p>
        </div>
      )
    }
  </div>
</section>

<WorkshopModal />

<script src="../scripts/workshop-modal.js"></script>

<style>
  .workshops {
    padding: var(--space-8) var(--gutter);
  }

  .workshops .container {
    max-width: var(--max-width);
    margin: 0 auto;
    background: rgba(255, 255, 255, 0.58);
    border: 1px solid rgba(66, 52, 48, 0.10);
    border-radius: 18px;
    padding: var(--space-5);
    box-shadow: 0 10px 26px rgba(66, 52, 48, 0.08);
  }

  .workshops__empty {
    text-align: center;
    color: var(--color-text-secondary);
    padding: var(--space-8) var(--space-4);
    background: rgba(242, 235, 229, 0.55);
    border-radius: 14px;
    border: 1px solid rgba(66, 52, 48, 0.10);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .workshops__empty-icon {
    color: var(--accent-caramel, #CFA874);
    margin-bottom: var(--space-2);
  }

  .workshops__empty-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--brand-espresso, #423430);
    margin: 0;
  }

  .workshops__empty-text {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.6;
  }

  .workshops__empty-text a {
    color: var(--accent-terra, #D96C4A);
    text-decoration: underline;
    font-weight: 600;
  }

  .workshops__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 14px;
  }

  @media (min-width: 640px) {
    .workshops__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .workshops__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 639px) {
    .workshops {
      padding: var(--space-6) var(--gutter);
    }

    .workshops .container {
      padding: var(--space-4);
    }

    .workshops__empty {
      padding: var(--space-6) var(--space-3);
    }
  }
</style>
