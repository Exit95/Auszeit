---
import Stars from "../components/Stars.astro";
import Brush from "../components/Brush.astro";

// Statische Fallback-Bewertungen (identisch mit Design-Reference: Carina, Helene, Linda)
const fallbackReviews = [
  {
    name: "Carina",
    comment: "Irena hat einen ganz tollen Ort geschaffen, an dem man einfach mal abschalten kann. Werde definitiv noch oft wiederkommen!",
  },
  {
    name: "Helene",
    comment: "Irena erklärt alles mit viel Geduld, Witz und Herz. Ein wunderbarer Ort, um eine kleine Auszeit vom Alltag zu nehmen.",
  },
  {
    name: "Linda",
    comment: "Kreativ sein hat uns sehr gut getan. Schön, dass es Anlaufstellen gibt zum Entspannen. Preis-Leistung ist super.",
  },
];

// Emojis und sonstige Sonderzeichen (Emoji-Ranges) entfernen
function stripEmojis(text: string): string {
  return text
    .replace(/[\u{1F300}-\u{1FFFF}]/gu, "")
    .replace(/[\u{2600}-\u{27BF}]/gu, "")
    .replace(/[\u{FE00}-\u{FEFF}]/gu, "")
    .replace(/[\u{1F000}-\u{1F9FF}]/gu, "")
    .replace(/‍/g, "")
    .trim();
}

interface Review {
  id: string;
  name: string;
  rating: number;
  comment: string;
  date: string;
  approved: boolean;
}

let reviews: { name: string; comment: string }[] = fallbackReviews;

try {
  // Server-seitig aus der API lesen (SSR)
  const { default: fs } = await import("fs");
  const { default: path } = await import("path");
  const reviewsFile = path.join(process.cwd(), "data", "reviews.json");
  if (fs.existsSync(reviewsFile)) {
    const raw: Review[] = JSON.parse(fs.readFileSync(reviewsFile, "utf-8"));
    const approved = raw
      .filter((r) => r.approved)
      .map((r) => ({ name: r.name, comment: stripEmojis(r.comment) }));
    if (approved.length >= 1) {
      reviews = approved;
    }
  }
} catch {
  // S3 oder kein Dateisystem — Fallback bleibt aktiv
}
---

<section class="blk">
  <div class="wrap">
    <div class="head">
      <span class="eyebrow">Bewertungen</span>
      <h2>Was Gäste über uns sagen</h2>
      <Brush />
    </div>
    <div class="rev-grid">
      {reviews.map((r) => (
        <blockquote class="rev">
          <Stars label="Fünf von fünf Sternen" />
          <p>„{r.comment}"</p>
          <cite>{r.name} · Google</cite>
        </blockquote>
      ))}
    </div>
  </div>
</section>

<style>
  .rev-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .rev {
    background: #fff;
    border-radius: var(--r-md, 12px);
    padding: 1.7rem;
    box-shadow: var(--shadow-card, 0 12px 28px -22px rgba(58, 45, 36, 0.3));
  }

  .rev p {
    font-family: var(--serif, serif);
    font-style: italic;
    font-size: 1.08rem;
    line-height: 1.5;
    color: var(--ink, #3a2d24);
    margin: 0.7rem 0 1rem;
  }

  .rev cite {
    font-style: normal;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--meta, #94816f);
  }
</style>
