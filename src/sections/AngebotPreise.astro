---
import Photo from '../components/Photo.astro';
import Brush from '../components/Brush.astro';
---

<section class="blk" id="angebot">
  <div class="wrap">
    <div class="head" data-animate="fade-up">
      <span class="eyebrow">Angebot und Preise</span>
      <h2>Transparent, ohne&nbsp;Überraschungen</h2>
      <Brush />
    </div>
    <div class="price-split">
      <div class="price-photos" data-animate-stagger="110">
        <div class="photo-wrap photo-hover" data-animate="scale-up">
          <Photo src="/fotos/sh-tiles.jpg" alt="Bemalte Keramikkacheln mit verschiedenen Motiven" />
        </div>
        <div class="photo-wrap photo-hover" data-animate="scale-up">
          <Photo src="/fotos/sh-dachs.jpg" alt="Schale mit Dackelmotiv" />
        </div>
        <div class="photo-wrap photo-hover" data-animate="scale-up">
          <Photo src="/fotos/sh-vase.jpg" alt="Handbemalte Vase mit Sprenkeln" />
        </div>
      </div>
      <div class="price-card" data-animate="slide-right" data-animate-delay="180">
        <h3>Rohlinge</h3>
        <ul class="price-list">
          <li><span>Tassen</span><span class="p">ab 14,50 €</span></li>
          <li><span>Teller</span><span class="p">ab 12,50 €</span></li>
          <li><span>Spardosen, Krüge und Boxen</span><span class="p">ab 8,00 €</span></li>
          <li><span>Anhänger</span><span class="p">ab 6,00 €</span></li>
        </ul>
        <p class="more-note">Und immer wieder etwas Ungewöhnliches, unser Sortiment überrascht.</p>
        <div class="pauschale">
          <b>Farb- und Brennpauschale pro Person</b>
          <ul>
            <li><span>bis 3 Teile</span><span>10,00 €</span></li>
            <li><span>4 bis 6 Teile</span><span>15,00 €</span></li>
            <li><span>7 bis 9 Teile</span><span>20,00 €</span></li>
          </ul>
        </div>
        <p class="price-note">Farben und Pinsel inklusive. Abholbereit nach 10 bis 14 Tagen.</p>
        <a href="/warum" class="warum-link">Was steckt hinter dem Preis? Ich zeige es dir &rarr;</a>
      </div>
    </div>
  </div>
</section>

<style>
  .price-split {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  @media (min-width: 820px) {
    .price-split {
      grid-template-columns: 7fr 5fr;
    }
  }

  .head {
    margin-bottom: 2.5rem;
  }

  .price-photos {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .photo-wrap {
    border-radius: var(--r-md);
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }

  .photo-wrap:first-child {
    grid-column: 1 / -1;
  }

  .photo-wrap :global(img) {
    aspect-ratio: 1;
    object-fit: cover;
    width: 100%;
    display: block;
    transition: transform 0.55s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .photo-wrap:first-child :global(img) {
    aspect-ratio: 4 / 3;
  }

  .photo-wrap:hover :global(img) {
    transform: scale(1.04);
  }

  .price-card {
    background: #fff;
    border-radius: var(--r-lg);
    padding: 2rem;
    box-shadow: var(--shadow-card);
  }

  .price-card h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .price-list {
    list-style: none;
  }

  .price-list li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: .7rem 0;
    border-bottom: 1px solid var(--hair);
    font-size: .98rem;
  }

  .price-list li:last-child {
    border: 0;
  }

  .price-list .p {
    font-weight: 700;
    color: var(--terra);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .more-note {
    margin-top: .6rem;
    font-size: .85rem;
    color: var(--ink-2);
  }

  .price-note {
    margin-top: 1.1rem;
    font-size: .85rem;
    color: var(--meta);
  }

  .warum-link {
    display: inline-block;
    margin-top: 1.2rem;
    font-size: .88rem;
    color: var(--terra);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .pauschale {
    margin-top: 1.4rem;
    background: var(--bg);
    border-radius: var(--r-sm);
    padding: 1rem 1.2rem;
  }

  .pauschale b {
    font-size: .8rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--meta);
  }

  .pauschale ul {
    list-style: none;
    margin-top: .5rem;
  }

  .pauschale li {
    display: flex;
    justify-content: space-between;
    font-size: .92rem;
    padding: .25rem 0;
  }
</style>
