---
import Photo from '../components/Photo.astro';
import Brush from '../components/Brush.astro';
---

<section class="blk" id="angebot">
  <div class="wrap">
    <div class="head">
      <span class="eyebrow">Angebot und Preise</span>
      <h2>Transparent, ohne Überraschungen</h2>
      <Brush />
    </div>
    <div class="price-split">
      <div class="price-photos">
        <Photo src="/fotos/sh-amore.jpg" alt="Handbemaltes Herztablett" />
        <Photo src="/fotos/sh-cup.jpg" alt="Auszeit-Tasse" />
        <Photo src="/fotos/sh-bee.jpg" alt="Krug mit Bienenmotiv" />
      </div>
      <div class="price-card">
        <h3>Rohlinge</h3>
        <ul class="price-list">
          <li><span>Tassen</span><span class="p">ab 14,50 €</span></li>
          <li><span>Teller</span><span class="p">ab 12,50 €</span></li>
          <li><span>Spardosen, Krüge und Boxen</span><span class="p">ab 8,00 €</span></li>
          <li><span>Anhänger</span><span class="p">ab 6,00 €</span></li>
        </ul>
        <div class="pauschale">
          <b>Farb- und Brennpauschale pro Person</b>
          <ul>
            <li><span>bis 3 Teile</span><span>10,00 €</span></li>
            <li><span>4 bis 6 Teile</span><span>15,00 €</span></li>
            <li><span>7 bis 9 Teile</span><span>20,00 €</span></li>
          </ul>
        </div>
        <p class="price-note">Farben, Pinsel und Brennen immer inklusive. Abholbereit nach 10 bis 14 Tagen.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .price-split {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    margin-top: 3rem;
    align-items: start;
  }

  @media (min-width: 820px) {
    .price-split {
      grid-template-columns: 7fr 5fr;
    }
  }

  .price-photos {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .price-photos img {
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: var(--r-md);
    box-shadow: var(--shadow-card);
  }

  .price-photos img:first-child {
    grid-column: 1 / -1;
    aspect-ratio: 16 / 10;
  }

  .price-card {
    background: #fff;
    border-radius: var(--r-lg);
    padding: 2rem;
    box-shadow: var(--shadow-card);
  }

  .price-card h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .price-list {
    list-style: none;
  }

  .price-list li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: .7rem 0;
    border-bottom: 1px solid var(--hair);
    font-size: .98rem;
  }

  .price-list li:last-child {
    border: 0;
  }

  .price-list .p {
    font-weight: 700;
    color: var(--terra);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .price-note {
    margin-top: 1.1rem;
    font-size: .85rem;
    color: var(--meta);
  }

  .pauschale {
    margin-top: 1.4rem;
    background: var(--bg);
    border-radius: var(--r-sm);
    padding: 1rem 1.2rem;
  }

  .pauschale b {
    font-size: .8rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--meta);
  }

  .pauschale ul {
    list-style: none;
    margin-top: .5rem;
  }

  .pauschale li {
    display: flex;
    justify-content: space-between;
    font-size: .92rem;
    padding: .25rem 0;
  }
</style>
