---
interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  loading?: 'eager' | 'lazy';
  fetchpriority?: 'high' | 'auto';
  sizes?: string;
  class?: string;
}
const { src, alt, width, height, loading = 'lazy', fetchpriority = 'auto', sizes, class: cls = '' } = Astro.props;
const isJpg = /\.(jpe?g)$/i.test(src);
const base = src.replace(/\.(jpe?g)$/i, '');
const imgClass = `warm ${cls}`.trim();
---
{isJpg ? (
  <picture>
    <source srcset={`${base}.avif`} type="image/avif" />
    <source srcset={`${base}.webp`} type="image/webp" />
    <img src={src} alt={alt} width={width} height={height} loading={loading} fetchpriority={fetchpriority} sizes={sizes} decoding="async" class={imgClass} />
  </picture>
) : (
  <img src={src} alt={alt} width={width} height={height} loading={loading} fetchpriority={fetchpriority} sizes={sizes} decoding="async" class={imgClass} />
)}
