---
interface Props {
  icon: string;
  title: string;
  text: string;
  number: number;
}

const { title, text } = Astro.props;
---

<div class="step-item">
  <div class="step-item__bar" />
  <h3 class="step-item__title">{title}</h3>
  <p class="step-item__text">{text}</p>
</div>

<style>
  .step-item {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .step-item__bar {
    width: 40px;
    height: 3px;
    border-radius: 2px;
    background: var(--accent-terra, #D96C4A);
    margin-bottom: var(--space-1);
  }

  .step-item__title {
    font-family: var(--font-serif, 'Lora', serif);
    color: var(--brand-espresso, #423430);
    margin: 0;
    font-size: 1.15rem;
  }

  .step-item__text {
    font-family: var(--font-sans, 'Source Sans 3', sans-serif);
    color: var(--color-text-secondary);
    line-height: 1.65;
    font-size: 0.9rem;
    margin: 0;
    max-width: 280px;
  }
</style>
