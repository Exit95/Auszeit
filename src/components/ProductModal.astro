---
// Produkt-Modal als Carousel
---

<div id="productModal" class="pmodal" role="dialog" aria-modal="true" aria-label="Produktgalerie">
  <div class="pmodal__overlay"></div>
  <div class="pmodal__box">
    <button class="pmodal__close" aria-label="Schließen">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <div class="pmodal__header">
      <h3 class="pmodal__title"></h3>
      <p class="pmodal__price"></p>
    </div>

    <!-- Carousel -->
    <div class="pmc">
      <button class="pmc__nav pmc__nav--prev" id="pmc-prev" aria-label="Vorheriges Bild">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>

      <div class="pmc__stage">
        <img id="pmc-main" class="pmc__main-img" src="" alt="" loading="eager">
      </div>

      <button class="pmc__nav pmc__nav--next" id="pmc-next" aria-label="Nächstes Bild">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>

    <div class="pmc__counter" id="pmc-counter">1 / 1</div>
  </div>
</div>

<style>
  .pmodal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
  }

  .pmodal.active {
    display: flex;
  }

  .pmodal__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.82);
    backdrop-filter: blur(4px);
    animation: pmFadeIn 0.25s ease;
  }

  @keyframes pmFadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .pmodal__box {
    position: relative;
    background: var(--color-background, #fff);
    border-radius: var(--radius, 12px);
    max-width: 840px;
    width: 100%;
    max-height: 92vh;
    overflow-y: auto;
    padding: var(--space-6);
    animation: pmSlideUp 0.28s ease;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.35);
  }

  @keyframes pmSlideUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .pmodal__close {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    background: var(--color-sienna, #A0522D);
    color: white;
    border: none;
    border-radius: 50%;
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    z-index: 10;
  }

  .pmodal__close:hover {
    background: var(--brand-espresso, #423430);
    transform: rotate(90deg);
  }

  .pmodal__header {
    text-align: center;
    margin-bottom: var(--space-4);
    padding-right: var(--space-8);
  }

  .pmodal__title {
    font-family: var(--font-serif);
    color: var(--brand-espresso, #423430);
    font-size: 1.75rem;
    margin-bottom: 0.25rem;
  }

  .pmodal__price {
    font-family: var(--font-sans);
    font-size: 1.25rem;
    color: var(--color-sienna, #A0522D);
    font-weight: 700;
  }

  /* Carousel */
  .pmc {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .pmc__stage {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 320px;
    background: var(--bg-linen, #EDE4DA);
    border-radius: 10px;
    overflow: hidden;
  }

  .pmc__main-img {
    max-height: 420px;
    max-width: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 8px;
    transition: opacity 0.18s ease;
    cursor: zoom-in;
  }

  .pmc__main-img.loading {
    opacity: 0.4;
  }

  .pmc__nav {
    background: var(--bg-linen, #EDE4DA);
    border: 1.5px solid var(--color-sienna, #A0522D);
    color: var(--color-sienna, #A0522D);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    flex-shrink: 0;
  }

  .pmc__nav:hover {
    background: var(--color-sienna, #A0522D);
    color: white;
  }

  .pmc__nav:disabled {
    opacity: 0.35;
    cursor: default;
  }

  .pmc__counter {
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    margin: 0.5rem 0;
  }

  /* Mobile */
  @media (max-width: 640px) {
    .pmodal { padding: 0; }

    .pmodal__box {
      max-height: 100dvh;
      border-radius: 0;
      padding: var(--space-4);
    }

    .pmodal__title { font-size: 1.35rem; }
    .pmodal__price { font-size: 1.1rem; }

    .pmc__stage { min-height: 220px; }
    .pmc__main-img { max-height: 260px; }
    .pmc__nav { width: 36px; height: 36px; }
  }
</style>
