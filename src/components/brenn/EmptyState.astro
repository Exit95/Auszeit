---
interface Props {
  message: string;
  hint?: string;
}

const { message, hint } = Astro.props;
---

<div class="brenn-empty">
  <p class="brenn-empty__message">{message}</p>
  {hint && <p class="brenn-empty__hint">{hint}</p>}
</div>

<style>
  .brenn-empty {
    text-align: center;
    padding: var(--space-8, 4rem) var(--space-4, 2rem);
    color: var(--color-text-secondary, #5D4E43);
  }
  .brenn-empty__message {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }
  .brenn-empty__hint {
    font-size: 0.875rem;
    margin: 0;
    opacity: 0.7;
  }
</style>
