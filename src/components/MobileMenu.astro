---
// MobileMenu.astro — off-canvas mobile navigation panel
// Burger visible below 880px (matches design-reference breakpoint)
---

<!-- Burger Button -->
<button
  class="burger"
  id="mobile-menu-btn"
  aria-label="Menü öffnen"
  aria-expanded="false"
  aria-controls="mobile-panel"
>
  <svg viewBox="0 0 28 28" width="28" height="28" fill="none" aria-hidden="true" focusable="false">
    <path d="M4 7.5C7 6.9 13 7.3 24 7.5" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
    <path d="M6 14C11 13.6 18 14.2 22 14" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
    <path d="M4 20.5C9 21.1 17 20.2 24 20.5" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
  </svg>
</button>

<!-- Off-Canvas Panel -->
<div
  id="mobile-panel"
  class="mobile-panel"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation"
  aria-hidden="true"
>
  <div class="mobile-panel__inner">
    <button
      class="mobile-panel__close"
      id="mobile-panel-close"
      aria-label="Menü schließen"
    >
      <svg viewBox="0 0 28 28" width="24" height="24" fill="none" aria-hidden="true" focusable="false">
        <path d="M6 6L22 22" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
        <path d="M22 6L6 22" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
      </svg>
    </button>

    <nav aria-label="Mobile Navigation" class="mobile-panel__nav">
      <a href="/#keramik-preise" class="mobile-panel__link">Keramik bemalen</a>
      <a href="/workshops" class="mobile-panel__link">Workshops</a>
      <a href="/events" class="mobile-panel__link">Besondere Anlasse</a>
      <a href="/galerie" class="mobile-panel__link">Galerie</a>
      <a href="/gutscheine" class="mobile-panel__link">Gutscheine</a>
      <a href="/#termin-buchen" class="mobile-panel__link mobile-panel__link--cta btn btn-terra">Termin buchen</a>
    </nav>

    <address class="mobile-panel__address">
      <span>Feldstiege 6a, 48599 Gronau (Westf.)</span>
      <a href="tel:+4917634255005">+49 176 34255005</a>
    </address>
  </div>
</div>

<!-- Overlay backdrop -->
<div class="mobile-panel__backdrop" id="mobile-panel-backdrop" aria-hidden="true"></div>

<script is:inline>
(function () {
  var btn = document.getElementById('mobile-menu-btn');
  var panel = document.getElementById('mobile-panel');
  var closeBtn = document.getElementById('mobile-panel-close');
  var backdrop = document.getElementById('mobile-panel-backdrop');

  if (!btn || !panel) return;

  function openMenu() {
    panel.classList.add('is-open');
    backdrop.classList.add('is-open');
    panel.setAttribute('aria-hidden', 'false');
    btn.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    // Move focus into panel
    setTimeout(function () {
      var first = panel.querySelector('button, a');
      if (first) first.focus();
    }, 50);
  }

  function closeMenu() {
    panel.classList.remove('is-open');
    backdrop.classList.remove('is-open');
    panel.setAttribute('aria-hidden', 'true');
    btn.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    btn.focus();
  }

  btn.addEventListener('click', openMenu);
  closeBtn && closeBtn.addEventListener('click', closeMenu);
  backdrop.addEventListener('click', closeMenu);

  // Close on any nav link click
  panel.querySelectorAll('.mobile-panel__link').forEach(function (link) {
    link.addEventListener('click', closeMenu);
  });

  // Escape closes
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && panel.classList.contains('is-open')) {
      closeMenu();
    }
  });
})();
</script>

<style>
  /* ── Burger button ────────────────────────── */
  .burger {
    display: none;
    background: none;
    border: none;
    color: var(--ink);
    padding: 8px;
    border-radius: 8px;
    min-width: 44px;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background var(--dur-fast, 180ms);
    position: relative;
    z-index: 42;
  }

  .burger:hover {
    background: rgba(58, 45, 36, 0.07);
  }

  @media (max-width: 880px) {
    .burger {
      display: flex;
    }
  }

  /* ── Backdrop ─────────────────────────────── */
  .mobile-panel__backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 49;
    background: rgba(58, 45, 36, 0.45);
    opacity: 0;
    transition: opacity 300ms var(--ease-smooth, ease);
  }

  .mobile-panel__backdrop.is-open {
    display: block;
    opacity: 1;
  }

  /* ── Off-canvas panel ─────────────────────── */
  .mobile-panel {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    z-index: 50;
    width: min(320px, 90vw);
    background: var(--bg, #F7F1EA);
    transform: translateX(100%);
    transition: transform 320ms var(--ease-smooth, cubic-bezier(0.22, 0.61, 0.36, 1));
    overflow-y: auto;
    /* keep panel hidden from AT when closed */
    visibility: hidden;
  }

  .mobile-panel.is-open {
    transform: translateX(0);
    visibility: visible;
    box-shadow: -8px 0 32px rgba(58, 45, 36, 0.18);
  }

  /* ── Inner layout ─────────────────────────── */
  .mobile-panel__inner {
    display: flex;
    flex-direction: column;
    padding: 5rem 1.75rem 2.5rem;
    min-height: 100%;
  }

  /* ── Close button ─────────────────────────── */
  .mobile-panel__close {
    position: absolute;
    top: 0.9rem;
    right: 1rem;
    background: none;
    border: none;
    color: var(--ink-2, #5D4A3C);
    min-width: 44px;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    cursor: pointer;
    transition: background var(--dur-fast, 180ms);
  }

  .mobile-panel__close:hover {
    background: var(--surface, #EDE3D8);
  }

  /* ── Nav links ────────────────────────────── */
  .mobile-panel__nav {
    display: flex;
    flex-direction: column;
    gap: 0;
    flex: 1;
  }

  .mobile-panel__link {
    display: block;
    padding: 0.9rem 0;
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--ink, #3A2D24);
    text-decoration: none;
    border-bottom: 1px solid var(--hair, #E4D8CB);
    min-height: 44px;
    line-height: 1.2;
    transition: color var(--dur-fast, 180ms), padding-left var(--dur-fast, 180ms);
  }

  .mobile-panel__link:hover {
    color: var(--terra, #D96C4A);
    padding-left: 0.4rem;
  }

  .mobile-panel__link--cta {
    margin-top: 1.5rem;
    text-align: center;
    border-bottom: none;
    border-radius: 10px;
    padding: 0.82rem 1.7rem;
    font-size: 1rem;
  }

  .mobile-panel__link--cta:hover {
    padding-left: 1.7rem; /* override the indent */
    color: #fff;
  }

  /* ── Address block ────────────────────────── */
  .mobile-panel__address {
    margin-top: 2rem;
    font-style: normal;
    font-size: 0.82rem;
    color: var(--meta, #94816F);
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .mobile-panel__address a {
    color: var(--meta, #94816F);
    text-decoration: none;
  }

  .mobile-panel__address a:hover {
    color: var(--terra, #D96C4A);
  }
</style>
