---
interface Props {
  href?: string;
  variant?: "primary" | "secondary";
  size?: "small" | "medium" | "large";
  type?: "button" | "submit" | "reset";
  ariaLabel?: string;
}

const {
  href,
  variant = "primary",
  size = "medium",
  type = "button",
  ariaLabel,
} = Astro.props;

const Tag = href ? "a" : "button";
---

<Tag
  href={href}
  type={!href ? type : undefined}
  class={`btn btn--${variant} btn--${size}`}
  aria-label={ariaLabel}
>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-family: var(--font-sans);
    font-weight: 650;
    font-size: 14px;
    border-radius: 14px;
    border: 0;
    cursor: pointer;
    transition: transform 140ms ease, box-shadow 140ms ease, background 140ms ease, color 140ms ease, border-color 140ms ease;
    text-decoration: none;
    white-space: nowrap;
    min-height: 44px;
    padding: 12px 16px;
  }

  .btn--small {
    font-size: 0.875rem;
    padding: 10px 14px;
    min-height: 36px;
  }

  .btn--medium {
    font-size: 14px;
  }

  .btn--large {
    font-size: 15px;
    padding: 14px 20px;
    min-height: 52px;
  }

  .btn--primary {
    background: var(--accent-terra, #D96C4A);
    color: #fff;
    box-shadow: 0 12px 22px rgba(217, 108, 74, 0.22);
  }

  .btn--primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 14px 26px rgba(217, 108, 74, 0.28);
    background: var(--color-sienna, #A0522D);
  }

  .btn--primary:active {
    transform: translateY(0);
  }

  .btn--secondary {
    background: rgba(66, 52, 48, 0.04);
    color: var(--color-sienna, #A0522D);
    border: 1px solid var(--color-sienna, #A0522D);
  }

  .btn--secondary:hover {
    transform: translateY(-1px);
    background: rgba(160, 82, 45, 0.07);
    border-color: var(--color-sienna, #A0522D);
  }

  .btn--secondary:active {
    transform: translateY(0);
  }

  /* Mobile Optimierungen */
  @media (max-width: 639px) {
    .btn {
      width: 100%;
      justify-content: center;
    }

    .btn--large {
      min-height: 48px;
    }
  }

  @media (max-width: 374px) {
    .btn {
      font-size: 14px;
      padding: 12px 16px;
    }

    .btn--large {
      font-size: 14px;
      padding: 12px 18px;
    }
  }
</style>
