---
interface Props {
  href?: string;
  variant?: 'terra' | 'ghost';
  type?: 'button' | 'submit';
  class?: string;
}
const { href, variant = 'terra', type = 'button', class: cls = '' } = Astro.props;
const klass = `btn btn-${variant} ${cls}`.trim();
---
{href ? (
  <a href={href} class={klass}><slot /></a>
) : (
  <button type={type} class={klass}><slot /></button>
)}
