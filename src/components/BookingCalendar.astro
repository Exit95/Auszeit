---
import Brush from './Brush.astro';
---

<section class="blk soft" id="buchen" style="scroll-margin-top:60px">
  <div class="wrap">
    <div class="head center">
      <span class="eyebrow">Termin buchen</span>
      <h2>Sichere dir deinen Platz</h2>
      <Brush />
      <p class="lead">Wähle einen Tag und eine Uhrzeit, den Rest übernehmen wir.</p>
    </div>

    <div class="book-card" id="calCard">
      <!-- Kalender-Ansicht -->
      <div class="cal" id="calView">
        <div class="cal-main">
          <div class="cal-head">
            <b id="calMonthLabel">Lade…</b>
            <div class="cal-nav">
              <button type="button" id="calPrev" aria-label="Voriger Monat">&#8249;</button>
              <button type="button" id="calNext" aria-label="Nächster Monat">&#8250;</button>
            </div>
          </div>
          <div class="cal-grid" id="calGrid">
            <div class="cal-wd">Mo</div>
            <div class="cal-wd">Di</div>
            <div class="cal-wd">Mi</div>
            <div class="cal-wd">Do</div>
            <div class="cal-wd">Fr</div>
            <div class="cal-wd">Sa</div>
            <div class="cal-wd">So</div>
          </div>
          <div class="cal-legend">
            <span><i style="background:var(--terra)"></i>freie Tage</span>
            <span><i style="background:var(--meta);opacity:.4"></i>belegt oder Ruhetag</span>
            <span><i style="background:#e8b86d;opacity:.7"></i>Urlaub / geschlossen</span>
          </div>
        </div>

        <div class="cal-side" id="calSide">
          <p class="cal-side-placeholder">Wähle einen Tag im Kalender, um verfügbare Uhrzeiten zu sehen.</p>
          <div id="calSideDynamic" class="hidden">
            <h3 id="calSideDate"></h3>
            <div class="hours">Wähle eine Uhrzeit, je Termin ca. 2 Stunden</div>
            <div class="times" id="calTimes"></div>
            <button type="button" class="btn btn-terra" id="calProceed" disabled>Weiter zur Buchung</button>
            <span class="book-note">Kostenlos stornierbar bis 24 Stunden vorher</span>
          </div>
        </div>
      </div>

      <!-- Buchungsformular -->
      <div id="bookingForm" class="booking-form hidden">
        <div class="booking-trust">
          <div class="booking-trust__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="booking-trust__quote">„Ein wunderschöner Nachmittag! Wir kommen wieder."</p>
          <span class="booking-trust__source">Google Bewertung</span>
        </div>
        <h3>Buchung bestätigen</h3>
        <div class="booking-details">
          <p><strong>Datum:</strong> <span id="selectedDate"></span></p>
          <p><strong>Uhrzeit:</strong> <span id="selectedTime"></span></p>
          <p><strong>Verfügbare Plätze:</strong> <span id="availableCapacity"></span></p>
        </div>

        <form id="bookingFormElement">
          <div class="form-group">
            <label for="bookName">Name *</label>
            <input type="text" id="bookName" name="name" required autocomplete="name" />
          </div>
          <div class="form-group">
            <label for="bookEmail">E-Mail *</label>
            <input type="email" id="bookEmail" name="email" required autocomplete="email" />
          </div>
          <div class="form-group">
            <label for="bookPhone">Telefon *</label>
            <input type="tel" id="bookPhone" name="phone" required autocomplete="tel" />
          </div>
          <div class="form-group">
            <label for="bookParticipants">Anzahl Personen *</label>
            <input type="number" id="bookParticipants" name="participants" min="1" max="15" value="1" required />
          </div>

          <div id="participantNamesContainer" class="participant-names-container hidden">
            <label class="participant-names-label">Namen der weiteren Teilnehmer *</label>
            <p class="participant-names-hint">Ihr Name wird automatisch als Teilnehmer 1 übernommen.</p>
            <div id="participantNameFields"></div>
          </div>

          <div class="form-group">
            <label for="bookNotes">Anmerkungen</label>
            <textarea id="bookNotes" name="notes" rows="3"></textarea>
          </div>

          <p class="booking-privacy-note">
            Mit dem Absenden stimmst du der Verarbeitung deiner Angaben zur Bearbeitung deiner Buchung zu.
            Details dazu in unserer <a href="/datenschutz">Datenschutzerklärung</a>.
          </p>

          <div class="form-actions">
            <button type="button" class="btn btn-ghost" id="backToCalendar">Zurück</button>
            <button type="submit" class="btn btn-terra">Verbindlich buchen</button>
          </div>

          <div class="trust-bar">
            <span class="trust-bar__item">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              5,0 von 5, 33 Bewertungen
            </span>
            <span class="trust-bar__item">
              Kostenlose Stornierung bis 24h vorher
            </span>
          </div>
        </form>
      </div>

      <!-- Erfolgs-/Fehlermeldung -->
      <div id="bookMsg" class="book-msg hidden" role="alert" aria-live="assertive"></div>
    </div>
  </div>
</section>

<style>
  /* ---- Book card wrapper ---- */
  .book-card {
    max-width: 940px;
    margin: 2.6rem auto 0;
    background: #fff;
    border-radius: var(--r-lg);
    padding: clamp(1.4rem, 3.5vw, 2.4rem);
    box-shadow: var(--shadow-soft);
  }

  /* ---- Calendar two-column grid ---- */
  .cal {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.4rem, 3vw, 2.2rem);
  }
  @media (min-width: 780px) {
    .cal { grid-template-columns: 1.3fr 1fr; }
    .cal-side { border-left: 1px solid var(--hair); padding-left: clamp(1.4rem, 3vw, 2.2rem); }
  }

  /* ---- Calendar header ---- */
  .cal-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }
  .cal-head b {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 1.35rem;
  }
  .cal-nav { display: flex; gap: .5rem; }
  .cal-nav button {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 1.5px solid var(--hair);
    background: #fff;
    color: var(--ink-2);
    font-size: 1.15rem;
    cursor: pointer;
    line-height: 1;
    transition: border-color .15s, color .15s;
  }
  .cal-nav button:hover {
    border-color: var(--terra);
    color: var(--terra);
  }
  .cal-nav button:focus-visible {
    outline: 2px solid var(--terra);
    outline-offset: 2px;
  }

  /* ---- Calendar grid ---- */
  .cal-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: .25rem;
  }
  .cal-wd {
    font-size: .66rem;
    text-transform: uppercase;
    letter-spacing: .05em;
    color: var(--meta);
    text-align: center;
    padding-bottom: .5rem;
    font-weight: 600;
  }
  /* per JS erzeugte Tageszellen -> :global, sonst greifen Astros gescopte Styles nicht */
  :global(.cal-grid .day) {
    aspect-ratio: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    border-radius: 13px;
    font-size: .95rem;
    cursor: pointer;
    border: 0;
    background: transparent;
    color: var(--ink);
    transition: background .15s, color .15s;
    font-family: var(--font-sans);
    min-height: var(--touch-min);
  }
  :global(.cal-grid .day:hover) { background: var(--surface); }
  :global(.cal-grid .day:focus-visible) { outline: 2px solid var(--terra); outline-offset: 2px; }
  :global(.cal-grid .day .dot) { width: 5px; height: 5px; border-radius: 50%; background: var(--terra); }
  :global(.cal-grid .day.is-vacation) {
    background: #e8b86d18;
    color: #a07830;
    cursor: default;
    pointer-events: none;
    position: relative;
    font-size: .75rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1px;
    padding: 2px;
    border: 1px solid #e8b86d40;
    border-radius: 6px;
  }
  :global(.cal-grid .day.is-vacation .vacation-lbl) {
    font-size: .55rem;
    line-height: 1;
    color: #a07830;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }
  :global(.cal-grid .day.is-muted) {
    color: var(--meta);
    opacity: .4;
    cursor: default;
    pointer-events: none;
  }
  :global(.cal-grid .day.is-sel) {
    background: var(--terra);
    color: #fff;
    font-weight: 700;
    box-shadow: 0 12px 22px -10px rgba(217,108,74,.6);
  }
  :global(.cal-grid .day.is-sel .dot) { background: #fff; }
  :global(.cal-grid .day.is-empty) { cursor: default; background: transparent; pointer-events: none; }

  /* ---- Legend ---- */
  .cal-legend {
    display: flex;
    gap: 1.4rem;
    font-size: .76rem;
    color: var(--meta);
    margin-top: 1.1rem;
    flex-wrap: wrap;
  }
  .cal-legend span { display: inline-flex; align-items: center; gap: .4rem; }
  .cal-legend i { width: 7px; height: 7px; border-radius: 50%; display: inline-block; }

  /* ---- Side panel ---- */
  .cal-side-placeholder {
    font-size: .92rem;
    color: var(--meta);
    padding-top: .5rem;
  }
  .cal-side h3 {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 1.35rem;
    margin-bottom: .2rem;
  }
  .hours {
    font-size: .84rem;
    color: var(--meta);
    margin-bottom: 1.1rem;
  }
  .times { display: flex; gap: .6rem; flex-wrap: wrap; }
  /* per JS erzeugte Zeit-Pillen -> :global */
  :global(.times .timepill) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
    border: 1.5px solid var(--hair);
    background: #fff;
    border-radius: 14px;
    padding: .5rem 1.05rem;
    font-weight: 600;
    color: var(--ink-2);
    cursor: pointer;
    transition: border-color .16s, color .16s, transform .16s, background .16s;
    font-family: var(--font-sans);
    min-height: var(--touch-min);
    min-width: var(--touch-min);
  }
  :global(.times .timepill:hover) {
    border-color: var(--terra);
    color: var(--terra);
    transform: translateY(-1px);
  }
  :global(.times .timepill:focus-visible) { outline: 2px solid var(--terra); outline-offset: 2px; }
  :global(.times .timepill.is-active) { background: var(--terra); border-color: var(--terra); color: #fff; }
  :global(.times .timepill.is-off) {
    opacity: .4;
    text-decoration: line-through;
    cursor: default;
    pointer-events: none;
  }
  :global(.times .tp-time) { font-size: .98rem; line-height: 1.1; }
  :global(.times .tp-free) { font-size: .68rem; font-weight: 500; color: var(--meta); letter-spacing: .01em; }
  :global(.times .timepill.is-low .tp-free) { color: var(--terra); }
  :global(.times .timepill.is-active .tp-free) { color: rgba(255,255,255,.88); }
  #calProceed {
    margin-top: 1.4rem;
    width: 100%;
    text-align: center;
  }
  #calProceed:disabled { opacity: .45; cursor: default; }
  .book-note { display: block; margin-top: .8rem; font-size: .82rem; color: var(--meta); text-align: center; }

  /* ---- Booking form ---- */
  .booking-form {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--hair);
  }
  .booking-form h3 {
    font-family: var(--font-serif);
    color: var(--ink);
    margin-bottom: .75rem;
    font-size: 1.25rem;
  }
  .booking-trust {
    text-align: center;
    padding: 1rem;
    margin-bottom: 1rem;
    background: var(--surface);
    border-radius: var(--r-md);
    border-left: 3px solid var(--terra);
  }
  .booking-trust__stars { color: #FBBC05; font-size: 1.1rem; letter-spacing: 2px; }
  .booking-trust__quote { font-style: italic; color: var(--ink); font-size: .95rem; margin: .4rem 0; }
  .booking-trust__source { font-size: .8rem; color: var(--meta); }
  .booking-details {
    background: var(--surface);
    padding: .75rem 1rem;
    border-radius: var(--r-md);
    margin-bottom: 1.25rem;
    border: 1px solid var(--hair);
  }
  .booking-details p { margin-bottom: .25rem; font-size: .9rem; }
  .form-group { margin-bottom: .875rem; }
  .form-group label {
    display: block;
    margin-bottom: .25rem;
    font-weight: 550;
    font-size: .875rem;
    color: var(--ink);
  }
  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: .75rem;
    border: 1px solid var(--hair);
    border-radius: var(--r-sm);
    font-family: var(--font-sans);
    font-size: .9rem;
    background: rgba(255,255,255,.8);
    color: var(--ink);
    transition: border-color .14s, box-shadow .14s;
    box-sizing: border-box;
  }
  .form-group input:focus,
  .form-group textarea:focus {
    outline: 2px solid transparent;
    border-color: var(--terra);
    box-shadow: 0 0 0 3px rgba(217,108,74,.12);
  }
  .participant-names-container { margin-bottom: .875rem; }
  .participant-names-container.hidden { display: none; }
  .participant-names-hint { font-size: .8rem; color: var(--meta); margin: 0 0 .5rem; font-style: italic; }
  .participant-names-label {
    display: block;
    margin-bottom: .25rem;
    font-weight: 550;
    font-size: .875rem;
    color: var(--ink);
  }
  .participant-name-field { display: flex; align-items: center; gap: .5rem; margin-bottom: .5rem; }
  .participant-name-field span { min-width: 1.5rem; font-size: .85rem; font-weight: 600; color: var(--terra); }
  .participant-name-field input {
    flex: 1;
    padding: .75rem;
    border: 1px solid var(--hair);
    border-radius: var(--r-sm);
    font-family: var(--font-sans);
    font-size: .9rem;
    background: rgba(255,255,255,.8);
    color: var(--ink);
    transition: border-color .14s, box-shadow .14s;
  }
  .participant-name-field input:focus {
    outline: 2px solid transparent;
    border-color: var(--terra);
    box-shadow: 0 0 0 3px rgba(217,108,74,.12);
  }
  .booking-privacy-note {
    margin: .25rem 0 .75rem;
    font-size: .8rem;
    color: var(--meta);
    line-height: 1.5;
  }
  .booking-privacy-note a { color: var(--terra); text-decoration: underline; }
  .form-actions {
    display: flex;
    gap: .5rem;
    justify-content: flex-end;
    margin-top: 1rem;
    flex-wrap: wrap;
  }
  @media (max-width: 480px) {
    .form-actions { flex-direction: column; }
    .form-actions .btn { width: 100%; text-align: center; }
  }
  .trust-bar {
    display: flex;
    flex-direction: column;
    gap: .5rem;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--hair);
  }
  .trust-bar__item {
    display: flex;
    align-items: center;
    gap: .5rem;
    font-size: .85rem;
    color: var(--ink-2);
  }
  .trust-bar__item svg { flex-shrink: 0; color: var(--terra); }

  /* ---- Message ---- */
  .book-msg {
    margin-top: 1.25rem;
    padding: .875rem 1rem;
    border-radius: var(--r-md);
    text-align: center;
    font-size: .9rem;
  }
  .book-msg.success { background: rgba(74,124,89,.1); color: #3a6e4a; border: 1px solid rgba(74,124,89,.2); }
  .book-msg.error   { background: rgba(185,74,72,.08); color: #a03030; border: 1px solid rgba(185,74,72,.2); }

  /* ---- Utility ---- */
  .hidden { display: none !important; }
</style>

<script>
  interface Slot {
    date: string;
    time: string;
    endTime?: string;
    maxCapacity: number;
    available: number;
    id: string;
    eventType?: string;
    isBlocked?: boolean;
    blockedReason?: string;
  }

  interface BlockedPeriod { from: string; to: string; reason: string; }

  // ── State ────────────────────────────────────────────────────────────────
  let allSlots: Slot[] = [];
  let blockedPeriods: BlockedPeriod[] = [];
  let viewYear  = new Date().getFullYear();
  let viewMonth = new Date().getMonth(); // 0-based
  let selDateISO: string | null = null;
  let selTime: string | null = null;
  let selTimeDisplay: string | null = null;
  let selCapacity = 0;
  let selMax = 0;

  // ── DOM refs ─────────────────────────────────────────────────────────────
  const calGrid      = document.getElementById('calGrid')    as HTMLElement;
  const calMonthLbl  = document.getElementById('calMonthLabel') as HTMLElement;
  const calPrev      = document.getElementById('calPrev')    as HTMLButtonElement;
  const calNext      = document.getElementById('calNext')    as HTMLButtonElement;
  const calSideDyn   = document.getElementById('calSideDynamic') as HTMLElement;
  const calPlaceholder = document.querySelector('.cal-side-placeholder') as HTMLElement;
  const calSideDate  = document.getElementById('calSideDate')  as HTMLElement;
  const calTimes     = document.getElementById('calTimes')   as HTMLElement;
  const calProceed   = document.getElementById('calProceed') as HTMLButtonElement;
  const calView      = document.getElementById('calView')    as HTMLElement;
  const bookingForm  = document.getElementById('bookingForm') as HTMLElement;
  const bookMsg      = document.getElementById('bookMsg')    as HTMLElement;
  const selectedDateEl = document.getElementById('selectedDate') as HTMLElement;
  const selectedTimeEl = document.getElementById('selectedTime') as HTMLElement;
  const capacityEl   = document.getElementById('availableCapacity') as HTMLElement;

  // ── Helpers ───────────────────────────────────────────────────────────────
  const DE_MONTHS = ['Januar','Februar','März','April','Mai','Juni','Juli','August','September','Oktober','November','Dezember'];
  const DE_WD_LONG = ['Sonntag','Montag','Dienstag','Mittwoch','Donnerstag','Freitag','Samstag'];

  function toISO(y: number, m: number, d: number): string {
    return `${y}-${String(m+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
  }

  function slotsForDate(iso: string): Slot[] {
    return allSlots.filter(s => s.date === iso && !s.isBlocked && s.available > 0);
  }

  function hasFreeSlotsInMonth(y: number, m: number): boolean {
    const prefix = `${y}-${String(m+1).padStart(2,'0')}-`;
    return allSlots.some(s => s.date.startsWith(prefix) && !s.isBlocked && s.available > 0);
  }

  function getBlockedReason(iso: string): string | null {
    const p = blockedPeriods.find(b => iso >= b.from && iso <= b.to);
    return p ? p.reason : null;
  }

  // ── Calendar render ───────────────────────────────────────────────────────
  function renderCalendar() {
    calMonthLbl.textContent = `${DE_MONTHS[viewMonth]} ${viewYear}`;

    // Disable prev if current month ≤ today's month
    const today = new Date();
    const todayY = today.getFullYear();
    const todayM = today.getMonth();
    calPrev.disabled = (viewYear < todayY) || (viewYear === todayY && viewMonth <= todayM);

    // Remove old day cells (keep 7 .cal-wd headers)
    const children = Array.from(calGrid.children);
    children.slice(7).forEach(c => c.remove());

    // First weekday of month (0=Sun … 6=Sat), convert to Mon-start (0=Mon … 6=Sun)
    const firstDay = new Date(viewYear, viewMonth, 1).getDay();
    const leadingEmpties = (firstDay === 0 ? 6 : firstDay - 1); // Mon=0 offset
    const daysInMonth = new Date(viewYear, viewMonth + 1, 0).getDate();

    // Leading empty cells
    for (let i = 0; i < leadingEmpties; i++) {
      const el = document.createElement('div');
      el.className = 'day is-empty';
      el.setAttribute('aria-hidden', 'true');
      calGrid.appendChild(el);
    }

    const todayISO = toISO(todayY, todayM, today.getDate());

    for (let d = 1; d <= daysInMonth; d++) {
      const iso = toISO(viewYear, viewMonth, d);
      const dow = new Date(viewYear, viewMonth, d).getDay(); // 0=Sun, 1=Mon …
      const isMonday = dow === 1;
      const isPast = iso < todayISO;
      const freeSlots = slotsForDate(iso);
      const hasFree = freeSlots.length > 0;

      const btn = document.createElement('button');
      btn.type = 'button';
      btn.textContent = String(d);
      btn.setAttribute('aria-label', `${d}. ${DE_MONTHS[viewMonth]}`);

      const blockedReason = getBlockedReason(iso);

      if (isPast || isMonday) {
        btn.className = 'day is-muted';
        btn.disabled = true;
        btn.setAttribute('aria-disabled', 'true');
      } else if (blockedReason) {
        btn.className = 'day is-vacation';
        btn.disabled = true;
        btn.setAttribute('aria-disabled', 'true');
        btn.setAttribute('title', blockedReason);
        const lbl = document.createElement('span');
        lbl.className = 'vacation-lbl';
        lbl.textContent = blockedReason.length > 7 ? 'Urlaub' : blockedReason;
        btn.appendChild(lbl);
      } else if (!hasFree) {
        btn.className = 'day is-muted';
        btn.disabled = true;
        btn.setAttribute('aria-disabled', 'true');
      } else {
        btn.className = 'day';
        const dot = document.createElement('span');
        dot.className = 'dot';
        dot.setAttribute('aria-hidden', 'true');
        btn.appendChild(dot);

        if (iso === selDateISO) {
          btn.classList.add('is-sel');
        }

        btn.addEventListener('click', () => selectDate(iso));
      }

      calGrid.appendChild(btn);
    }

    // Trailing empty cells to fill row
    const totalCells = leadingEmpties + daysInMonth;
    const trailingEmpties = (7 - (totalCells % 7)) % 7;
    for (let i = 0; i < trailingEmpties; i++) {
      const el = document.createElement('div');
      el.className = 'day is-empty';
      el.setAttribute('aria-hidden', 'true');
      calGrid.appendChild(el);
    }
  }

  // ── Date selection ────────────────────────────────────────────────────────
  function selectDate(iso: string) {
    selDateISO = iso;
    selTime = null;
    selTimeDisplay = null;
    calProceed.disabled = true;

    // Re-render to update .is-sel
    renderCalendar();

    // Parse display date
    const [y, m, d] = iso.split('-').map(Number);
    const dow = new Date(y, m - 1, d).getDay();
    calSideDate.textContent = `${DE_WD_LONG[dow]}, ${d}. ${DE_MONTHS[m - 1]}`;

    // Build time pills
    calTimes.innerHTML = '';
    const daySlots = slotsForDate(iso);

    if (daySlots.length === 0) {
      const p = document.createElement('p');
      p.style.fontSize = '.9rem';
      p.style.color = 'var(--meta)';
      p.textContent = 'Keine freien Zeiten an diesem Tag.';
      calTimes.appendChild(p);
    } else {
      daySlots.forEach(slot => {
        const pill = document.createElement('button');
        pill.type = 'button';
        pill.className = 'timepill' + (slot.available <= 2 ? ' is-low' : '');
        const t = document.createElement('span');
        t.className = 'tp-time';
        t.textContent = slot.time;
        const f = document.createElement('span');
        f.className = 'tp-free';
        f.textContent = slot.available === 1 ? 'noch 1 frei' : `noch ${slot.available} frei`;
        pill.appendChild(t);
        pill.appendChild(f);
        pill.setAttribute('aria-label', `Uhrzeit ${slot.time}, noch ${slot.available} von ${slot.maxCapacity} Plätzen frei`);
        pill.addEventListener('click', () => selectTime(slot, pill));
        calTimes.appendChild(pill);
      });
    }

    // Show side panel
    calPlaceholder.classList.add('hidden');
    calSideDyn.classList.remove('hidden');
  }

  // ── Time selection ────────────────────────────────────────────────────────
  function selectTime(slot: Slot, pillEl: HTMLButtonElement) {
    selTime = slot.time;
    selTimeDisplay = slot.endTime ? `${slot.time} bis ${slot.endTime} Uhr` : `${slot.time} Uhr`;
    selCapacity = slot.available;
    selMax = slot.maxCapacity;

    // Visual state
    calTimes.querySelectorAll<HTMLButtonElement>('.timepill').forEach(p => p.classList.remove('is-active'));
    pillEl.classList.add('is-active');
    calProceed.disabled = false;
  }

  // ── Proceed to booking form ───────────────────────────────────────────────
  calProceed.addEventListener('click', () => {
    if (!selDateISO || !selTime) return;

    const [y, m, d] = selDateISO.split('-').map(Number);
    const dow = new Date(y, m - 1, d).getDay();
    const dateDisplay = `${DE_WD_LONG[dow]}, ${d}. ${DE_MONTHS[m - 1]} ${y}`;

    selectedDateEl.textContent = dateDisplay;
    selectedDateEl.dataset.isoDate = selDateISO;
    selectedTimeEl.textContent = selTimeDisplay || selTime;
    selectedTimeEl.dataset.time = selTime;
    const booked = Math.max(0, selMax - selCapacity);
    capacityEl.textContent = `${selCapacity} von ${selMax} frei (${booked} gebucht)`;

    calView.classList.add('hidden');
    bookingForm.classList.remove('hidden');
    bookingForm.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  // ── Back to calendar ──────────────────────────────────────────────────────
  document.getElementById('backToCalendar')?.addEventListener('click', () => {
    bookingForm.classList.add('hidden');
    calView.classList.remove('hidden');
  });

  // ── Month navigation ──────────────────────────────────────────────────────
  calPrev.addEventListener('click', () => {
    if (viewMonth === 0) { viewMonth = 11; viewYear--; }
    else { viewMonth--; }
    selDateISO = null;
    selTime = null;
    calSideDyn.classList.add('hidden');
    calPlaceholder.classList.remove('hidden');
    renderCalendar();
  });

  calNext.addEventListener('click', () => {
    if (viewMonth === 11) { viewMonth = 0; viewYear++; }
    else { viewMonth++; }
    selDateISO = null;
    selTime = null;
    calSideDyn.classList.add('hidden');
    calPlaceholder.classList.remove('hidden');
    renderCalendar();
  });

  // ── Participant name fields ───────────────────────────────────────────────
  function updateParticipantNameFields(count: number): void {
    const container = document.getElementById('participantNameFields');
    const wrapper   = document.getElementById('participantNamesContainer');
    if (!container || !wrapper) return;
    container.innerHTML = '';
    if (count <= 1) { wrapper.classList.add('hidden'); return; }
    wrapper.classList.remove('hidden');
    for (let i = 2; i <= count; i++) {
      const field = document.createElement('div');
      field.className = 'participant-name-field';
      field.innerHTML = `<span>${i}.</span><input type="text" name="participantName_${i}" placeholder="Name Teilnehmer ${i}" required />`;
      container.appendChild(field);
    }
  }
  updateParticipantNameFields(1);

  const participantsInput = document.getElementById('bookParticipants') as HTMLInputElement;
  participantsInput?.addEventListener('input', () => {
    const n = Math.min(Math.max(parseInt(participantsInput.value, 10) || 1, 1), 15);
    updateParticipantNameFields(n);
  });

  // ── Form submit ───────────────────────────────────────────────────────────
  document.getElementById('bookingFormElement')?.addEventListener('submit', async (e: Event) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    if (!submitBtn) return;

    const origText = submitBtn.textContent || 'Verbindlich buchen';
    submitBtn.disabled = true;
    submitBtn.textContent = 'Wird gesendet…';

    const fd = new FormData(form);
    const participantCount = parseInt(fd.get('participants') as string, 10) || 1;
    const bookerName = ((fd.get('name') as string) || '').trim();
    const participantNames: string[] = [bookerName];
    let missingNames = false;
    for (let i = 2; i <= participantCount; i++) {
      const n = ((fd.get(`participantName_${i}`) as string) || '').trim();
      if (!n) missingNames = true;
      else participantNames.push(n);
    }
    if (missingNames && participantCount > 1) {
      showMsg('Bitte gib die Namen aller Teilnehmer an.', 'error');
      submitBtn.disabled = false;
      submitBtn.textContent = origText;
      return;
    }

    const isoDate = selectedDateEl.dataset.isoDate || '';
    const timeVal = selectedTimeEl.dataset.time   || '';

    const payload = {
      date: isoDate,
      time: timeVal,
      name: fd.get('name') as string,
      email: fd.get('email') as string,
      phone: fd.get('phone') as string,
      participants: fd.get('participants') as string,
      participantNames,
      notes: fd.get('notes') as string,
    };

    try {
      const res = await fetch('/api/booking', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const result = await res.json();

      if (res.ok && result.success) {
        bookingForm.classList.add('hidden');
        calView.classList.remove('hidden');
        form.reset();
        updateParticipantNameFields(1);
        selDateISO = null;
        selTime = null;
        calSideDyn.classList.add('hidden');
        calPlaceholder.classList.remove('hidden');
        renderCalendar();
        showMsg('Geschafft! Deine Anfrage ist bei mir angekommen. Schau gleich in dein Postfach, die Bestätigung mit Kalendereintrag ist schon unterwegs.', 'success');
        setTimeout(() => bookMsg.classList.add('hidden'), 8000);
      } else {
        throw new Error(result.message || 'Buchung fehlgeschlagen');
      }
    } catch (err) {
      console.error('Buchungsfehler:', err);
      showMsg('Das hat gerade nicht geklappt. Versuch es in einem Moment nochmal oder schreib mir auf WhatsApp, ich helf dir sofort.', 'error');
      setTimeout(() => bookMsg.classList.add('hidden'), 6000);
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = origText;
    }
  });

  function showMsg(text: string, type: 'success' | 'error') {
    bookMsg.textContent = text;
    bookMsg.className = `book-msg ${type}`;
    bookMsg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  // ── Initial load ──────────────────────────────────────────────────────────
  async function init() {
    // Render placeholder calendar immediately
    renderCalendar();

    try {
      const res = await fetch('/api/slots');
      if (res.ok) {
        const data = await res.json();
        allSlots = data.slots ?? data;
        blockedPeriods = data.blockedPeriods ?? [];
      }
    } catch (err) {
      console.error('Fehler beim Laden der Termine:', err);
    }

    // Re-render with actual data; jump to first month that has free slots if current has none
    if (!hasFreeSlotsInMonth(viewYear, viewMonth)) {
      const today = new Date();
      let y = today.getFullYear();
      let m = today.getMonth();
      for (let i = 0; i < 6; i++) {
        if (hasFreeSlotsInMonth(y, m)) { viewYear = y; viewMonth = m; break; }
        if (m === 11) { m = 0; y++; } else { m++; }
      }
    }

    renderCalendar();
  }

  document.addEventListener('DOMContentLoaded', init);
</script>
